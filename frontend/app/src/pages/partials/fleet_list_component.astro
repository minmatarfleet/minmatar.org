---
import { i18n } from '@helpers/i18n'
const { t, translatePath } = i18n(Astro.url)

import { HTTP_403_Forbidden } from '@helpers/http_responses'

import type { User } from '@dtypes/jwt'
import * as jose from 'jose'

const auth_token = Astro.cookies.has('auth_token') ? (Astro.cookies.get('auth_token')?.value as string) : false
const user:User | false = auth_token ? jose.decodeJwt(auth_token) as User : false
const is_superuser = (user ? user?.is_superuser : false)

if (!user)
    return HTTP_403_Forbidden()

import { get_user_permissions } from '@helpers/permissions'
const user_permissions = (user ? await get_user_permissions(user?.username) : [])

const can_view_fleets = is_superuser || user_permissions.includes('fleets.view_evefleet')

if (!can_view_fleets)
    return HTTP_403_Forbidden()

import type { FleetItem, DoctrineType } from '@dtypes/layout_components'
import { fetch_fleets_auth } from '@helpers/fetching/fleets'
import { fetch_doctrine_by_id } from '@helpers/fetching/doctrines'

let fetch_fleets_error: Error | false = false
let fleets:FleetItem[] = []
let active_fleet:FleetItem | undefined = undefined
let active_doctrine:DoctrineType | undefined = undefined

const upcoming = JSON.parse(Astro.url.searchParams.get('upcoming') as string)

try {
    fleets = await fetch_fleets_auth(auth_token as string, upcoming)
    fleets.sort(function(a, b) {
        return new Date(a.start_time).getTime() - new Date(b.start_time).getTime();
    });

    if (upcoming) {
        active_fleet = fleets.find(fleet => fleet?.status !== 'cancelled' && fleet?.tracking && !fleet?.tracking?.end_time)

        active_fleet = fleets.find(fleet => fleet?.status !== 'cancelled' && fleet?.tracking && !fleet?.tracking?.end_time)
        if (active_fleet && active_fleet.doctrine_id)
            active_doctrine = await fetch_doctrine_by_id(active_fleet.doctrine_id)
    }
} catch (error) {
    fetch_fleets_error = error
}

import { get_market_contracts } from '@helpers/api.minmatar.org/market'
import { get_locations } from '@helpers/api.minmatar.org/locations'
import type { Contract } from '@dtypes/api.minmatar.org'
let supply_contracts: Contract[] = []

if (active_fleet && active_doctrine) {
    try {
        const locations = await get_locations()
        const fleet_location = locations.find(location => location.location_name === active_fleet?.location)
        
        supply_contracts = fleet_location?.location_id ? await get_market_contracts(fleet_location?.location_id) : []
    } catch (error) {
        console.error('Error fetching supply contracts:', error)
    }
}

let count_text = ''
if (upcoming)
    count_text = t(fleets.length !== 1 ? 'fleets_on_schedule_plural' : 'fleets_on_schedule_singular')
        .replace('{count}', String(fleets.length))
else
    count_text = t(fleets.length !== 1 ? 'fleets_in_the_past_30_days_plural' : 'fleets_in_the_past_30_days_singular')
        .replace('{count}', String(fleets.length))

const FLEET_LIST_PARTIAL_URL = translatePath(`/partials/fleet_list_component?upcoming=${JSON.stringify(upcoming)}`)

const delay = parseInt(Astro.url.searchParams.get('delay') ?? '0')

import FleetList from '@components/blocks/FleetList.astro';
import ErrorRefetch from '@components/blocks/ErrorRefetch.astro';
---

{fetch_fleets_error ?
    <ErrorRefetch
        args={{
            partial: FLEET_LIST_PARTIAL_URL,
            error: fetch_fleets_error,
            delay: delay,
        }}
    />
    :
    <small id="count-text-oob" hx-swap-oob="true">
        {count_text}
    </small>

    <FleetList
        fleets={fleets}
        active_fleet={upcoming ? active_fleet : undefined}
        active_doctrine={upcoming ? active_doctrine : undefined}
        supply_contracts={upcoming ? supply_contracts : undefined}
        history={!upcoming}
        init_tooltips={true}
    />
}