---
import { i18n } from '@helpers/i18n'
const { t, translatePath } = i18n(Astro.url)

import type { User } from '@dtypes/jwt'
import * as jose from 'jose'

const auth_token = Astro.cookies.has('auth_token') ? Astro.cookies.get('auth_token')?.value : false
const user = auth_token ? jose.decodeJwt(auth_token) as User : false

import type { Tribe } from '@dtypes/api.minmatar.org'
import { get_tribes, get_current_tribes } from '@helpers/api.minmatar.org/tribes'

let tribes: Tribe[] = []
let current_tribe_ids: Set<number> = new Set()
let get_tribes_error: Error | false = false

try {
    tribes = await get_tribes()

    if (auth_token) {
        const current = await get_current_tribes(auth_token)
        current_tribe_ids = new Set(current.map(t => t.id))
    }
} catch (error) {
    get_tribes_error = error
}

const TRIBES_LIST_PARTIAL_URL = translatePath('/partials/tribes_list_component')

const delay = parseInt(Astro.url.searchParams.get('delay') ?? '0')

import ErrorRefetch from '@components/blocks/ErrorRefetch.astro';
import TribesTiles from '@components/blocks/TribesTiles.astro';
---

{get_tribes_error ?
    <ErrorRefetch
        args={{
            partial: TRIBES_LIST_PARTIAL_URL,
            error: get_tribes_error,
            delay: delay,
        }}
    />
    :
    <TribesTiles
        tribes={tribes}
        current_tribe_ids={current_tribe_ids}
        init_tooltips={false}
    />
}