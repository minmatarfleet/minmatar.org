---
import { i18n } from '@helpers/i18n'
const { t, translatePath } = i18n(Astro.url)

import type { User } from '@dtypes/jwt'
import * as jose from 'jose'

const order_id = parseInt(Astro.url.searchParams.get('order_id') ?? '0')

import type { RootSingleItem } from '@dtypes/api.minmatar.org'
import { fetch_order_breakdown_grouped } from '@helpers/fetching/industry'
import { get_primary_characters } from '@helpers/api.minmatar.org/characters'

const auth_token = Astro.cookies.has('auth_token') ? (Astro.cookies.get('auth_token')?.value as string) : false
const user:User | false = auth_token ? jose.decodeJwt(auth_token) as User : false

let order_breakdown: RootSingleItem[] = []
let primary_character_id = 0
let fetching_error:string | false = false
let order_id_error:string | false = false

if (!isNaN(order_id)) {
    try {
        order_breakdown = await fetch_order_breakdown_grouped(order_id)
        const primary_pilot = await get_primary_characters(auth_token as string)
        primary_character_id = primary_pilot?.character_id ?? 0
    } catch (error) {
        fetching_error = error.message
    }
} else {
    order_id_error = t('invalid_order_id')
}

const ORDER_BREAKDOWN_PARTIAL_URL = `${translatePath('/partials/order_breakdown_component')}?order_id=${order_id}`

const delay = parseInt(Astro.url.searchParams.get('delay') ?? '5')

import OrderBreakdown from '@components/blocks/OrderBreakdown.astro'
import DebugTag from '@components/blocks/DebugTag.astro'
import ErrorRefetch from '@components/blocks/ErrorRefetch.astro'
---

{order_id_error ?
    <DebugTag>{order_id_error}</DebugTag> :
    <>{fetching_error !== false ?
        <ErrorRefetch
            args={{
                partial: ORDER_BREAKDOWN_PARTIAL_URL,
                message: fetching_error,
                delay: delay,
            }}
        /> :
        <>{order_breakdown ?
            <OrderBreakdown
                order_id={order_id}
                primary_character_id={primary_character_id}
                order_breakdown={order_breakdown}
                init_tooltips={true}
            />
            :
            <DebugTag>{t('no_order_unexpected_error')}</DebugTag>
        }</>
    }</>
}