---
import { i18n } from '@helpers/i18n'
const { lang, t, translatePath } = i18n(Astro.url)

import { HTTP_403_Forbidden } from '@helpers/http_responses'

import type { User } from '@dtypes/jwt'
import * as jose from 'jose'

const auth_token = Astro.cookies.has('auth_token') ? (Astro.cookies.get('auth_token')?.value as string) : false
const user:User | false = auth_token ? jose.decodeJwt(auth_token) as User : false
const is_superuser = (user ? user?.is_superuser : false)

import { get_user_permissions } from '@helpers/permissions'
const user_permissions = (user ? await get_user_permissions(user?.username) : [])

const can_view_srp = is_superuser || user_permissions.includes('srp.view_evefleetshipreimbursement')
const can_add_srp = is_superuser || user_permissions.includes('srp.add_evefleetshipreimbursement')
const can_view_all_srp = is_superuser || user_permissions.includes('srp.change_evefleetshipreimbursement')

if (!can_view_srp)
    return HTTP_403_Forbidden()

import type { FleetSRPUI } from '@dtypes/layout_components'
import { fetch_srps } from '@helpers/fetching/srp'
import type { SRPStatsOverview } from '@dtypes/api.minmatar.org'
import { get_srp_stats } from '@helpers/api.minmatar.org/srp'

let fetch_srp_error: Error | false = false
let fleets_srps:FleetSRPUI[] | null = []
let srps_count:number = 0
let fleetless:boolean = false
let ship_types:string[] = []
let stats_overview:SRPStatsOverview | null = null

try {
    const fleets_srps_data = await fetch_srps(auth_token as string)
    ship_types = fleets_srps_data.ship_types
    fleets_srps = fleets_srps_data.fleets_srps
    fleetless = fleets_srps.find(srp => srp.fleet_id === 0) !== undefined
    srps_count = fleets_srps.reduce((c, v) => c + v.srps.length, 0)

    stats_overview = await get_srp_stats( auth_token as string)
} catch (error) {
    fetch_srp_error = error
}

const killmails_text = t(srps_count !== 1 ? 'killmails_pending_plural' : 'killmails_pending_singular')
    .replace('{count}', number_thousand_separator(srps_count, lang))

const FLEETS_SRPS_PARTIAL_URL = translatePath(`/partials/fleets_srps_component`)

const delay = parseInt(Astro.url.searchParams.get('delay') ?? '0')

import { number_thousand_separator } from '@helpers/numbers'

import PageSubheader from '@components/page/PageSubheader.astro';

import Flexblock from '@components/compositions/Flexblock.astro';

import ErrorRefetch from '@components/blocks/ErrorRefetch.astro';
import SRPTable from '@components/blocks/SRPTable.astro';
import SRPFiltersSwiper from '@components/blocks/SRPFiltersSwiper.astro';
import UpdateAlpineVariables from '@components/blocks/UpdateAlpineVariables.astro'
import NumberNameTooltip from '@components/blocks/NumberNameTooltip.astro'
---
        
{fetch_srp_error ?
    <ErrorRefetch
        args={{
            partial: FLEETS_SRPS_PARTIAL_URL,
            error: fetch_srp_error,
            delay: delay,
        }}
    />
    :
    <UpdateAlpineVariables
        variables={{
            srps_count: srps_count
        }}
    />

    <small id="killmails-text-oob" hx-swap-oob="true">
        {killmails_text} (<NumberNameTooltip number={stats_overview?.pending_total ?? 0} /> ISK)
    </small>

    <SRPFiltersSwiper ship_types={ship_types} />

    <PageSubheader
        id="subheader-oob"
        hx-swap-oob="true"
        is_empty={!can_view_all_srp || ship_types.length === 0}
    >
        {can_view_all_srp && ship_types.length > 0 && <SRPFiltersSwiper ship_types={ship_types} /> }
    </PageSubheader>

    <Flexblock class="[ w-full ]" gap='var(--space-xl)'>
        {fleets_srps.map(fleet_srps =>
            <SRPTable
                fleet_id={fleet_srps.fleet_id ?? 0}
                fleet_srps={fleet_srps.srps}
                readonly={!can_view_all_srp}
                fleet_title={true}
                can_add_srp={can_add_srp}
            />
        )}
        {!fleetless && <div id="srp-table-0" class="[ hidden ]" />}
    </Flexblock>
}