---
import { i18n } from '@helpers/i18n'
const { t, translatePath } = i18n(Astro.url)

import { prod_error_messages } from '@helpers/env'
import { HTTP_400_Bad_Request } from '@helpers/http_responses'
import { get_auth_url } from '@helpers/env'

import type { User } from '@dtypes/jwt'
import * as jose from 'jose'

const auth_token = Astro.cookies.has('auth_token') ? Astro.cookies.get('auth_token')?.value : false
const user = auth_token ? jose.decodeJwt(auth_token) as User : false

if (!auth_token || !user) {
    Astro.cookies.set('redirect_after_auth', Astro.url.href, { path: '/' })
    return Astro.redirect(get_auth_url())
}

const tribe_id = parseInt(Astro.url.searchParams.get('tribe_id') ?? '0')
const group_id = parseInt(Astro.url.searchParams.get('group_id') ?? '0')

console.log(tribe_id)
console.log(group_id)

if (isNaN(tribe_id) || isNaN(group_id))
    return HTTP_400_Bad_Request()

import { apply_to_group, leave_group } from '@helpers/api.minmatar.org/tribes'
import type { Alert } from '@dtypes/layout_components'

let apply_to_group_error:string | false = false
let leave_group_error:string | false = false
let alert:Alert | false = false

if (Astro.request.method === "POST") {
    try {
        const data = await Astro.request.formData()
        console.log(data.get('character_ids'))
        const character_ids = JSON.parse(data.get('character_ids') as string) as number[]

        if (!Array.isArray(character_ids) || !character_ids.every(character_id => typeof character_id === 'number'))
            throw new Error(t('invalid_characters'))

        await apply_to_group(
            auth_token as string,
            tribe_id,
            group_id,
            character_ids
        )
    } catch (error) {
        apply_to_group_error = prod_error_messages() ? t('apply_to_group_error') : error.message
    }

    if (apply_to_group_error) {
        alert = {
            title: t('tribes.detail.apply'),
            content: apply_to_group_error,
        }
    }
}

if (Astro.request.method === "DELETE") {
    try {
        const membership_id = parseInt(Astro.url.searchParams.get('membership_id') ?? '0')

        if (isNaN(membership_id))
            throw new Error(t('invalid_membership_id'));

        await leave_group(
            auth_token as string,
            tribe_id,
            group_id,
            membership_id,
        )
    } catch (error) {
        leave_group_error = prod_error_messages() ? t('leave_group_error') : error.message
    }

    if (leave_group_error) {
        alert = {
            title: t('tribes.detail.withdraw'),
            content: leave_group_error,
        }
    }
}

import type { TribeGroup, SummaryCharacter, TribeMembership } from '@dtypes/api.minmatar.org'
import { get_tribe_group, get_memberships } from '@helpers/api.minmatar.org/tribes'
import { get_characters_summary_sorted } from '@helpers/fetching/characters'

let user_characters: SummaryCharacter[] = []
let tribe_group:TribeGroup | null = null
const membership_by_group = new Map<number, TribeMembership | null>()
let is_member = false
let is_pending = false
let fetch_group_error:string | false = false

try {
    tribe_group = await get_tribe_group(tribe_id, group_id)

    const memberships = await get_memberships(auth_token as string, tribe_id, tribe_group.id)
    const mine = memberships.find(m => m.user_id === user.user_id) ?? null
    membership_by_group.set(tribe_group.id, mine)

    const summary = await get_characters_summary_sorted(auth_token)
    user_characters = summary.characters ?? []
    
    const membership = membership_by_group.get(tribe_group.id) ?? null
    is_member = membership?.status === 'approved'
    is_pending = membership?.status === 'pending'
} catch (error) {
    fetch_group_error = prod_error_messages() ? t('fetch_group_error') : error.message
}

const TRIBE_GROUP_STATUS_PARTIAL_URL = translatePath(`/partials/tribe_group_status_component?tribe_id=${tribe_id}&group_id=${group_id}`)

const delay = parseInt(Astro.url.searchParams.get('delay') ?? '5')

import ShowAlert from '@components/blocks/ShowAlert.astro';
import TribeStatus from '@components/blocks/TribeStatus.astro';
import ErrorRefetch from '@components/blocks/ErrorRefetch.astro';
import DebugTag from '@components/blocks/DebugTag.astro';
---

{alert && <ShowAlert alert={alert} /> }

{fetch_group_error ?
    <ErrorRefetch
        args={{
            partial: TRIBE_GROUP_STATUS_PARTIAL_URL,
            message: fetch_group_error,
            delay: delay,
        }}
    /> :
    tribe_group ?
        <small
            id={`membership-${tribe_group.tribe_id}-${tribe_group.id}`}
            class:list={[ 'text-highlight', { hidden: !is_member && !is_pending }, { 'animate-rubber-band': is_pending } ]}
            hx-swap-oob="true"
        >
            {is_member ? t('member_of_tribe_group') : is_pending ? t('tribes.detail.apply_confirm_text') : ''}
        </small>

        <TribeStatus
            group={tribe_group}
            tribe_id={tribe_group.tribe_id}
            group_id={tribe_group.id}
            user_characters={user_characters}
            is_auth={!!user}
            membership_by_group={membership_by_group}
        />
        :
        <DebugTag set:html={t('no_tribe_group_unexpected_error')} />
}