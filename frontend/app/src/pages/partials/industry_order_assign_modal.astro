---
import { i18n } from '@helpers/i18n'
const { t, translatePath } = i18n(Astro.url)

import type { User } from '@dtypes/jwt'
import * as jose from 'jose'

import { prod_error_messages } from '@helpers/env'
import { query_string } from '@helpers/string'
import { get_order_by_id, post_order_item_assignment } from '@helpers/api.minmatar.org/industry'
import { get_characters } from '@helpers/api.minmatar.org/characters'
import { fetch_order_breakdown } from '@helpers/fetching/industry'

const auth_token = Astro.cookies.has('auth_token')
    ? (Astro.cookies.get('auth_token')?.value as string)
    : false
const user: User | false = auth_token ? (jose.decodeJwt(auth_token) as User) : false

let order_id = parseInt(Astro.url.searchParams.get('order_id') ?? '0', 10)

const ASSIGN_MODAL_PATH = translatePath('/partials/industry_order_assign_modal')
const AUTH_INIT = translatePath('/redirects/auth_init')

let login_redirect = translatePath('/industry/orders')
const referer = Astro.request.headers.get('referer')
if (referer) {
    try {
        const ref_url = new URL(referer)
        if (ref_url.origin === Astro.url.origin) {
            login_redirect = `${ref_url.pathname}${ref_url.search}`
        }
    } catch {
        /* ignore */
    }
}

let post_error: string | false = false
let post_success = false

if (Astro.request.method === 'POST') {
    const data = await Astro.request.formData()
    const from_form = parseInt((data.get('order_id') as string) ?? '', 10)
    if (!isNaN(from_form)) order_id = from_form

    if (auth_token && user && !isNaN(order_id)) {
        const order_item_id = parseInt((data.get('order_item_id') as string) ?? '', 10)
        const character_id = parseInt((data.get('character_id') as string) ?? '', 10)
        const quantity = parseInt((data.get('quantity') as string) ?? '', 10)

        try {
            if (
                isNaN(order_item_id) ||
                isNaN(character_id) ||
                isNaN(quantity) ||
                quantity < 1
            ) {
                throw new Error(t('industry.orders.assign_invalid_form'))
            }
            await post_order_item_assignment(auth_token, order_id, order_item_id, {
                character_id,
                quantity,
            })
            post_success = true
        } catch (error) {
            post_error = prod_error_messages()
                ? t('industry.orders.assign_error')
                : (error as Error).message
        }
    }
}

const assign_modal_partial_url = `${ASSIGN_MODAL_PATH}?${query_string({
    order_id: String(order_id),
})}`

let order_breakdown_for_oob: Awaited<ReturnType<typeof fetch_order_breakdown>> = []
if (post_success && !isNaN(order_id)) {
    try {
        order_breakdown_for_oob = await fetch_order_breakdown(order_id)
    } catch {
        order_breakdown_for_oob = []
    }
}

let assignable_items: {
    id: number
    eve_type_name: string
    unassigned_quantity: number
}[] = []
let characters_list: { character_id: number; character_name: string }[] = []

if (!post_success && user && auth_token && !isNaN(order_id)) {
    try {
        const order = await get_order_by_id(order_id)
        assignable_items =
            order?.items
                .filter((item) => (item.unassigned_quantity ?? 0) > 0)
                .map((item) => ({
                    id: item.id,
                    eve_type_name: item.eve_type_name,
                    unassigned_quantity: item.unassigned_quantity ?? 0,
                })) ?? []
        const chars = await get_characters(auth_token)
        characters_list = chars.map((c) => ({
            character_id: c.character_id,
            character_name: c.character_name,
        }))
    } catch {
        assignable_items = []
        characters_list = []
    }
}

const first_unassigned =
    assignable_items.length > 0 ? assignable_items[0].unassigned_quantity : 1

import Flexblock from '@components/compositions/Flexblock.astro'
import FlexInline from '@components/compositions/FlexInline.astro'
import Button from '@components/blocks/Button.astro'
import Select from '@components/blocks/Select.astro'
import Input from '@components/blocks/Input.astro'
import OrderBreakdown from '@components/blocks/OrderBreakdown.astro'
---

{
    post_success ? (
        <>
            <Flexblock gap="var(--space-m)">
                <p>{t('industry.orders.assign_success')}</p>
                <FlexInline>
                    <Button type="button" size="sm" narrow={true} modal-action="cancel">
                        {t('close')}
                    </Button>
                </FlexInline>
            </Flexblock>
            <div id={`order-breakdown-${order_id}`} hx-swap-oob="innerHTML">
                <OrderBreakdown
                    order_breakdown={order_breakdown_for_oob}
                    assign_modal_partial_url={assign_modal_partial_url}
                    authenticated={true}
                    init_tooltips={true}
                />
            </div>
        </>
    ) : !user || !auth_token ? (
        <Flexblock gap="var(--space-m)">
            <p>{t('industry.orders.assign_login_required')}</p>
            <Button
                href={`${AUTH_INIT}?${query_string({
                    redirect_url: login_redirect,
                })}`}
                size="sm"
                narrow={true}
            >
                {t('industry.orders.assign_log_in')}
            </Button>
        </Flexblock>
    ) : isNaN(order_id) ? (
        <p>{t('invalid_resource_type')}</p>
    ) : assignable_items.length === 0 ? (
        <Flexblock gap="var(--space-m)">
            <p>{t('industry.orders.assign_nothing_available')}</p>
            <Button type="button" size="sm" narrow={true} modal-action="cancel">
                {t('close')}
            </Button>
        </Flexblock>
    ) : characters_list.length === 0 ? (
        <Flexblock gap="var(--space-m)">
            <p>{t('industry.orders.assign_no_characters')}</p>
            <Button type="button" size="sm" narrow={true} modal-action="cancel">
                {t('close')}
            </Button>
        </Flexblock>
    ) : (
        <form
            class="[ industry-order-assign-form ]"
            hx-post={ASSIGN_MODAL_PATH}
            hx-target="#modal-description"
            hx-swap="innerHTML"
            hx-indicator=".loader"
            x-data={`{
                maxUnassigned: ${first_unassigned},
                syncQuantityCap(selectEl, qtyEl) {
                    const opt = selectEl.selectedOptions[0]
                    const m = parseInt(opt?.dataset?.unassigned ?? '1', 10)
                    this.maxUnassigned = m
                    qtyEl.max = m
                    const v = parseInt(qtyEl.value, 10)
                    if (v > m) qtyEl.value = String(m)
                    if (v < 1 || isNaN(v)) qtyEl.value = '1'
                }
            }`}
        >
            <input type="hidden" name="order_id" value={order_id} />
            <Flexblock gap="var(--space-m)">
                <h3 class="[ text-highlight ]">{t('industry.orders.assign_modal_title')}</h3>
                {post_error ? (
                    <p class="[ text-red-400 ]" set:text={post_error} />
                ) : null}
                <Flexblock gap="var(--space-3xs)">
                    <label class="[ text-step--1 ]" for={`assign-item-${order_id}`}>
                        {t('industry.orders.assign_order_item')}
                    </label>
                    <Select
                        id={`assign-item-${order_id}`}
                        name="order_item_id"
                        required={true}
                        x-ref="itemSelect"
                        x-init="$nextTick(() => syncQuantityCap($refs.itemSelect, $refs.qtyInput))"
                        x-on:change="syncQuantityCap($refs.itemSelect, $refs.qtyInput)"
                    >
                        {assignable_items.map((item) => (
                            <option
                                value={item.id}
                                data-unassigned={item.unassigned_quantity}
                            >
                                {`${item.eve_type_name} (${item.unassigned_quantity} ${t('industry.orders.assign_unassigned_suffix')})`}
                            </option>
                        ))}
                    </Select>
                </Flexblock>
                <Flexblock gap="var(--space-3xs)">
                    <label class="[ text-step--1 ]" for={`assign-char-${order_id}`}>
                        {t('industry.orders.assign_character')}
                    </label>
                    <Select
                        id={`assign-char-${order_id}`}
                        name="character_id"
                        required={true}
                    >
                        {characters_list.map((c) => (
                            <option value={c.character_id}>{c.character_name}</option>
                        ))}
                    </Select>
                </Flexblock>
                <Flexblock gap="var(--space-3xs)">
                    <label class="[ text-step--1 ]" for={`assign-qty-${order_id}`}>
                        {t('industry.orders.assign_quantity')}
                    </label>
                    <Input
                        id={`assign-qty-${order_id}`}
                        name="quantity"
                        type="number"
                        min={1}
                        max={first_unassigned}
                        value={first_unassigned}
                        required={true}
                        x-ref="qtyInput"
                    />
                </Flexblock>
                <FlexInline gap="var(--space-s)">
                    <Button type="submit" size="sm" narrow={true}>
                        {t('industry.orders.assign_submit')}
                    </Button>
                    <Button type="button" size="sm" narrow={true} modal-action="cancel">
                        {t('close')}
                    </Button>
                </FlexInline>
            </Flexblock>
        </form>
    )
}
