---
import { i18n } from '@helpers/i18n'
const { t, translatePath } = i18n(Astro.url)

import type { User } from '@dtypes/jwt'
import * as jose from 'jose'

const auth_token = Astro.cookies.has('auth_token') ? (Astro.cookies.get('auth_token')?.value as string) : false
const user: User | false = auth_token ? (jose.decodeJwt(auth_token) as User) : false

if (!user) {
    return Astro.redirect(translatePath('/industry/mining/systems/'))
}

if (Astro.request.method === "POST") {
    try {
        const data = await Astro.request.formData()
        const system_id = parseInt((data.get('system_id') as string) ?? '0', 10)
        if (system_id > 0) {
            const { post_mining_completion } = await import('@helpers/api.minmatar.org/industry')
            await post_mining_completion(auth_token, system_id)
        }
    } catch (_) {
        // on error still redirect so user sees the list
    }
    return Astro.redirect(translatePath('/industry/mining/systems/'))
}
---

<div></div>
