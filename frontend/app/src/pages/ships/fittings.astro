---
import { i18n } from '@helpers/i18n'
const { t, translatePath } = i18n(Astro.url)

import type { FittingItem, ShipFittings, ShipTypeFittingGroups } from '@dtypes/layout_components'
import { fetch_fittings } from '@helpers/fetching/ships'
import { fitting_tag_label, format_fitting_tags_line } from '@helpers/fitting_tags'
import { SHIP_TYPES_SORTED } from '@helpers/eve'
import { get_ship_type_icon } from '@helpers/eve'
import { get_ships_meta } from '@helpers/sde/ships'
import { unique_values } from '@helpers/array'
import {
    buildFittingsListJsonLd,
    buildFittingsListMetaDescription,
    buildFittingsListMetaTitle,
} from '@helpers/fitting_seo'

let fittings:FittingItem[] = []
let get_fittings_error:string | false = false

try {
    fittings = await fetch_fittings()
    const ship_ids = fittings.map(fitting => fitting.ship_id)
    const unique_ships_ids = unique_values(ship_ids)
    const ships_meta = await get_ships_meta(unique_ships_ids)
    const ships_meta_map: Record<number, string> = {}
    ships_meta.forEach((meta) => {
        ships_meta_map[meta.ship_id] = meta.meta
    })
    
    fittings = fittings.map(fitting => {
        fitting.ship_meta = ships_meta_map[fitting.ship_id] ?? 'Tech I'
        return fitting
    })
} catch (error) {
    get_fittings_error = error.message
}

let ship_type: Record<string, string> = {};
fittings.forEach((fitting) => {
    ship_type[fitting.ship_type] = fitting.ship_type;
    if (fitting.ship_type === 'Unknown')
        console.log(fitting)
})

const tag_slugs_seen = new Set<string>()
fittings.forEach((fitting) => {
    (fitting.tags ?? []).forEach((tag) => tag_slugs_seen.add(tag))
})
const tag_options = [...tag_slugs_seen]
    .map((value) => ({
        value,
        label: fitting_tag_label(value, t),
    }))
    .sort((a, b) => a.label.localeCompare(b.label))

let fitting_ship_types = Object.keys(ship_type)
fitting_ship_types = fitting_ship_types.sort((a, b) => SHIP_TYPES_SORTED.indexOf(a) - SHIP_TYPES_SORTED.indexOf(b))

let fittings_grouped_by_ship_type:FittingItem[][] = []
fitting_ship_types.forEach((fitting_ship_type) => {
    fittings_grouped_by_ship_type.push(
        fittings.filter((fitting) => fitting.ship_type === fitting_ship_type).sort((a, b) => a.ship_name.localeCompare(b.ship_name))
    )
})

import { group_by } from '@helpers/array';

const fitting_groups = fittings_grouped_by_ship_type.map(fittings_group => {
    let _array = Object.values(fittings_group)
    const fittings_by_ship = group_by(_array, 'ship_name') as Record<string, FittingItem[]>

    return {
        ship_type: fittings_group[0].ship_type,
        ship_groups: Object.entries(fittings_by_ship).map(([ship_name, fittings]) => ({
            ship_name: ship_name,
            ship_id: fittings[0].ship_id,
            ship_meta: fittings[0].ship_meta,
            count: fittings.length,
            ship_type: fittings[0].ship_type,
            tags: unique_values(fittings.flatMap(fitting => fitting.tags ?? [])),
            fittings: fittings.sort((a, b) => a.fitting_name.localeCompare(b.fitting_name)),
        })),
    } as ShipTypeFittingGroups
})

console.log(fitting_groups)
const ships_count = fitting_groups.flatMap(fitting_group => fitting_group.ship_groups).length

const search_tag = Astro.url.searchParams.get('tag')
const initial_tag_filter =
    search_tag && tag_options.some((o) => o.value === search_tag) ? search_tag : '-1'

import Viewport from '@layouts/Viewport.astro';

import PageWide from '@components/page/PageWide.astro';
import PageTitle from '@components/page/PageTitle.astro';

import Flexblock from '@components/compositions/Flexblock.astro';
import BlockList from '@components/compositions/BlockList.astro';
import FlexInline from '@components/compositions/FlexInline.astro';
import Grid from '@components/compositions/Grid.astro';

import Input from '@components/blocks/Input.astro';
import Select from '@components/blocks/Select.astro';

import MagnifierIcon from '@components/icons/buttons/MagnifierIcon.astro';
import FittingsDialog from '@components/blocks/FittingsDialog.astro'

const page_title = t('fitting.list.page_title');
const site_name = t('index.page_title')
const meta_title = buildFittingsListMetaTitle(site_name, t)
const meta_description = buildFittingsListMetaDescription(fittings.length, t)
const canonical_url = new URL(translatePath('/ships/fittings/'), Astro.url.origin).href
const meta_image = new URL('/images/fits-cover.jpg', Astro.url.origin).href
const ships_url = new URL(translatePath('/ships/'), Astro.url.origin).href

const structured_data = buildFittingsListJsonLd(
    {
        fittings: fittings.map((fitting) => ({
            id: fitting.id,
            name: fitting.fitting_name.replace(/^\[[^\]]+\]\s*/, ''),
            shipName: fitting.ship_name,
            url: new URL(translatePath(`/ships/fittings/${fitting.id}`), Astro.url.origin).href,
        })),
        siteName: site_name,
        siteOrigin: Astro.url.origin,
        fittingsListUrl: canonical_url,
        shipsUrl: ships_url,
        canonicalUrl: canonical_url,
        metaImage: meta_image,
    },
    meta_title,
    meta_description,
)
---

<Viewport
    title={meta_title}
    meta_description={meta_description}
    meta_image={meta_image}
    canonical_url={canonical_url}
>
    <script type="application/ld+json" is:inline set:html={JSON.stringify(structured_data)} />

    <PageWide
        cover={{
            image: "/images/fits-cover.jpg",
            image_990: "/images/fits-cover.jpg",
            alt: t('fitting.cover_alt'),
            animated: false,
            scrollable: true,
            overlay: true
        }}
        sticky={true}
        x-data={`{
            fitting_name_filter: '',
            fitting_tag_filter: ${JSON.stringify(initial_tag_filter)},
            ship_type_filter: '-1',
            ships_count: ${ships_count},
            countVisibleElements(selector, parent = document) {
                const elements = parent.querySelectorAll(selector)
                let visible_count = 0

                elements.forEach(element => {
                    const is_visible = element.offsetParent !== null
                    if (is_visible)
                        visible_count++
                })

                return visible_count
            },
            show_item(el) {
                const ps = el.querySelectorAll('.fitting-card-filters p')
                const name_el = ps[0]
                const ship_el = ps[1]
                const tag_attr = el.getAttribute('data-fitting-tags') || ''
                const tag_list = tag_attr.split(/\\s+/).filter(Boolean)
                return (
                    (this.fitting_name_filter === '' || (name_el && name_el.textContent.toLowerCase().includes(this.fitting_name_filter.toLowerCase()))) &&
                    (this.fitting_tag_filter === '-1' || tag_list.includes(this.fitting_tag_filter)) &&
                    (this.ship_type_filter === '-1' || (ship_el && ship_el.textContent === this.ship_type_filter))
                )
            },
        }`}
    >
        <FlexInline slot="header" justification='space-between' class="[ w-full ]">
            <FlexInline>
                <Flexblock gap="var(--space-3xs)">
                    <PageTitle>
                        {page_title}
                    </PageTitle>
                    <small x-text={'`'+t('showing')+' ${ships_count} '+t('ship').toLowerCase()+'${ships_count != 1 ? `s` : ``}`'}>
                        {t('showing')} {ships_count} {t('ship').toLowerCase()}{ships_count != 1 ? 's' : ''}
                    </small>
                </Flexblock>
            </FlexInline>
            <FlexInline class="[ !items-start ]">
                <Input
                    type="text"
                    placeholder={t('search')}
                    x-model="fitting_name_filter"
                    x-on:keyup="setTimeout(function () { ships_count = countVisibleElements('.fitting-card') })"
                    x-init="$el.focus()"
                    width='250px'
                >
                    <MagnifierIcon slot="icon" />
                </Input>
                
                <div class="[ hidden 2xl:!block ]">
                    <Select
                        x-model="fitting_tag_filter"
                        x-on:change="setTimeout(function () { ships_count = countVisibleElements('.fitting-card') }, 100)"
                    >
                        <option selected value="-1">{t('all_fitting_types')}</option>
                        {tag_options.map(({ value, label }) => 
                            <option value={value}>{label}</option>
                        )}
                    </Select>
                </div>

                <div class="[ hidden xl:!block ]">
                    <Select
                        x-model="ship_type_filter"
                        x-on:change="setTimeout(function () { ships_count = countVisibleElements('.fitting-card') }, 100)"
                    >
                        <option selected value="-1">{t('all_ship_type')}</option>
                        {fitting_ship_types.map((option) => 
                            <option value={option}>{option}</option>
                        )}
                    </Select>
                </div>
            </FlexInline>
        </FlexInline>

        <BlockList gap='var(--space-2xl)'>
            {fitting_groups.map((ship_type_group) =>
                <Flexblock
                    class="[ fitting-groups ]"
                    gap='var(--space-m)'
                >
                    <FlexInline gap='var(--space-2xs)'>
                        {get_ship_type_icon(ship_type_group.ship_type) !== null &&
                            <img
                                class="[ mt-[2px] ]"
                                src={`/images/icons/ships/${get_ship_type_icon(ship_type_group.ship_type)}`}
                                height="32"
                                width="32"
                                alt={`${ship_type_group.ship_type} icon`}
                            />
                        }
                        <h2>{ship_type_group.ship_type}</h2>
                    </FlexInline>
                    <BlockList gap='var(--space-m)'>
                        <Grid
                            role="list"
                            class="[ w-full grid-fill ]"
                            min_item_width='240px'
                            row_gap='var(--space-3xs)'
                            column_gap='var(--space-3xs)'
                        >
                            {ship_type_group.ship_groups.map((ship_group) =>
                                <div
                                    class="[ fitting-card-container ][ flex ]"
                                    data-fitting-tags={(ship_group.tags ?? []).join(' ')}
                                    x-show="show_item($el)"
                                >
                                    <FittingsDialog ship_group={ship_group} />
                                </div>
                        )}
                    </Grid>
                    </BlockList>
                </Flexblock>
            )}
        </BlockList>
        <p x-show="ships_count === 0" class="[ text-center ]">{get_fittings_error ? t('error_fetching_fittings') : t('no_results')}</p>
    </PageWide>
</Viewport>

<style lang="scss">
    .fitting-groups:not(:has(.fitting-card-container:not([style="display: none;"]))) {
        border: 0;
        clip: rect(0 0 0 0);
        height: auto;
        margin: 0;
        overflow: hidden;
        padding: 0;
        position: absolute;
        width: 1px;
        white-space: nowrap;
        left: 0;
        top: 0;
    }
</style>