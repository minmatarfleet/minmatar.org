---
import { HTTP_404_Not_Found } from '@helpers/http_responses'

import type { User } from '@dtypes/jwt'
import * as jose from 'jose'

const auth_token = Astro.cookies.has('auth_token') ? (Astro.cookies.get('auth_token')?.value as string) : false
const user:User | false = auth_token ? jose.decodeJwt(auth_token) as User : false
const is_superuser = (user ? user?.is_superuser : false)

if (!is_superuser)
  return Astro.redirect(HTTP_404_Not_Found())

import fs from 'node:fs';
import path from 'node:path';

// 1. Get the path to the data folder
const dataDirPath = path.resolve(process.cwd(), 'src/data');
let filesData: { name: string; size: string; modified: string }[] = [];

// Helper to format bytes into a human-readable string
function formatBytes(bytes) {
    if (bytes === 0) return '0 Bytes';
    const k = 1024;
    const sizes = ['Bytes', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
}

if (fs.existsSync(dataDirPath)) {
    // 2. Read all filenames in the directory
    const filenames = fs.readdirSync(dataDirPath);

    filesData = filenames.map((name) => {
        const filePath = path.join(dataDirPath, name);
        const stats = fs.statSync(filePath);
        
        return {
            name,
            size: formatBytes(stats.size),
            modified: stats.mtime.toLocaleString() // Last modified date
        };
    });
}
---

<div class="file-explorer">
    <h3>Files in /src/data</h3>
    
    <table style="width: 100%; border-collapse: collapse; margin-top: 1rem;">
        <thead>
            <tr style="text-align: left; background: #23262d; color: white;">
                <th style="padding: 12px; border: 1px solid #444;">File Name</th>
                <th style="padding: 12px; border: 1px solid #444;">Size</th>
                <th style="padding: 12px; border: 1px solid #444;">Last Modified</th>
            </tr>
        </thead>
        <tbody>
            {filesData.length > 0 ? (
                filesData.map((file) => (
                    <tr>
                        <td style="padding: 10px; border: 1px solid #ddd;">
                            <code>{file.name}</code>
                        </td>
                        <td style="padding: 10px; border: 1px solid #ddd;">
                            {file.size}
                        </td>
                        <td style="padding: 10px; border: 1px solid #ddd; font-size: 0.9em;">
                            {file.modified}
                        </td>
                    </tr>
                ))
            ) : (
                <tr>
                    <td colspan="3" style="padding: 20px; text-align: center;">
                        No files found in <code>/src/data/</code>
                    </td>
                </tr>
            )}
        </tbody>
    </table>
</div>

<style>
    .file-explorer {
        font-family: system-ui, sans-serif;
        padding: 20px;
        background: #f9f9f9;
        border-radius: 8px;
        color: #333;
    }
    code {
        background: #eee;
        padding: 2px 4px;
        border-radius: 4px;
    }
</style>