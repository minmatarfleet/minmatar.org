---
import { i18n } from '@helpers/i18n'
const { t, translatePath } = i18n(Astro.url)

import { guideMeta, credits, buildNavyDestroyerMetagameJsonLd, guideSections } from '@/data/navy-destroyer-metagame'
import { pageProgressFromSections } from '@helpers/pageProgress'
import { get_site_origin } from '@helpers/seo'

import Viewport from '@layouts/Viewport.astro'
import PageLanding from '@components/page/PageLanding.astro'
import PageTitle from '@components/page/PageTitle.astro'
import TextBox from '@components/layout/TextBox.astro'
import Wrapper from '@components/compositions/Wrapper.astro'
import Flexblock from '@components/compositions/Flexblock.astro'
import NavyDestroyerMetagame from '@components/blocks/navy-destroyer-metagame/NavyDestroyerMetagame.astro'
import PageProgress from '@components/blocks/PageProgress.astro'

const page_title = t('ships.navy_destroyer_metagame.page_title')
const page_description = t('ships.navy_destroyer_metagame.leading_text')
const meta_title = t('ships.navy_destroyer_metagame.meta_title')
    .replace('{site}', t('index.page_title'))
const meta_description = t('ships.navy_destroyer_metagame.meta_description')
const site_origin = get_site_origin(Astro.url.origin)
const canonical_url = new URL(translatePath('/guides/navy-destroyer-metagame/'), site_origin).href
const meta_image = new URL(guideMeta.coverImage, site_origin).href
const guides_url = new URL(translatePath('/guides/'), site_origin).href

const structured_data = buildNavyDestroyerMetagameJsonLd({
    canonicalUrl: canonical_url,
    siteName: t('index.page_title'),
    siteOrigin: site_origin,
    metaTitle: meta_title,
    headline: page_title,
    metaDescription: meta_description,
    metaImage: meta_image,
    guidesUrl: guides_url,
    authorName: credits.firstEditionAuthor,
    publisherName: 'Minmatar Fleet Alliance',
    editionLabel: `${guideMeta.edition} · ${guideMeta.yc}`,
    originalEditionUrl: guideMeta.firstEditionUrl,
})

const progress = pageProgressFromSections({
    page_key: 'guides/navy-destroyer-metagame',
    page_title,
    sections: guideSections,
    version_source: JSON.stringify({
        edition: guideMeta.edition,
        yc: guideMeta.yc,
        sections: guideSections.map((section) => section.id),
    }),
})
---

<Viewport
    title={meta_title}
    meta_description={meta_description}
    meta_image={meta_image}
    canonical_url={canonical_url}
    og_type="article"
    components={{
        alert_dialog: true,
        confirm_dialog: true,
    }}
>
    <script type="application/ld+json" is:inline set:html={JSON.stringify(structured_data)} />

    <PageLanding
        wide={true}
        cover={{
            image: guideMeta.coverImage,
            image_990: guideMeta.coverImage,
            alt: guideMeta.coverAlt,
            scrollable: true,
            overlay: true,
        }}
    >
        <Flexblock gap="var(--space-2xl)" class="ndm-page" data-page-progress-root>
            <TextBox max_width="var(--max-content-width)">
                <Flexblock gap="var(--space-xl)">
                    <div class="ndm-page__header-top">
                        <nav class="ndm-page__breadcrumb" aria-label="Breadcrumb">
                            <ol>
                                <li><a href={translatePath('/guides/')}>{t('guides.page_title')}</a></li>
                                <li aria-current="page">{page_title}</li>
                            </ol>
                        </nav>
                        <div class="ndm-page__progress">
                            <PageProgress {...progress} />
                        </div>
                    </div>
                    <PageTitle is_landing={true}>{page_title}</PageTitle>
                    <p class="[ excerpt ]">{page_description}</p>
                </Flexblock>
            </TextBox>

            <Wrapper
                max_width="var(--max-content-width)"
                padding_inline="0"
                padding_block="0"
            >
                <NavyDestroyerMetagame />
            </Wrapper>
        </Flexblock>
    </PageLanding>
</Viewport>

<style lang="scss">
    .ndm-page {
        width: 100%;
        max-width: 100%;
        min-width: 0;
        overflow-x: clip;
    }

    .ndm-page__header-top {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: flex-start;
        gap: var(--space-s);
        width: 100%;
    }

    .ndm-page__progress {
        flex: 0 0 auto;
        margin-left: auto;
    }

    .ndm-page__breadcrumb {
        margin: 0;
        min-width: 0;

        ol {
            display: flex;
            flex-wrap: wrap;
            gap: var(--space-2xs);
            margin: 0;
            padding: 0;
            list-style: none;
            font-size: var(--step--1);
            color: var(--text-color-secondary, var(--faded));
        }

        li:not(:last-child)::after {
            content: '/';
            margin-left: var(--space-2xs);
            color: var(--text-color-secondary, var(--faded));
        }

        a {
            color: var(--highlight);
            text-decoration: none;

            &:hover,
            &:focus-visible {
                color: var(--fleet-yellow);
                text-decoration: underline;
            }
        }

        [aria-current='page'] {
            color: var(--foreground);
        }
    }

    .excerpt,
    :global(.excerpt p) {
        font-size: var(--step-1);
        line-height: 1.6;
        max-width: var(--max-text-width);
    }
</style>
