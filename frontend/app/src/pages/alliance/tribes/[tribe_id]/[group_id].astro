---
import { i18n } from '@helpers/i18n'
const { t, translatePath } = i18n(Astro.url)

import { HTTP_400_Bad_Request } from '@helpers/http_responses'
import { get_auth_url } from '@helpers/env'

import type { User } from '@dtypes/jwt'
import * as jose from 'jose'

const auth_token = Astro.cookies.has('auth_token') ? Astro.cookies.get('auth_token')?.value : false
const user = auth_token ? jose.decodeJwt(auth_token) as User : false

if (!auth_token || !user) {
    Astro.cookies.set('redirect_after_auth', Astro.url.href, { path: '/' })
    return Astro.redirect(get_auth_url())
}

const tribe_id = parseInt(Astro?.params?.tribe_id ?? '')
const group_id = parseInt(Astro?.params?.group_id ?? '')

if (isNaN(tribe_id) || isNaN(group_id))
    return HTTP_400_Bad_Request()

import { apply_to_group, leave_group } from '@helpers/api.minmatar.org/tribes'
import type { Alert } from '@dtypes/layout_components'

let apply_to_group_error: Error | false = false
let leave_group_error: Error | false = false
let alert:Alert | false = false

import type { Tribe, TribeGroup, SummaryCharacter, TribeMembership } from '@dtypes/api.minmatar.org'
import { get_tribe, get_tribe_group, get_memberships } from '@helpers/api.minmatar.org/tribes'
import { get_characters_summary_sorted } from '@helpers/fetching/characters'

let tribe: Tribe | null = null
let user_characters: SummaryCharacter[] = []
let tribe_group:TribeGroup | null = null
const membership_by_group = new Map<number, TribeMembership | null>()
let members:TribeMembership[] = []
let is_member = false
let is_pending = false
let fetch_group_error: Error | false = false

try {
    tribe = await get_tribe(tribe_id)
    tribe_group = await get_tribe_group(tribe_id, group_id)

    const memberships = await get_memberships(auth_token as string, tribe_id, tribe_group.id)
    const mine = memberships.find(m => m.user_id === user.user_id) ?? null
    membership_by_group.set(tribe_group.id, mine)
    members = memberships.filter(membership => membership.status === 'active')

    const summary = await get_characters_summary_sorted(auth_token)
    user_characters = summary.characters ?? []
    
    const membership = membership_by_group.get(tribe_group.id) ?? null
    is_member = membership?.status === 'active'
    is_pending = membership?.status === 'pending'
} catch (error) {
    fetch_group_error = error
}

import { strip_markdown } from '@helpers/string'

const TRIBE_GROUP_PARTIAL_URL = translatePath(`/partials/tribe_group_component?tribe_id=${tribe_id}&group_id=${group_id}`)

import Viewport from '@layouts/Viewport.astro';

import PageWide from '@components/page/PageWide.astro';
import PageTitle from '@components/page/PageTitle.astro';

import TextBox from '@components/layout/TextBox.astro';

import Flexblock from '@components/compositions/Flexblock.astro';
import FlexInline from '@components/compositions/FlexInline.astro';

import ErrorRefetch from '@components/blocks/ErrorRefetch.astro';
import Button from '@components/blocks/Button.astro';
import PilotBadge from '@components/blocks/PilotBadge.astro'
import TribeGroupLandingPage from '@components/blocks/TribeGroupLandingPage.astro'
import DebugTag from '@components/blocks/DebugTag.astro';

const page_title = tribe_group?.name ?? ''
const page_description = tribe_group?.description ?? ''
const meta_description = await strip_markdown(tribe_group?.description ?? '')
---

<Viewport
    title={page_title}
    meta_description={meta_description}
    components={{
        alert_dialog: true,
        confirm_dialog: true,
        modal: true,
    }}
>
    <PageWide
        cover={{
            image: "/images/groups-cover.jpg",
            image_990: "/images/groups-cover.jpg",
            overlay: true,
            scrollable: true,
        }}
        wide={true}
    >
        <FlexInline slot="header" justification='space-between' class="[ w-full ]">
            <Flexblock gap="var(--space-3xs)">
                <PageTitle>
                    {page_title}
                </PageTitle>
                {tribe_group?.chief &&
                    <PilotBadge
                        character_id={tribe_group.chief.character_id}
                        character_name={tribe_group.chief.character_name}
                        size={32}
                        centered={true}
                    >
                        <small>{t('group_chief')}</small>
                    </PilotBadge>
                }
            </Flexblock>
            <FlexInline gap="var(--space-2xs)">
                <Button href={translatePath(`/alliance/tribes/${tribe_id}/${group_id}/activity`)} size="sm">
                    {t('tribes.detail.activity')}
                </Button>
                <Button href={translatePath(`/alliance/tribes/${tribe_group?.tribe_id}`)}>
                    {t('back_to_tribe_template').replace('{name}', tribe_group?.tribe_name ?? '')}
                </Button>
            </FlexInline>
        </FlexInline>

        <Flexblock gap='var(--space-2xl)'>
            <TextBox>
                <p class="[ excerpt ]">{page_description}</p>
            </TextBox>

            {fetch_group_error ?
                <ErrorRefetch
                    args={{
                        partial: TRIBE_GROUP_PARTIAL_URL,
                        error: fetch_group_error,
                        delay: 0,
                    }}
                />
                :
                tribe_group ?
                    <TribeGroupLandingPage
                        tribe_group={tribe_group}
                        members={members}
                        is_member={is_member}
                        is_pending={is_pending}
                        init_tooltips={false}
                    /> :
                    <DebugTag set:html={t('no_tribe_group_unexpected_error')} />
            }
        </Flexblock>
    </PageWide>
</Viewport>