---
import { i18n } from '@helpers/i18n'
const { t, translatePath } = i18n(Astro.url)

import { prod_error_messages } from '@helpers/env'
import { HTTP_400_Bad_Request } from '@helpers/http_responses'

const tribe_id = parseInt(Astro?.params?.tribe_id ?? '')
const group_id = parseInt(Astro?.params?.group_id ?? '')

if (isNaN(tribe_id) || isNaN(group_id))
    return HTTP_400_Bad_Request()

import type { TribeGroup, TribeGroupActivityRecord } from '@dtypes/api.minmatar.org'
import { get_tribe_group, get_tribe_group_activity } from '@helpers/api.minmatar.org/tribes'

const PAGE_SIZE = 20

let tribe_group: TribeGroup | null = null
let activityItems: TribeGroupActivityRecord[] = []
let activityTotal = 0
let activityLimit = PAGE_SIZE
let activityOffset = 0
let fetch_error: string | false = false

try {
    tribe_group = await get_tribe_group(tribe_id, group_id)
    const activity = await get_tribe_group_activity(tribe_id, group_id, PAGE_SIZE, 0)
    activityItems = activity.items
    activityTotal = activity.total
    activityLimit = activity.limit
    activityOffset = activity.offset
} catch (error) {
    fetch_error = prod_error_messages() ? t('fetch_tribe_error') : (error as Error).message
}

import Viewport from '@layouts/Viewport.astro'
import PageWide from '@components/page/PageWide.astro'
import PageTitle from '@components/page/PageTitle.astro'
import Flexblock from '@components/compositions/Flexblock.astro'
import FlexInline from '@components/compositions/FlexInline.astro'
import ErrorRefetch from '@components/blocks/ErrorRefetch.astro'
import Button from '@components/blocks/Button.astro'
import PilotBadge from '@components/blocks/PilotBadge.astro'
import DebugTag from '@components/blocks/DebugTag.astro'

const page_title = tribe_group ? `${tribe_group.name} — ${t('tribes.detail.activity')}` : t('tribes.detail.activity')
const TRIBE_GROUP_ACTIVITY_PARTIAL_URL = translatePath(`/partials/tribe_group_activity_component?tribe_id=${tribe_id}&group_id=${group_id}`)

function formatRecordRow(r: TribeGroupActivityRecord): Record<string, unknown> {
    const date = r.created_at ? new Date(r.created_at).toLocaleString() : ''
    const who = r.character_name || r.username || '—'
    const qty = r.quantity != null && r.unit ? `${r.quantity} ${r.unit}` : ''
    return {
        id: r.id,
        created_at: r.created_at,
        date_display: date,
        activity_type_display: r.activity_type_display,
        character_name: r.character_name,
        username: r.username,
        who,
        quantity: r.quantity,
        unit: r.unit,
        qty,
        reference_type: r.reference_type,
        reference_id: r.reference_id,
    }
}

const activityInitPayload = {
    items: activityItems.map(formatRecordRow),
    total: activityTotal,
    limit: activityLimit,
    offset: activityOffset,
    viewMoreLabel: t('tribes.activity.view_more'),
    tribeId: tribe_id,
    groupId: group_id,
    pageSize: PAGE_SIZE,
    apiUrl: import.meta.env.API_URL,
}
---

<Viewport
    title={page_title}
    components={{
        alert_dialog: true,
        confirm_dialog: true,
        modal: true,
    }}
>
    <PageWide
        cover={{
            image: "/images/groups-cover.jpg",
            image_990: "/images/groups-cover.jpg",
            overlay: true,
            scrollable: true,
        }}
        wide={true}
        data-activity-init={JSON.stringify(activityInitPayload)}
        x-data="window.__tribeActivityInit && window.__tribeActivityInit($el)"
    >
        <FlexInline slot="header" justification="space-between" class="[ w-full ]">
            <Flexblock gap="var(--space-3xs)">
                <PageTitle>{page_title}</PageTitle>
                {tribe_group?.chief &&
                    <PilotBadge
                        character_id={tribe_group.chief.character_id}
                        character_name={tribe_group.chief.character_name}
                        size={32}
                        centered={true}
                    >
                        <small>{t('group_chief')}</small>
                    </PilotBadge>
                }
            </Flexblock>
            <FlexInline>
                <Button href={translatePath(`/alliance/tribes/${tribe_id}/${group_id}`)}>
                    {t('back_to_name').replace('{name}', tribe_group?.name ?? t('group'))}
                </Button>
            </FlexInline>
        </FlexInline>

        <Flexblock gap="var(--space-2xl)">
            {fetch_error ? (
                <ErrorRefetch
                    args={{
                        partial: TRIBE_GROUP_ACTIVITY_PARTIAL_URL,
                        message: fetch_error,
                        delay: 0,
                    }}
                />
            ) : tribe_group ? (
                <Flexblock gap="var(--space-m)">
                    <p class="text-secondary" x-text="total + ' ' + (items.length < total ? '(' + items.length + ' shown)' : '')"></p>
                    <ul class="list-none p-0 m-0 flex flex-col gap-2" aria-label={t('tribes.detail.activity')}>
                        <template x-for="(row, i) in items" :key="row.id">
                            <li
                                class="rounded border border-default bg-card padding-block-sm padding-inline-m"
                                :data-index="i"
                            >
                                <span class="font-mono text-sm" x-text="row.date_display"></span>
                                <span class="mx-2" aria-hidden="true">·</span>
                                <span x-text="row.activity_type_display"></span>
                                <span class="mx-2" aria-hidden="true">·</span>
                                <span x-text="row.who"></span>
                                <template x-if="row.qty">
                                    <span><span class="mx-2" aria-hidden="true">·</span><span x-text="row.qty"></span></span>
                                </template>
                            </li>
                        </template>
                    </ul>
                    <div class="flex justify-center padding-block-m" x-show="hasMore">
                        <button
                            type="button"
                            class="button button--secondary"
                            @click="loadMore()"
                            :disabled="loading"
                            x-text="loading ? '…' : viewMoreLabel"
                        ></button>
                    </div>
                    <p class="text-error text-sm" x-show="error" x-text="error"></p>
                </Flexblock>
            ) : (
                <DebugTag set:html={t('no_tribe_group_unexpected_error')} />
            )}
        </Flexblock>
    </PageWide>
</Viewport>

<script>
    window.__tribeActivityInit = function (el) {
        const raw = el.getAttribute('data-activity-init')
        const d = raw ? JSON.parse(raw) : {}
        const apiUrl = d.apiUrl || ''
        const tribeId = d.tribeId ?? 0
        const groupId = d.groupId ?? 0
        const pageSize = d.pageSize ?? 20
        return {
            items: Array.isArray(d.items) ? d.items : [],
            total: typeof d.total === 'number' ? d.total : 0,
            limit: typeof d.limit === 'number' ? d.limit : pageSize,
            offset: typeof d.offset === 'number' ? d.offset : 0,
            loading: false,
            error: null,
            viewMoreLabel: typeof d.viewMoreLabel === 'string' ? d.viewMoreLabel : 'View more',
            get hasMore() {
                return this.items.length < this.total
            },
            async loadMore() {
                if (this.loading || !this.hasMore) return
                this.loading = true
                this.error = null
                const nextOffset = this.offset + this.limit
                const url = `${apiUrl}/api/tribes/${tribeId}/groups/${groupId}/activity?limit=${pageSize}&offset=${nextOffset}`
                try {
                    const res = await fetch(url, { headers: { 'Content-Type': 'application/json' } })
                    if (!res.ok) throw new Error(res.statusText)
                    const data = await res.json()
                    const newRows = (data.items || []).map((r) => ({
                        id: r.id,
                        created_at: r.created_at,
                        date_display: r.created_at ? new Date(r.created_at).toLocaleString() : '',
                        activity_type_display: r.activity_type_display || '',
                        character_name: r.character_name || '',
                        username: r.username || '',
                        who: r.character_name || r.username || '—',
                        quantity: r.quantity,
                        unit: r.unit || '',
                        qty: r.quantity != null && r.unit ? r.quantity + ' ' + r.unit : '',
                        reference_type: r.reference_type || '',
                        reference_id: r.reference_id || '',
                    }))
                    this.items = this.items.concat(newRows)
                    this.offset = data.offset
                    this.limit = data.limit
                    this.total = data.total
                } catch (e) {
                    this.error = e && e.message ? e.message : 'Failed to load more'
                }
                this.loading = false
            },
        }
    }
</script>
