---
import { i18n } from '@helpers/i18n'
const { t, translatePath } = i18n(Astro.url)

import { prod_error_messages } from '@helpers/env'
import { HTTP_400_Bad_Request } from '@helpers/http_responses'
import { get_auth_url } from '@helpers/env'

import type { User } from '@dtypes/jwt'
import * as jose from 'jose'

const auth_token = Astro.cookies.has('auth_token') ? Astro.cookies.get('auth_token')?.value : false
const user = auth_token ? jose.decodeJwt(auth_token) as User : false

if (!auth_token || !user) {
    Astro.cookies.set('redirect_after_auth', Astro.url.href, { path: '/' })
    return Astro.redirect(get_auth_url())
}

const tribe_id = parseInt(Astro?.params?.tribe_id ?? '')
const group_id = parseInt(Astro?.params?.group_id ?? '')

if (isNaN(tribe_id) || isNaN(group_id))
    return HTTP_400_Bad_Request()

import type { TribeGroup, SummaryCharacter, TribeMembership } from '@dtypes/api.minmatar.org'
import { get_tribe_group, get_memberships } from '@helpers/api.minmatar.org/tribes'

let tribe_group:TribeGroup | null = null
let approved:TribeMembership[] = []
let pending:TribeMembership[] = []
let fetch_membership_error:string | false = false

try {
    tribe_group = await get_tribe_group(tribe_id, group_id)

    approved = await get_memberships(auth_token as string, tribe_id, tribe_group.id, 'active')
    pending = await get_memberships(auth_token as string, tribe_id, tribe_group.id, 'pending')
} catch (error) {
    fetch_membership_error = prod_error_messages() ? t('fetch_membership_error') : error.message
}

let count_text = ''

if (pending.length > 0)
    count_text = t(pending.length !== 1 ? 'pending_applications_plural' : 'pending_applications_singular').replace('{count}', String(pending.length))
else
    count_text = t(approved.length !== 1 ? 'memebrship_plural' : 'memebrship_singular').replace('{count}', String(approved.length))

const TRIBE_GROUP_MEMBERSHIPS_PARTIAL_URL = translatePath(`/partials/tribe_group_memberships_component?tribe_id=${tribe_id}&group_id=${group_id}`)

import Viewport from '@layouts/Viewport.astro';

import PageWide from '@components/page/PageWide.astro';
import PageTitle from '@components/page/PageTitle.astro';

import Flexblock from '@components/compositions/Flexblock.astro';
import FlexInline from '@components/compositions/FlexInline.astro';

import ErrorRefetch from '@components/blocks/ErrorRefetch.astro';
import Button from '@components/blocks/Button.astro';
import Input from '@components/blocks/Input.astro';
import MembershipRequests from '@components/blocks/MembershipRequests.astro'
import MembershipTable from '@components/blocks/MembershipTable.astro'
import GroupLeadership from '@components/blocks/GroupLeadership.astro';
import DebugTag from '@components/blocks/DebugTag.astro';

import MagnifierIcon from '@components/icons/buttons/MagnifierIcon.astro';

const page_title = t('tribes.groups.membership.page_title').replace('{group}', tribe_group?.name ?? '')
---

<Viewport
    title={page_title}
    components={{
        alert_dialog: true,
        confirm_dialog: true,
        modal: true,
    }}
>
    <PageWide
        cover={{
            image: "/images/groups-cover.jpg",
            image_990: "/images/groups-cover.jpg",
            overlay: true,
            scrollable: true,
        }}
        sticky={true}
        wide={true}
        x-data={`{
            count_text: '${count_text}',
            item_name_filter: '',
            show_item(el) {
                const name_filter_element = el.querySelectorAll('.membership-characters')

                return ( this.item_name_filter === '' || name_filter_element[0].textContent.toLowerCase().includes(this.item_name_filter.toLowerCase()) )
            },
        }`}
    >
        <FlexInline id="header-oob" slot="header" justification='space-between' class="[ w-full ]">
            <Flexblock gap="var(--space-3xs)">
                <PageTitle>
                    {page_title}
                </PageTitle>
                <small x-text="count_text">{count_text}</small>
            </Flexblock>
            <FlexInline>
                <Input type="text"
                    placeholder={t('filter')}
                    x-model="item_name_filter"
                    x-init="$el.focus()"
                >
                    <MagnifierIcon slot="icon" />
                </Input>
            </FlexInline>
        </FlexInline>

        <FlexInline id="subheader-oob" slot="subheader">
            {tribe_group &&
                <Button
                    href={translatePath(`/alliance/tribes/${tribe_group.tribe_id}/${tribe_group.id}/activities`)}
                    size='sm'
                >
                    {t('activities')}
                </Button>

                <Button
                    href={translatePath(`/alliance/tribes/${tribe_group?.tribe_id}`)}
                    size='sm'
                >
                    {t('back_to_name').replace('{name}', tribe_group?.tribe_name ?? t('tribe'))}
                </Button>
            }
        </FlexInline>
        
        {fetch_membership_error ?
            <ErrorRefetch
                args={{
                    partial: TRIBE_GROUP_MEMBERSHIPS_PARTIAL_URL,
                    message: fetch_membership_error,
                    delay: 0,
                }}
            />
            :
            tribe_group ?
                <Flexblock id="members" gap='var(--space-2xl)'>
                    {pending.length > 0 || approved.length > 0 ?
                        <GroupLeadership chief={tribe_group?.chief} elders={[]} />
                        <MembershipRequests requests={pending} init_tooltips={false} />
                        <MembershipTable memberships={approved} init_tooltips={false} />
                        :
                        <p>{t('no_request_no_members')}</p>
                    }
                </Flexblock>
                :
                <DebugTag set:html={t('no_tribe_group_unexpected_error')} />
        }
    </PageWide>
</Viewport>