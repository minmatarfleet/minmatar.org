---
import { i18n } from '@helpers/i18n'
const { t, translatePath } = i18n(Astro.url)

import { prod_error_messages } from '@helpers/env'

import type { User } from '@dtypes/jwt'
import * as jose from 'jose'

const auth_token = Astro.cookies.has('auth_token') ? (Astro.cookies.get('auth_token')?.value as string) : false
const user: User | false = auth_token ? jose.decodeJwt(auth_token) as User : false

import type { Tribe } from '@dtypes/api.minmatar.org'
import { get_tribes, get_current_tribes } from '@helpers/api.minmatar.org/tribes'

let tribes: Tribe[] = []
let current_tribe_ids: Set<number> = new Set()
let get_tribes_error: string | null = null

try {
    tribes = await get_tribes()
    if (auth_token) {
        const current = await get_current_tribes(auth_token)
        current_tribe_ids = new Set(current.map(t => t.id))
    }
} catch (error) {
    get_tribes_error = prod_error_messages() ? 'Error loading tribes. Please try again.' : error.message
}

import Viewport from '@layouts/Viewport.astro'
import PageWide from '@components/page/PageWide.astro'
import PageTitle from '@components/page/PageTitle.astro'
import TextBox from '@components/layout/TextBox.astro'
import Flexblock from '@components/compositions/Flexblock.astro'
import FlexInline from '@components/compositions/FlexInline.astro'
import Button from '@components/blocks/Button.astro'
import ErrorRefetch from '@components/blocks/ErrorRefetch.astro'

const page_title = t('tribes.list.page_title')
---

<Viewport
    title={page_title}
    meta_description={t('tribes.list.meta_description')}
>
    <PageWide
        cover={{
            image: "/images/groups-cover.jpg",
            image_990: "/images/groups-cover.jpg",
            animated: false,
            scrollable: true,
            overlay: true,
        }}
    >
        <FlexInline slot="header" justification="space-between" class="[ w-full ]">
            <Flexblock gap="var(--space-3xs)">
                <PageTitle>{page_title}</PageTitle>
                <small>
                    {tribes.length}&nbsp;{tribes.length !== 1 ? t('tribes_available').toLowerCase() : t('tribe_available').toLowerCase()}
                </small>
            </Flexblock>
        </FlexInline>

        <Flexblock gap="var(--space-xl)">
            <TextBox>
                <p class="[ excerpt ]">{t('tribes.list.leading_text')}</p>
            </TextBox>

            {get_tribes_error ? (
                <ErrorRefetch
                    args={{
                        partial: '',
                        message: get_tribes_error,
                        delay: 0,
                    }}
                />
            ) : (
                <div class="[ tribes-grid ]">
                    {tribes.map(tribe => (
                        <a
                            href={translatePath(`/alliance/tribes/${tribe.id}`)}
                            class={`[ tribe-card ]${current_tribe_ids.has(tribe.id) ? ' tribe-card--member' : ''}`}
                        >
                            <div class="[ tribe-card__cover ]">
                                {tribe.banner_url ? (
                                    <img
                                        src={tribe.banner_url}
                                        alt={tribe.name}
                                        loading="lazy"
                                    />
                                ) : tribe.image_url ? (
                                    <img
                                        src={tribe.image_url}
                                        alt={tribe.name}
                                        loading="lazy"
                                    />
                                ) : (
                                    <div class="[ tribe-card__cover-fallback ]"></div>
                                )}
                            </div>

                            <div class="[ tribe-card__body ]">
                                <FlexInline justification="space-between" class="[ tribe-card__header ]">
                                    <h3 class="[ tribe-card__name ]">{tribe.name}</h3>
                                    {current_tribe_ids.has(tribe.id) && (
                                        <span class="[ tribe-badge tribe-badge--member ]">Member</span>
                                    )}
                                </FlexInline>

                                {tribe.description && (
                                    <p class="[ tribe-card__description ]">{tribe.description}</p>
                                )}

                                <FlexInline gap="var(--space-m)" class="[ tribe-card__meta ]">
                                    <span class="[ tribe-meta-item ]">
                                        <span class="[ tribe-meta-item__value ]">{tribe.group_count}</span>
                                        <span class="[ tribe-meta-item__label ]">{t('tribes.list.groups')}</span>
                                    </span>
                                    <span class="[ tribe-meta-item ]">
                                        <span class="[ tribe-meta-item__value ]">{tribe.total_member_count}</span>
                                        <span class="[ tribe-meta-item__label ]">{t('tribes.list.members')}</span>
                                    </span>
                                </FlexInline>
                            </div>
                        </a>
                    ))}
                </div>
            )}
        </Flexblock>
    </PageWide>
</Viewport>

<style lang="scss">
    .tribes-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(min(100%, 340px), 1fr));
        gap: var(--space-m);
    }

    .tribe-card {
        display: flex;
        flex-direction: column;
        border: 1px solid var(--border-color);
        border-radius: var(--border-radius, 4px);
        overflow: hidden;
        text-decoration: none;
        color: inherit;
        transition: border-color 200ms ease, box-shadow 200ms ease;
        background: var(--surface-1, hsl(0 0% 8%));

        &:hover {
            border-color: var(--highlight);
            box-shadow: 0 0 0 1px var(--highlight);
        }

        &--member {
            border-color: var(--fleet-yellow, #f0d060);
        }
    }

    .tribe-card__cover {
        width: 100%;
        aspect-ratio: 16 / 7;
        overflow: hidden;

        img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            transition: transform 400ms ease;

            .tribe-card:hover & {
                transform: scale(1.03);
            }
        }
    }

    .tribe-card__cover-fallback {
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, hsl(220 30% 14%) 0%, hsl(220 40% 20%) 100%);
    }

    .tribe-card__body {
        display: flex;
        flex-direction: column;
        gap: var(--space-2xs);
        padding: var(--space-s) var(--space-m) var(--space-m);
        flex: 1;
    }

    .tribe-card__header {
        align-items: flex-start;
    }

    .tribe-card__name {
        font-size: var(--step-1);
        font-weight: 600;
        margin: 0;
        color: var(--highlight, #c8a951);
    }

    .tribe-card__description {
        font-size: var(--step--1);
        color: var(--foreground-2, hsl(0 0% 65%));
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin: 0;
    }

    .tribe-card__meta {
        margin-top: auto;
        padding-top: var(--space-xs);
        border-top: 1px solid var(--border-color);
    }

    .tribe-meta-item {
        display: flex;
        align-items: baseline;
        gap: var(--space-3xs);
    }

    .tribe-meta-item__value {
        font-size: var(--step-1);
        font-weight: 700;
        color: var(--foreground, white);
    }

    .tribe-meta-item__label {
        font-size: var(--step--2);
        color: var(--foreground-2, hsl(0 0% 65%));
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .tribe-badge {
        font-size: var(--step--2);
        padding: 2px 8px;
        border-radius: 999px;
        font-weight: 600;
        white-space: nowrap;
        text-transform: uppercase;
        letter-spacing: 0.05em;

        &--member {
            background: color-mix(in srgb, var(--fleet-yellow, #f0d060) 20%, transparent);
            color: var(--fleet-yellow, #f0d060);
            border: 1px solid color-mix(in srgb, var(--fleet-yellow, #f0d060) 40%, transparent);
        }
    }
</style>
