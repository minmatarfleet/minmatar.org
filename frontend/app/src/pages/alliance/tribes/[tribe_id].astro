---
import { i18n } from '@helpers/i18n'
const { t, translatePath } = i18n(Astro.url)

import type { User } from '@dtypes/jwt'
import * as jose from 'jose'

const auth_token = Astro.cookies.has('auth_token') ? Astro.cookies.get('auth_token')?.value : false
const user = auth_token ? jose.decodeJwt(auth_token) as User : false
const is_superuser = (user ? user?.is_superuser : false)

import { get_user_permissions } from '@helpers/permissions'

const user_permissions = user && user?.username ? await get_user_permissions(user?.username) : []
const is_alliance_member = user_permissions.includes('eveonline.add_evecharactertag')

import { HTTP_404_Not_Found } from '@helpers/http_responses'

import type {
    Tribe,
    TribeGroup,
    TribeMembership,
    SummaryCharacter,
    TribeAvailableCharacter,
} from '@dtypes/api.minmatar.org'
import {
    get_tribe,
    get_tribe_groups,
    get_memberships,
    get_membership_characters_available,
} from '@helpers/api.minmatar.org/tribes'
import { get_characters_summary_sorted } from '@helpers/fetching/characters'

const tribe_id = parseInt(Astro.params.tribe_id as string)
if (isNaN(tribe_id)) return HTTP_404_Not_Found()

let tribe: Tribe | null = null
let tribe_groups: TribeGroup[] = []
const membership_by_group = new Map<number, TribeMembership | null>()
const available_by_group = new Map<number, TribeAvailableCharacter[]>()
let user_characters: SummaryCharacter[] = []
let get_tribe_error: Error | false = false

try {
    tribe = await get_tribe(tribe_id)
    tribe_groups = await get_tribe_groups(tribe_id)

    if (auth_token && user) {
        for (const group of tribe_groups) {
            const memberships = await get_memberships(auth_token, tribe_id, group.id)
            const mine = memberships.find(m => m.user_id === user.user_id) ?? null
            membership_by_group.set(group.id, mine)
        }

        const summary = await get_characters_summary_sorted(auth_token)
        user_characters = summary.characters ?? []

        const availableResults = await Promise.all(
            tribe_groups.map(async (group) => {
                try {
                    const list = await get_membership_characters_available(
                        auth_token as string,
                        tribe_id,
                        group.id,
                    )
                    return [group.id, list] as const
                } catch {
                    return [group.id, []] as const
                }
            }),
        )

        for (const [gid, list] of availableResults)
            available_by_group.set(gid, list as TribeAvailableCharacter[])
    }
} catch (error) {
    get_tribe_error = error
}

import { strip_markdown } from '@helpers/string'

const TRIBE_PARTIAL_URL = translatePath(`/partials/tribe_component?tribe_id=${tribe_id}`)

const count_text = t(tribe_groups.length != 1 ? 'tribes_plural' : 'tribes_singular').replace('{count}', String(tribe_groups.length))

import Viewport from '@layouts/Viewport.astro';

import PageLanding from '@components/page/PageLanding.astro';
import PageTitle from '@components/page/PageTitle.astro';

import TextBox from '@components/layout/TextBox.astro';

import Flexblock from '@components/compositions/Flexblock.astro';
import FlexInline from '@components/compositions/FlexInline.astro';

import ErrorRefetch from '@components/blocks/ErrorRefetch.astro';
import TribeTiles from '@components/blocks/TribeTiles.astro';
import Button from '@components/blocks/Button.astro';
import PilotBadge from '@components/blocks/PilotBadge.astro'

const page_title = tribe?.name ?? ''
const page_description = tribe?.description ?? ''
const meta_description = await strip_markdown(page_description)
---

<Viewport
    title={page_title}
    meta_description={meta_description}
    components={{
        alert_dialog: true,
        confirm_dialog: true,
        modal: true,
    }}
>
    <PageLanding
        cover={{
            image: "/images/groups-cover.jpg",
            image_990: "/images/groups-cover.jpg",
            overlay: true,
            scrollable: true,
        }}
        wide={true}
        x-data={`{
            count_text: '${count_text}',
        }`}
    >
        <Flexblock gap='var(--space-2xl)'>
            <FlexInline class="[ !items-start ]" justification='space-between'>
                <TextBox>
                    <Flexblock id="header-oob" gap="var(--space-3xs)">
                        <PageTitle is_landing={true}>
                            {page_title}
                        </PageTitle>
                        {tribe?.chief &&
                            <PilotBadge
                                character_id={tribe.chief.character_id}
                                character_name={tribe.chief.character_name}
                                size={32}
                                centered={true}
                            >
                                <small>{t('tribe_chief')}</small>
                            </PilotBadge>
                        }
                    </Flexblock>
                </TextBox>
                <FlexInline class="[ !items-start ]">
                    <Button href={translatePath('/alliance/tribes/')}>
                        {t('back_to_tribes')}
                    </Button>
                </FlexInline>
            </FlexInline>

            <TextBox>
                <p id="excerpt-oob" class="[ excerpt ]">{page_description}</p>
            </TextBox>

            {get_tribe_error ?
                <ErrorRefetch
                    args={{
                        partial: TRIBE_PARTIAL_URL,
                        error: get_tribe_error,
                        delay: 0,
                    }}
                />
                :
                <TribeTiles
                    tribe_groups={tribe_groups}
                    user_characters={user_characters}
                    available_by_group={available_by_group}
                    membership_by_group={membership_by_group}
                    is_alliance_member={is_alliance_member}
                    init_tooltips={false}
                />
            }
        </Flexblock>
    </PageLanding>
</Viewport>