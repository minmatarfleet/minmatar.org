---
import * as page from '@markdown/values.md'

import { marked } from 'marked'
import { renderer } from '@helpers/marked'
import { strip_markdown } from '@helpers/string'
import { pageProgressFromMarkdown } from '@helpers/pageProgress'

import Viewport from '@layouts/Viewport.astro'

import PageLanding from '@components/page/PageLanding.astro'
import PageTitle from '@components/page/PageTitle.astro'

import TextBox from '@components/layout/TextBox.astro'

import Wrapper from '@components/compositions/Wrapper.astro'

import Flexblock from '@components/compositions/Flexblock.astro'
import PageProgress from '@components/blocks/PageProgress.astro'

const page_title = page.frontmatter.title
const page_description = page.frontmatter.excerpt
const { html: values_html, sections: _sections, ...progress } = pageProgressFromMarkdown({
    page_key: 'alliance/values',
    page_title,
    markdown: page.rawContent(),
})
---

<Viewport
    title={page_title}
    meta_description={await strip_markdown(page_description)}
    components={{
        alert_dialog: true,
        confirm_dialog: true,
    }}
>
    <PageLanding
        wide={true}
        cover={{
            image: "/images/alliance-cover.jpg",
            image_990: "/images/alliance-cover.jpg",
            scrollable: true,
            overlay: true
        }}
    >
        <Flexblock gap='var(--space-2xl)' data-page-progress-root>
            <Wrapper
                max_width="var(--max-text-width)"
                padding_inline="0"
                padding_block="0"
            >
                <Flexblock gap='var(--space-xl)'>
                    <PageTitle is_landing={true}>{page_title}</PageTitle>
                    <p class="[ excerpt ]" set:html={marked.parseInline(page_description as string, { renderer })} />
                    <PageProgress {...progress} />
                </Flexblock>
            </Wrapper>

            <TextBox>
                <Flexblock gap='var(--space-xl)'>
                    <div
                        class="[ prose ]"
                        set:html={values_html}
                        x-data={`{
                            init_zoom() {
                                mediumZoom('img[data-zoomable]', {
                                    background: 'var(--solid-transparency-background)',
                                    scrollOffset: 0,
                                    margin: 24,
                                    metaClick: false,
                                })
                            }
                        }`}
                        x-init="init_zoom()"
                    />
                </Flexblock>
            </TextBox>
        </Flexblock>
    </PageLanding>
</Viewport>

<style lang="scss">
    .excerpt,
    :global(.excerpt p) {
        font-size: var(--step-1);
    }

    picture {
        display: flex;
        justify-content: center;
        align-items: center;
        aspect-ratio: 1/1;

        &.bordered {
            border: solid 1px var(--border-color)
        }
    }
</style>
