---
import { i18n } from '@helpers/i18n'
const { t, translatePath } = i18n(Astro.url)

import { COVER_IMAGE } from '@/data/campaigns/hek'
import { buildHekCampaignJsonLd } from '@/data/campaigns/hek-seo'

import Viewport from '@layouts/Viewport.astro'
import PageLanding from '@components/page/PageLanding.astro'
import PageTitle from '@components/page/PageTitle.astro'
import TextBox from '@components/layout/TextBox.astro'
import Wrapper from '@components/compositions/Wrapper.astro'
import Flexblock from '@components/compositions/Flexblock.astro'
import HekCampaign from '@components/blocks/campaigns/hek/HekCampaign.astro'
import Tag from '@components/blocks/Tag.astro'

const page_title = t('campaigns.hek.page_title')
const campaign_period = t('campaigns.hek.campaign_period')
const page_description = t('campaigns.hek.leading_text')
const meta_title = t('campaigns.hek.meta_title')
    .replace('{site}', t('index.page_title'))
const meta_description = t('campaigns.hek.meta_description')
const canonical_url = new URL(translatePath('/campaigns/hek/'), Astro.url.origin).href
const meta_image = new URL(COVER_IMAGE, Astro.url.origin).href

const structured_data = buildHekCampaignJsonLd({
    canonicalUrl: canonical_url,
    siteName: t('index.page_title'),
    siteOrigin: Astro.url.origin,
    metaTitle: page_title,
    metaDescription: meta_description,
    metaImage: meta_image,
})
---

<Viewport
    title={meta_title}
    meta_description={meta_description}
    meta_image={meta_image}
    canonical_url={canonical_url}
    og_type="article"
    components={{
        alert_dialog: true,
        confirm_dialog: true,
    }}
>
    <script type="application/ld+json" is:inline set:html={JSON.stringify(structured_data)} />

    <PageLanding
        wide={true}
        cover={{
            image: "/images/alliance-cover.jpg",
            image_990: "/images/alliance-cover.jpg",
            overlay: true,
            scrollable: true,
        }}
    >
        <Flexblock gap="var(--space-2xl)">
            <TextBox>
                <Flexblock gap="var(--space-xl)">
                    <Flexblock gap="var(--space-3xs)">
                        <PageTitle is_landing={true}>{page_title}</PageTitle>
                        <Tag text={campaign_period} color='fleet-yellow' />
                    </Flexblock>
                    <p class="[ excerpt ]">{page_description}</p>
                </Flexblock>
            </TextBox>

            <HekCampaign />
        </Flexblock>
    </PageLanding>
</Viewport>

<style lang="scss">
    .hek-page {
        width: 100%;
        max-width: 100%;
        min-width: 0;
        overflow-x: clip;
    }

    .campaign-period {
        font-size: var(--step-0);
        line-height: 1.4;
        color: var(--faded);
        margin: 0;
        max-width: 100%;
    }

    .excerpt,
    :global(.excerpt p) {
        font-size: var(--step-1);
        line-height: 1.6;
        max-width: 100%;
    }
</style>
