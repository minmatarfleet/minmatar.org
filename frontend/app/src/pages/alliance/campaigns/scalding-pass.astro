---
import { i18n } from '@helpers/i18n'
const { t, translatePath } = i18n(Astro.url)

import { COVER_IMAGE } from '@/data/campaigns/scalding-pass'
import { buildScaldingPassCampaignJsonLd } from '@/data/campaigns/scalding-pass-seo'

import Viewport from '@layouts/Viewport.astro'
import PageLanding from '@components/page/PageLanding.astro'
import PageTitle from '@components/page/PageTitle.astro'
import TextBox from '@components/layout/TextBox.astro'
import Flexblock from '@components/compositions/Flexblock.astro'
import ScaldingPassCampaign from '@components/blocks/campaigns/scalding-pass/ScaldingPassCampaign.astro'
import Tag from '@components/blocks/Tag.astro'

const page_title = t('campaigns.scalding_pass.page_title')
const campaign_period = t('campaigns.scalding_pass.campaign_period')
const page_description = t('campaigns.scalding_pass.leading_text')
const meta_title = t('campaigns.scalding_pass.meta_title')
    .replace('{site}', t('index.page_title'))
const meta_description = t('campaigns.scalding_pass.meta_description')
const canonical_url = new URL(translatePath('/campaigns/scalding-pass/'), Astro.url.origin).href
const meta_image = new URL(COVER_IMAGE, Astro.url.origin).href

import {
    get_location_video_cover,
    get_location_video_cover_thumb,
    get_location_cover,
    get_location_cover_990,
} from '@helpers/covers'

const structured_data = buildScaldingPassCampaignJsonLd({
    canonicalUrl: canonical_url,
    siteName: t('index.page_title'),
    siteOrigin: Astro.url.origin,
    metaTitle: page_title,
    metaDescription: meta_description,
    metaImage: meta_image,
})
---

<Viewport
    title={meta_title}
    meta_description={meta_description}
    meta_image={meta_image}
    canonical_url={canonical_url}
    og_type="article"
    components={{
        alert_dialog: true,
        confirm_dialog: true,
    }}
>
    <script type="application/ld+json" is:inline set:html={JSON.stringify(structured_data)} />

    <PageLanding
        wide={true}
        cover={{
            video: get_location_video_cover('watermellon') ?? undefined,
			video_thumb: get_location_video_cover_thumb('watermellon') ?? undefined,
            image: get_location_cover('watermellon') ?? COVER_IMAGE,
            image_990: get_location_cover_990('watermellon') ?? COVER_IMAGE,
            animated: false,
            scrollable: true,
            overlay: true,
        }}
    >
        <Flexblock gap="var(--space-2xl)" class="sp-page">
            <TextBox>
                <Flexblock gap="var(--space-xl)">
                    <Flexblock gap="var(--space-3xs)">
                        <PageTitle is_landing={true}>{page_title}</PageTitle>
                        <Tag text={campaign_period} color='fleet-yellow' />
                    </Flexblock>
                    <p class="[ excerpt ]">{page_description}</p>
                </Flexblock>
            </TextBox>

            <ScaldingPassCampaign />
        </Flexblock>
    </PageLanding>
</Viewport>

<style lang="scss">
    .sp-page {
        width: 100%;
        max-width: 100%;
        min-width: 0;
        overflow-x: clip;
    }

    .campaign-period {
        font-size: var(--step-0);
        line-height: 1.4;
        color: var(--faded);
        margin: 0;
        max-width: 100%;
    }

    .excerpt,
    :global(.excerpt p) {
        font-size: var(--step-1);
        line-height: 1.6;
        max-width: 100%;
    }
</style>
