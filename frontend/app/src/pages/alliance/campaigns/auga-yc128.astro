---
import { i18n } from '@helpers/i18n'
const { t, translatePath } = i18n(Astro.url)

import { COVER_IMAGE, CANONICAL_PATH } from '@/data/campaigns/auga'
import { buildAugaSiegeJsonLd } from '@/data/campaigns/auga-seo'
import { get_site_origin } from '@helpers/seo'

import Viewport from '@layouts/Viewport.astro'
import PageLanding from '@components/page/PageLanding.astro'
import PageTitle from '@components/page/PageTitle.astro'
import TextBox from '@components/layout/TextBox.astro'
import Flexblock from '@components/compositions/Flexblock.astro'
import AugaSiegeCampaign from '@components/blocks/campaigns/auga/AugaSiegeCampaign.astro'
import Tag from '@components/blocks/Tag.astro'

const page_title = t('campaigns.auga.page_title')
const campaign_period = t('campaigns.auga.campaign_period')
const page_description = t('campaigns.auga.leading_text')
const meta_title = t('campaigns.auga.meta_title').replace('{site}', t('index.page_title'))
const meta_description = t('campaigns.auga.meta_description')
const site_origin = get_site_origin(Astro.url.origin)
const canonical_url = new URL(translatePath(CANONICAL_PATH), site_origin).href
const meta_image = new URL(COVER_IMAGE, site_origin).href

const structured_data = buildAugaSiegeJsonLd({
    canonicalUrl: canonical_url,
    siteName: t('index.page_title'),
    siteOrigin: site_origin,
    metaTitle: page_title,
    metaDescription: meta_description,
    metaImage: meta_image,
})
---

<Viewport
    title={meta_title}
    meta_description={meta_description}
    meta_image={meta_image}
    canonical_url={canonical_url}
    og_type="article"
    components={{
        alert_dialog: true,
        confirm_dialog: true,
    }}
>
    <script type="application/ld+json" is:inline set:html={JSON.stringify(structured_data)} />

    <PageLanding
        wide={true}
        cover={{
            image: COVER_IMAGE,
            image_990: COVER_IMAGE,
            animated: false,
            scrollable: true,
            overlay: true,
        }}
    >
        <Flexblock gap="var(--space-2xl)" class="auga-page">
            <TextBox>
                <Flexblock gap="var(--space-xl)">
                    <Flexblock gap="var(--space-3xs)">
                        <PageTitle is_landing={true}>{page_title}</PageTitle>
                        <Tag text={campaign_period} color="fleet-yellow" />
                    </Flexblock>
                    <p class="[ excerpt ]">{page_description}</p>
                </Flexblock>
            </TextBox>

            <AugaSiegeCampaign />
        </Flexblock>
    </PageLanding>
</Viewport>

<style lang="scss">
    .auga-page {
        width: 100%;
        max-width: 100%;
        min-width: 0;
        overflow-x: clip;
    }

    .excerpt,
    :global(.excerpt p) {
        font-size: var(--step-1);
        line-height: 1.6;
        max-width: 100%;
    }
</style>
