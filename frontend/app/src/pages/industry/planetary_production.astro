---
import { i18n } from '@helpers/i18n'
const { t, translatePath } = i18n(Astro.url)

import type { User } from '@dtypes/jwt'
import * as jose from 'jose'

const auth_token = Astro.cookies.has('auth_token') ? (Astro.cookies.get('auth_token')?.value as string) : false
const user:User | false = auth_token ? jose.decodeJwt(auth_token) as User : false
const valid_user = user !== false && user?.user_id > 0

import type { HarvestOverviewItem, ProductionOverviewItem } from '@dtypes/api.minmatar.org'
import { get_planetary_harvest, get_planetary_production } from '@helpers/api.minmatar.org/industry'

import type {  SelectOptions } from '@dtypes/layout_components'
import { get_characters } from '@helpers/api.minmatar.org/characters'

let user_characters_ids:number[] = []
let data_fetching_error = ''
let harvest: HarvestOverviewItem[] = []
let production: ProductionOverviewItem[] = []

try {
    harvest = await get_planetary_harvest()
    harvest = harvest.sort((a, b) => (a.total_daily_quantity ?? 0) - (b.total_daily_quantity ?? 0))
    production = await get_planetary_production()
    production = production.sort((a, b) => (a.total_daily_quantity ?? 0) - (b.total_daily_quantity ?? 0))

    const user_characters = valid_user ? await get_characters(auth_token as string) : []
    user_characters_ids = user_characters.map(character => character.character_id)
} catch (error) {
    data_fetching_error = error.message
}

const PLANETARY_PRODUCTION_PARTIAL_URL = translatePath('/partials/planetary_production_component')

const resources = [ ...harvest, ...production ]
const resources_type_count = resources.length
const resources_type_count_text = (resources_type_count != 1 ? t('showing_resource_types_plural') : t('showing_resource_types_singular')).replace('{count}', String(resources_type_count))

const resources_names = resources.map(resource => resource.name)
const resources_options = resources_names.map(resource_name => {
    return { label: resource_name, value: resource_name } as SelectOptions
})

import Viewport from '@layouts/Viewport.astro';

import PageDefault from '@components/page/PageDefault.astro';
import PageTitle from '@components/page/PageTitle.astro';

import Flexblock from '@components/compositions/Flexblock.astro';
import FlexInline from '@components/compositions/FlexInline.astro';

import ErrorRefetch from '@components/blocks/ErrorRefetch.astro';
import Select from '@components/blocks/Select.astro';
import PlanetaryProductionTable from '@components/blocks/PlanetaryProductionTable.astro'


const page_title = t('industry.planetary_production.page_title')
---

<Viewport
    title={page_title}
    meta_description={t('industry.planetary_production.meta_description')}
    components={{
        alert_dialog: true,
        confirm_dialog: true,
    }}
>
    <PageDefault
        cover={{
            image: "/images/planetary-cover.jpg",
            image_990: "/images/planetary-cover.jpg",
            overlay: true,
            scrollable: true,
        }}
        sticky={true}
        x-data={`{
            resources_type_count: ${resources_type_count},
            resource_type_filter: '-1',
            resources_options: ${JSON.stringify(resources_options)},
            showing_resource_types_plural: '${t('showing_resource_types_plural')}',
            showing_resource_types_singular: '${t('showing_resource_types_singular')}',
            countVisibleElements(selector, parent = document) {
                const elements = parent.querySelectorAll(selector)
                let visible_count = 0

                elements.forEach(element => {
                    const is_visible = element.offsetParent !== null
                    if (is_visible)
                        visible_count++
                })

                return visible_count
            },
            show_item(el) {
                const resource_type_filter_element = el.querySelectorAll('h3')
                return ( this.resource_type_filter === '-1' || resource_type_filter_element[0].textContent.toLowerCase().includes(this.resource_type_filter.toLowerCase()) )
            },
        }`}
    >
        <FlexInline slot="header" justification='space-between' class="[ w-full ]">
            <Flexblock gap="var(--space-3xs)">
                <PageTitle>
                    {page_title}
                </PageTitle>
                <small x-text="(resources_type_count != 1 ? showing_resource_types_plural : showing_resource_types_singular).replace('{count}', String(resources_type_count))">
                    {resources_type_count_text}
                </small>
            </Flexblock>
            <FlexInline>
                <Select
                    x-model="resource_type_filter"
                    x-on:change="setTimeout(function () { resources_type_count = countVisibleElements('h3') }, 200)"
                >
                    <option selected value="-1">{t('all_resource_types')}</option>
                    <template x-for="option in resources_options">
                        <option x-bind:value="option.value" x-text="option.label" />
                    </template>
                </Select>
            </FlexInline>
        </FlexInline>
    
        {data_fetching_error ?
            <ErrorRefetch
                args={{
                    partial: PLANETARY_PRODUCTION_PARTIAL_URL,
                    message: data_fetching_error,
                    delay: 0,
                }}
            />
            :
            resources.length > 0 ?
                <PlanetaryProductionTable
                    harvest={harvest}
                    production={production}
                    init_tooltips={false}
                /> :
                <p>{t('no_planetary_resources')}</p>
        }
	</PageDefault>

    <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="0" height="0">
        <defs>
            <symbol id="volumen_icon" width="128" height="128">
                <style>
                    .s1 { opacity: .25; }
                    .s2 { opacity: .6; }
                </style>
                <path class="s0" d="m46.85 91.71l-39.75-22.95v-45.97l39.75 22.95z" fill="currentColor" />
