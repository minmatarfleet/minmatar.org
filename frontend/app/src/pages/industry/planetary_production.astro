            </symbol>
            <symbol id="extractor_icon">
                <path fill-rule="evenodd" class="s0" d="m94.24 28.02c2.11 2.11 2.11 5.54 0 7.65-2.11 2.11-5.54 2.11-7.65 0l-17.19-17.19v65c0 2.99-2.41 3-5.4 3-2.99 0-5.4-0.01-5.4-3v-65l-17.19 17.19c-2.11 2.11-5.54 2.11-7.65 0-2.11-2.11-2.11-5.54 0-7.65l26.41-26.41c2.11-2.11 5.54-2.11 7.65 0 0.01 0 26.42 26.41 26.42 26.41zm10.79 31.86c8.79 17.54 5.87 39.44-8.77 54.08-18.29 18.29-47.94 18.29-66.23 0-14.83-14.83-17.64-37.12-8.42-54.78 3-1.72 11.68 5.47 11.06 7.89-5.58 12.32-3.3 27.31 6.83 37.44 13.06 13.06 34.24 13.06 47.31 0 10.2-10.2 12.44-25.33 6.71-37.7-0.76-1.56 9.43-8.6 11.51-6.93z" fill="currentColor" />
            </symbol>
