---
import { i18n } from '@helpers/i18n'
const { t, translatePath } = i18n(Astro.url)

import { HTTP_400_Bad_Request } from '@helpers/http_responses'

import type { User } from '@dtypes/jwt'
import * as jose from 'jose'

const auth_token = Astro.cookies.has('auth_token') ? (Astro.cookies.get('auth_token')?.value as string) : false
const user:User | false = auth_token ? jose.decodeJwt(auth_token) as User : false
const is_logged_in = !!(user && auth_token)

import { get_order_by_id, get_planner_facilities } from '@helpers/api.minmatar.org/industry'
import { get_characters } from '@helpers/api.minmatar.org/characters'
import { get_ship_info } from '@helpers/sde/ships'
import { get_item_name } from '@helpers/sde/items'
import type { IndustrySingleOrder, RootSingleItem, Character } from '@dtypes/api.minmatar.org'
import type { PlannerFacility } from '@helpers/api.minmatar.org/industry'
import type { Alert } from '@dtypes/layout_components'

type PlannerProduct = {
    type_id: number
    type_name: string
    quantity: number
}

let order: IndustrySingleOrder | null = null
let item: RootSingleItem | undefined = undefined
let product: PlannerProduct | null = null
let facilities: PlannerFacility[] = []
let characters: Character[] = []
let data_fetching_error: Error | false = false
let alert: Alert | null = null
/** Default researched BPO; faction/navy hulls use ME 0 / TE 0. */
let default_blueprint_me = 10
let default_blueprint_te = 20

const type_id_param = parseInt(Astro.url.searchParams.get('type_id') ?? '0')
const quantity_param = parseInt(Astro.url.searchParams.get('quantity') ?? '0')
const order_id = parseInt(Astro.url.searchParams.get('order_id') ?? '0')
const item_id = parseInt(Astro.url.searchParams.get('item_id') ?? '0')

const has_type_id = !isNaN(type_id_param) && type_id_param > 0
const has_order_item = !isNaN(order_id) && order_id > 0 && !isNaN(item_id) && item_id > 0

try {
    if (has_type_id) {
        const type_name = await get_item_name(type_id_param)
        if (!type_name)
            throw new Error(t('industry.orders.planner.invalid_params'), { cause: 400 })

        product = {
            type_id: type_id_param,
            type_name,
            quantity: !isNaN(quantity_param) && quantity_param > 0 ? quantity_param : 1,
        }
    } else if (has_order_item) {
        order = await get_order_by_id(order_id)
        item = order.items.find(row => row.id === item_id)
        if (!item)
            throw new Error(t('industry.orders.planner.invalid_params'), { cause: 400 })

        product = {
            type_id: item.eve_type_id,
            type_name: item.eve_type_name,
            quantity: item.quantity,
        }
    } else {
        throw new Error(t('industry.orders.planner.invalid_params'), { cause: 400 })
    }

    facilities = await get_planner_facilities(auth_token || undefined)
    if (is_logged_in)
        characters = await get_characters(auth_token as string)
} catch (error) {
    data_fetching_error = error
    if (error?.cause === 400)
        return HTTP_400_Bad_Request()
}

let is_navy_hull = false
if (product) {
    try {
        const ship_info = await get_ship_info(product.type_id)
        const navy_name = /(?:Navy|Fleet) Issue$/i.test(product.type_name ?? '')
        if (ship_info?.meta === 'Faction' || navy_name) {
            default_blueprint_me = 0
            default_blueprint_te = 0
            is_navy_hull = true
        }
    } catch {
        const navy_name = /(?:Navy|Fleet) Issue$/i.test(product.type_name ?? '')
        if (navy_name) {
            default_blueprint_me = 0
            default_blueprint_te = 0
            is_navy_hull = true
        }
    }
}

import { query_string } from '@helpers/string'
import { number_thousand_separator } from '@helpers/numbers'

import {
    get_location_video_cover,
    get_location_video_cover_thumb,
    get_location_cover,
    get_location_cover_990,
} from '@helpers/covers'

const location_name = order?.location?.location_name

import Viewport from '@layouts/Viewport.astro';
import PageDefault from '@components/page/PageDefault.astro';
import PageTitle from '@components/page/PageTitle.astro';

import TextBox from '@components/layout/TextBox.astro';
import Markdown from '@components/blocks/Markdown.astro';

import BlockList from '@components/compositions/BlockList.astro'
import FlexInline from '@components/compositions/FlexInline.astro';
import Flexblock from '@components/compositions/Flexblock.astro';

import Button from '@components/blocks/Button.astro';
import Input from '@components/blocks/Input.astro';
import Select from '@components/blocks/Select.astro';
import Switch from '@components/blocks/Switch.astro';
import ClipboardButton from '@components/blocks/ClipboardButton.astro';
import ItemBadge from '@components/blocks/ItemBadge.astro';
import ErrorRefetch from '@components/blocks/ErrorRefetch.astro';
import ShowAlert from '@components/blocks/ShowAlert.astro';
import ComponentBlock from '@components/blocks/ComponentBlock.astro';
import TextGroup from '@components/blocks/TextGroup.astro';
import CharacterPicture from '@components/blocks/CharacterPicture.astro';
import ButtonAuth from '@components/blocks/ButtonAuth.astro';
import Breadcrumb from '@components/blocks/Breadcrumb.astro';

const page_title = product
    ? (product.quantity > 1
        ? `${product.type_name} × ${number_thousand_separator(product.quantity)}`
        : product.type_name)
    : t('industry.orders.planner.page_title')
const viewport_title = product
    ? `${page_title} · ${t('industry.orders.planner.page_title')}`
    : t('industry.orders.planner.page_title')
const default_facility = facilities[0]?.key ?? 'amamake'
const default_refine = facilities[0]?.reprocessing?.refine_rate ?? 0

const order_code = order?.public_short_code ?? (order_id > 0 ? String(order_id) : null)
const breadcrumb_items = [
    { label: t('market.page_title'), href: translatePath('/market/') },
    { label: t('industry.orders.page_title'), href: translatePath('/industry/orders/') },
    ...(order_code
        ? [{ label: order_code, href: translatePath(`/industry/orders/${order_id}/`) }]
        : []),
    { label: t('industry.orders.planner.page_title') },
]
const refetch_query = product
    ? (has_type_id
        ? query_string({
            type_id: product.type_id,
            ...(product.quantity !== 1 ? { quantity: product.quantity } : {}),
        })
        : query_string({ order_id, item_id }))
    : query_string({
        ...(has_type_id ? { type_id: type_id_param } : {}),
        ...(has_order_item ? { order_id, item_id } : {}),
    })

const bucket_labels = JSON.stringify({
    end_products: t('industry.orders.planner.bucket.end_products'),
    advanced_components: t('industry.orders.planner.bucket.advanced_components'),
    first_stage_reactions: t('industry.orders.planner.bucket.first_stage_reactions'),
    second_stage_reactions: t('industry.orders.planner.bucket.second_stage_reactions'),
    other: t('industry.orders.planner.bucket.other'),
})
---

<Viewport
    title={viewport_title}
    meta_description={t('industry.orders.planner.meta_description')}
    components={{
        alert_dialog: true,
        confirm_dialog: true,
    }}
>
    <PageDefault
        cover={{
			video: location_name ? get_location_video_cover(location_name) : undefined,
			video_thumb: location_name ? get_location_video_cover_thumb(location_name) : undefined,
            image: location_name ? get_location_cover(location_name) : '/images/industry-cover.jpg',
            image_990: location_name ? get_location_cover_990(location_name) : '/images/industry-cover.jpg',
            animated: false,
            scrollable: true,
            overlay: true,
        }}
    >
        {alert && <ShowAlert alert={alert} />}

        <Flexblock slot="header" gap="var(--space-s)" class="[ w-full ]">
            <Breadcrumb items={breadcrumb_items} />
            <PageTitle>
                {page_title}
            </PageTitle>
        </Flexblock>

        <BlockList gap='var(--space-xl)'>
            {data_fetching_error !== false ?
                <ErrorRefetch
                    args={{
                        partial: translatePath(`/industry/orders/planner?${refetch_query}`),
                        error: data_fetching_error,
                        delay: 0,
                    }}
                />
                :
                <>{product &&
                    <aside class="[ planner-beta ]" role="note">
                        <p class="[ planner-beta__title ]">{t('industry.orders.planner.beta_title')}</p>
                        <Markdown
                            class="[ planner-beta__body ]"
                            markdown={t('industry.orders.planner.beta_warning')}
                            inline={true}
                        />
                    </aside>

                    <TextBox>
                        <p>{t('industry.orders.planner.leading_text')}</p>
                    </TextBox>

                    <div
                        class="[ planner ]"
                        x-data={`{
                            quantity: ${product.quantity},
                            blueprint_me: ${default_blueprint_me},
                            blueprint_te: ${default_blueprint_te},
                            facility_key: '${default_facility}',
                            compressed: true,
                            character_id: '',
                            use_reprocessing_implants: false,
                            is_navy_hull: ${is_navy_hull ? 'true' : 'false'},
                            isk_per_lp: '',
                            build_fuel_blocks: false,
                            loading: false,
                            facility_loading: false,
                            rate_loading: false,
                            error: '',
                            materials_tsv: '',
                            effective_refine: ${default_refine},
                            refine_source: 'facility_default',
                            skill_summary: '',
                            implant_status: '${t('industry.orders.planner.implant_off')}',
                            ore_yields: [],
                            character_skills: null,
                            facility_detail: null,
                            jobs: [],
                            subitem_catalog: [],
                            build_toggles: {},
                            product_type_id: ${product.type_id},
                            cost_breakdown: null,
                            _replan_timer: null,
                            _suspend_watch: false,
                            _plan_generation: 0,
                            _loaded_facility_key: '',
                            _loaded_refine_key: '',
                            bucket_labels: ${bucket_labels},
                            // Auto-replan watches plannerInputSnapshot() only (user inputs).
                            // To add a new control: x-model it onto this component and include
                            // that field in plannerInputSnapshot() — no per-control @change.
                            // Do not put plan response fields (jobs, materials_tsv, etc.) here.
                            plannerInputSnapshot() {
                                const toggles = this.build_toggles
                                const toggle_entries = Object.keys(toggles)
                                    .sort()
                                    .map(k => k + ':' + toggles[k])
                                return [
                                    this.quantity,
                                    this.blueprint_me,
                                    this.blueprint_te,
                                    this.facility_key,
                                    this.character_id,
                                    this.compressed,
                                    this.use_reprocessing_implants,
                                    this.isk_per_lp,
                                    this.build_fuel_blocks,
                                    toggle_entries.join(','),
                                ].join('|')
                            },
                            initPlannerAutoReplan() {
                                this.$watch(
                                    () => this.plannerInputSnapshot(),
                                    () => this.scheduleReplan()
                                )
                                this.applyPlannerInputs()
                            },
                            scheduleReplan() {
                                if (this._suspend_watch)
                                    return
                                clearTimeout(this._replan_timer)
                                this._replan_timer = setTimeout(
                                    () => this.applyPlannerInputs(),
                                    300
                                )
                            },
                            withSuspendedWatch(fn) {
                                this._suspend_watch = true
                                try {
                                    return fn()
                                } finally {
                                    this._suspend_watch = false
                                }
                            },
                            async applyPlannerInputs() {
                                clearTimeout(this._replan_timer)
                                const gen = ++this._plan_generation
                                const facility_changed =
                                    this.facility_key !== this._loaded_facility_key
                                const refine_key = [
                                    this.facility_key,
                                    this.character_id,
                                    !!this.use_reprocessing_implants,
                                ].join('|')
                                const refine_changed =
                                    refine_key !== this._loaded_refine_key

                                if (facility_changed) {
                                    this.withSuspendedWatch(() => {
                                        this.subitem_catalog = []
                                        this.build_toggles = {}
                                    })
                                    this._loaded_facility_key = this.facility_key
                                    await this.loadFacility()
                                    if (gen !== this._plan_generation)
                                        return
                                }
                                if (refine_changed || facility_changed) {
                                    this._loaded_refine_key = refine_key
                                    await this.refreshRefineRate()
                                    if (gen !== this._plan_generation)
                                        return
                                }
                                await this.runPlan(gen)
                            },
                            pct(v) {
                                return ((Number(v) || 0) * 100).toFixed(2) + '%'
                            },
                            escapeHtml(s) {
                                return String(s ?? '')
                                    .replace(/&/g, '&amp;')
                                    .replace(/</g, '&lt;')
                                    .replace(/>/g, '&gt;')
                                    .replace(/"/g, '&quot;')
                            },
                            fittingTooltip(item) {
                                if (!item) return ''
                                const name = this.escapeHtml(item.name)
                                const effects = (item.effects || [])
                                    .map((line) => '<div>' + this.escapeHtml(line) + '</div>')
                                    .join('')
                                return '<strong>' + name + '</strong>' + effects
                            },
                            fittingTippy($el) {
                                if (!$el || typeof tippy === 'undefined')
                                    return
                                const opts = (typeof tippy_options !== 'undefined')
                                    ? Object.assign({}, tippy_options, { allowHTML: true })
                                    : { delay: [100, 200], arrow: true, allowHTML: true }
                                tippy($el, opts)
                            },
                            formatIsk(v) {
                                return Number(v || 0).toLocaleString()
                            },
                            costBreakdownTipHtml(mode) {
                                const breakdown = this.cost_breakdown
                                if (!breakdown || !breakdown.line_items)
                                    return ''
                                const qty = Math.max(
                                    Number(breakdown.output_quantity) || 1,
                                    1
                                )
                                const perUnit = mode === 'per_unit'
                                const lines = [
                                    perUnit
                                        ? '${t('industry.orders.planner.per_unit_cost_tip')}'
                                        : '${t('industry.orders.planner.total_cost_tip')}',
                                    '',
                                ]
                                // Show every backend line (incl. reprocessing tax
                                // when compression is on, and freight if present).
                                for (const row of breakdown.line_items) {
                                    const amount = Number(row.amount_isk) || 0
                                    const shown = perUnit
                                        ? Math.round(amount / qty)
                                        : amount
                                    lines.push(
                                        this.escapeHtml(row.label)
                                        + ': '
                                        + this.formatIsk(shown)
                                        + ' ISK'
                                    )
                                }
                                if (Number(breakdown.freight_volume_m3) > 0) {
                                    lines.push(
                                        '${t('industry.orders.planner.freight_volume')}: '
                                        + Number(breakdown.freight_volume_m3).toLocaleString(
                                            undefined,
                                            { maximumFractionDigits: 2 }
                                        )
                                        + ' m³'
                                    )
                                }
                                if (
                                    !breakdown.freight_route_id
                                    && Number(breakdown.freight_volume_m3) > 0
                                ) {
                                    lines.push(
                                        '${t('industry.orders.planner.freight_none')}'
                                    )
                                }
                                if (perUnit) {
                                    lines.push(
                                        '<strong>${t('industry.orders.planner.per_unit_cost')}: '
                                        + this.formatIsk(
                                            Math.round(breakdown.per_unit_isk)
                                        )
                                        + ' ISK</strong>'
                                    )
                                    lines.push(
                                        '${t('industry.orders.planner.per_unit_equals_total')}'
                                            .replace('{n}', String(qty))
                                    )
                                } else {
                                    lines.push(
                                        '<strong>${t('industry.orders.planner.total_cost')}: '
                                        + this.formatIsk(
                                            breakdown.grand_total_isk
                                        )
                                        + ' ISK</strong>'
                                    )
                                }
                                return lines.join('<br>')
                            },
                            bindCostTooltip() {
                                this.$nextTick(() => {
                                    if (typeof tippy === 'undefined')
                                        return
                                    const pairs = [
                                        [
                                            this.$refs.cost_total,
                                            this.costBreakdownTipHtml('total'),
                                        ],
                                        [
                                            this.$refs.cost_per_unit,
                                            this.costBreakdownTipHtml('per_unit'),
                                        ],
                                    ]
                                    for (const [el, content] of pairs) {
                                        if (!el)
                                            continue
                                        if (!content) {
                                            if (el._tippy)
                                                el._tippy.destroy()
                                            continue
                                        }
                                        if (el._tippy) {
                                            el._tippy.setContent(content)
                                        } else {
                                            tippy(el, {
                                                delay: [100, 200],
                                                arrow: true,
                                                allowHTML: true,
                                                content,
                                            })
                                        }
                                    }
                                })
                            },
                            defaultBuildForBucket(_bucket) {
                                // Intermediates default to buy/import (buy all).
                                // Root product is never in build_toggles / exclude_type_ids.
                                return false
                            },
                            excludeTypeIds() {
                                return Object.entries(this.build_toggles)
                                    .filter(([, on]) => !on)
                                    .map(([id]) => parseInt(id))
                            },
                            syncSubitemsFromJobs(jobs) {
                                let needs_replan = false
                                // Suspend watch so buy-all default toggles do not
                                // schedule a second debounced replan; runPlan re-runs
                                // inline when needs_replan is true.
                                return this.withSuspendedWatch(() => {
                                    const by_id = {}
                                    for (const row of this.subitem_catalog)
                                        by_id[row.product_type_id] = row
                                    for (const job of jobs || []) {
                                        if (job.product_type_id === this.product_type_id)
                                            continue
                                        const id = job.product_type_id
                                        const key = String(id)
                                        if (by_id[id]) {
                                            by_id[id].product_name = job.product_name
                                            by_id[id].bucket = job.bucket
                                            by_id[id].runs = job.runs
                                        } else {
                                            this.subitem_catalog.push({
                                                product_type_id: id,
                                                product_name: job.product_name,
                                                bucket: job.bucket,
                                                runs: job.runs,
                                            })
                                            by_id[id] = this.subitem_catalog[
                                                this.subitem_catalog.length - 1
                                            ]
                                        }
                                        if (this.build_toggles[key] === undefined) {
                                            const build = this.defaultBuildForBucket(
                                                job.bucket
                                            )
                                            this.build_toggles[key] = build
                                            if (!build)
                                                needs_replan = true
                                        }
                                    }
                                    return needs_replan
                                })
                            },
                            subitemBuckets() {
                                const order = [
                                    'advanced_components',
                                    'first_stage_reactions',
                                    'second_stage_reactions',
                                    'other',
                                ]
                                const grouped = {}
                                for (const row of this.subitem_catalog) {
                                    const bucket = row.bucket || 'other'
                                    if (!grouped[bucket]) grouped[bucket] = []
                                    grouped[bucket].push(row)
                                }
                                return order
                                    .filter(key => (grouped[key] || []).length)
                                    .map(key => ({
                                        key,
                                        label: this.bucket_labels[key] || key,
                                        rows: grouped[key].sort((a, b) =>
                                            a.product_name.localeCompare(b.product_name)
                                        ),
                                    }))
                            },
                            async loadFacility() {
                                this.facility_loading = true
                                try {
                                    const response = await fetch(
                                        '/api/industry/planner/facilities/' + encodeURIComponent(this.facility_key),
                                        { credentials: 'same-origin' }
                                    )
                                    if (!response.ok) throw new Error('facility')
                                    this.facility_detail = await response.json()
                                } catch (e) {
                                    this.facility_detail = null
                                } finally {
                                    this.facility_loading = false
                                }
                            },
                            async refreshRefineRate() {
                                this.rate_loading = true
                                try {
                                    const body = {
                                        facility_key: this.facility_key,
                                        use_reprocessing_implants: !!this.use_reprocessing_implants,
                                    }
                                    if (this.character_id)
                                        body.character_id = parseInt(this.character_id)
                                    const response = await fetch('/api/industry/planner/refine-rate', {
                                        method: 'POST',
                                        credentials: 'same-origin',
                                        headers: { 'Content-Type': 'application/json' },
                                        body: JSON.stringify(body),
                                    })
                                    if (!response.ok) throw new Error('refine')
                                    const data = await response.json()
                                    this.effective_refine = data.refine_rate
                                    this.refine_source = data.refine_rate_source
                                    this.ore_yields = data.ore_yields || []
                                    this.applySkillSummary(data.character_skills)
                                } catch (e) {
                                    this.skill_summary = ''
                                    this.implant_status = ''
                                    this.ore_yields = []
                                    this.character_skills = null
                                    this.bindRefineTooltip()
                                } finally {
                                    this.rate_loading = false
                                }
                            },
                            romanLevel(level) {
                                const n = Math.max(0, Math.min(5, Number(level) || 0))
                                return ['0', 'I', 'II', 'III', 'IV', 'V'][n]
                            },
                            applySkillSummary(s) {
                                this.character_skills = s || null
                                if (!this.use_reprocessing_implants) {
                                    this.skill_summary = s
                                        ? ('R' + s.reprocessing_level +
                                            '/RE' + s.reprocessing_efficiency_level +
                                            '/Ore' + s.ore_processing_level)
                                        : ''
                                    this.implant_status = '${t('industry.orders.planner.implant_off')}'
                                    this.bindRefineTooltip()
                                    return
                                }
                                if (!s) {
                                    this.skill_summary = ''
                                    this.implant_status = (!this.character_id)
                                        ? '${t('industry.orders.planner.implant_assumed_max')}'
                                        : ''
                                    this.bindRefineTooltip()
                                    return
                                }
                                this.skill_summary =
                                    'R' + s.reprocessing_level +
                                    '/RE' + s.reprocessing_efficiency_level +
                                    '/Ore' + s.ore_processing_level
                                if (s.implant_type_id && s.implant_bonus > 0) {
                                    const name = s.implant_name || ('type ' + s.implant_type_id)
                                    const pct = (s.implant_bonus * 100).toFixed(0) + '%'
                                    this.implant_status =
                                        '${t('industry.orders.planner.implant_fitted')}: ' +
                                        name + ' (+' + pct + ')'
                                } else {
                                    // Toggle ON with no RX found → backend assumes RX-804.
                                    this.implant_status =
                                        '${t('industry.orders.planner.implant_assumed_max')}'
                                }
                                this.bindRefineTooltip()
                            },
                            refineYieldTipHtml() {
                                const lines = [
                                    '${t('industry.orders.planner.effective_refine_tip')}',
                                    '',
                                    '<strong>${t('industry.orders.planner.refine_core')}</strong>',
                                ]
                                const s = this.character_skills
                                const rep = s ? s.reprocessing_level : 5
                                const re = s ? s.reprocessing_efficiency_level : 5
                                lines.push(
                                    this.escapeHtml('Reprocessing ' + this.romanLevel(rep))
                                )
                                lines.push(
                                    this.escapeHtml(
                                        'Reprocessing Efficiency ' + this.romanLevel(re)
                                    )
                                )
                                const yields = this.ore_yields || []
                                if (yields.length) {
                                    lines.push('')
                                    lines.push(
                                        '<strong>${t('industry.orders.planner.refine_per_ore')}</strong>'
                                    )
                                    for (const row of yields) {
                                        const pct = (
                                            (Number(row.refine_rate) || 0) * 100
                                        ).toFixed(2) + '%'
                                        lines.push(
                                            this.escapeHtml(
                                                row.ore_name
                                                + ' — '
                                                + row.skill_name
                                                + ' '
                                                + this.romanLevel(row.skill_level)
                                                + ' → '
                                                + pct
                                            )
                                        )
                                    }
                                } else if (this.skill_summary) {
                                    lines.push('')
                                    lines.push(this.escapeHtml(this.skill_summary))
                                }
                                if (this.implant_status)
                                    lines.push(this.escapeHtml(this.implant_status))
                                return lines.join('<br>')
                            },
                            bindRefineTooltip() {
                                this.$nextTick(() => {
                                    if (typeof tippy === 'undefined')
                                        return
                                    const el = this.$refs.refine_yield
                                    if (!el)
                                        return
                                    const content = this.refineYieldTipHtml()
                                    el.setAttribute('data-tippy-content', content)
                                    if (el._tippy) {
                                        el._tippy.setContent(content)
                                    } else {
                                        tippy(el, {
                                            delay: [100, 200],
                                            arrow: true,
                                            allowHTML: true,
                                            content,
                                        })
                                    }
                                })
                            },
                            async runPlan(gen) {
                                if (gen === undefined)
                                    gen = ++this._plan_generation
                                this.loading = true
                                this.error = ''
                                try {
                                    const body = {
                                        product_type_id: this.product_type_id,
                                        quantity: Math.max(1, parseInt(this.quantity) || 1),
                                        blueprint_me: Math.max(0, parseInt(this.blueprint_me) || 0),
                                        blueprint_te: Math.max(0, parseInt(this.blueprint_te) || 0),
                                        facility_key: this.facility_key,
                                        compressed: this.compressed,
                                        build_fuel_blocks: this.build_fuel_blocks,
                                        use_reprocessing_implants: !!this.use_reprocessing_implants,
                                        exclude_type_ids: this.excludeTypeIds(),
                                    }
                                    if (this.character_id)
                                        body.character_id = parseInt(this.character_id)
                                    if (this.is_navy_hull) {
                                        const rate = parseFloat(this.isk_per_lp)
                                        if (rate > 0)
                                            body.isk_per_lp = rate
                                    }

                                    const response = await fetch('/api/industry/planner/plans', {
                                        method: 'POST',
                                        credentials: 'same-origin',
                                        headers: { 'Content-Type': 'application/json' },
                                        body: JSON.stringify(body),
                                    })
                                    if (gen !== this._plan_generation)
                                        return
                                    if (!response.ok) {
                                        let detail = '${t('industry.orders.planner.error')}'
                                        try {
                                            const err = await response.json()
                                            if (err.detail) detail = err.detail
                                        } catch (e) {}
                                        throw new Error(detail)
                                    }
                                    const data = await response.json()
                                    if (gen !== this._plan_generation)
                                        return
                                    this.jobs = data.jobs || []
                                    const needs_replan = this.syncSubitemsFromJobs(this.jobs)
                                    if (needs_replan) {
                                        // Re-run once so buy-all defaults apply to the BOM.
                                        await this.runPlan(gen)
                                        return
                                    }
                                    this.cost_breakdown = data.cost_breakdown || null
                                    this.materials_tsv = data.materials_tsv || ''
                                    this.bindCostTooltip()
                                    if (data.compressed_ore) {
                                        this.effective_refine = data.compressed_ore.refine_rate
                                        this.refine_source = data.compressed_ore.refine_rate_source
                                        this.materials_tsv = data.compressed_ore.materials_tsv || data.materials_tsv
                                        this.ore_yields = data.compressed_ore.ore_yields || []
                                        this.applySkillSummary(data.compressed_ore.character_skills)
                                    }
                                } catch (e) {
                                    if (gen !== this._plan_generation)
                                        return
                                    this.error = e.message || '${t('industry.orders.planner.error')}'
                                    this.materials_tsv = ''
                                    this.cost_breakdown = null
                                } finally {
                                    if (gen === this._plan_generation)
                                        this.loading = false
                                }
                            },
                            setBucketSubitemToggles(bucket, on) {
                                for (const row of this.subitem_catalog) {
                                    if ((row.bucket || 'other') === bucket)
                                        this.build_toggles[String(row.product_type_id)] = on
                                }
                                if (bucket === 'other')
                                    this.build_fuel_blocks = on
                            },
                            selectBucketSubitems(bucket) {
                                this.setBucketSubitemToggles(bucket, true)
                            },
                            deselectBucketSubitems(bucket) {
                                this.setBucketSubitemToggles(bucket, false)
                            },
                        }`}
