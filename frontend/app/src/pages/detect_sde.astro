---
// 1. Get a map of all files in the data directory
// The asterisk (*) matches any file name
const dataFiles = import.meta.glob('/src/data/*');

// 2. Define the file you are looking for (relative to the project root)
const targetFile = '/src/data/sqlite-latest-3316380.sqlite';

// 3. Check if the key exists in the object
const fileExists = Object.keys(dataFiles).includes(targetFile);
---

<div>
  {fileExists ? (
    <p>The file "{targetFile}" was found!</p>
  ) : (
    <p>File not found in /src/data/</p>
  )}
</div>