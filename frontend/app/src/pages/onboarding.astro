---
import { i18n } from '@helpers/i18n'
const { t, translatePath } = i18n(Astro.url)

import type { User } from '@dtypes/jwt'
import * as jose from 'jose'

const auth_token = Astro.cookies.has('auth_token') ? Astro.cookies.get('auth_token')?.value : false
const user = auth_token ? jose.decodeJwt(auth_token) as User : false

if (!user) return Astro.redirect(`${translatePath('/redirects/auth_init')}?redirect_url=${Astro.url}`)

import {
    post_onboarding_ack,
    SRP_ONBOARDING_PROGRAM_TYPE,
} from '@helpers/api.minmatar.org/onboarding'
import { safe_onboarding_return_path } from '@helpers/onboarding/srpRedirect'

const default_return_path = translatePath('/ships/srp/')
const return_from_query = safe_onboarding_return_path(
    Astro.url.searchParams.get('return'),
    default_return_path,
)

let submit_error: string | false = false

if (Astro.request.method === 'POST') {
    const data = await Astro.request.formData()
    const ack_ok = ['onboarding_ack_1', 'onboarding_ack_2', 'onboarding_ack_3'].every(
        (name) => data.get(name) === 'on',
    )
    if (!ack_ok) {
        submit_error = t('onboarding.submit_incomplete_body')
    } else {
        try {
            await post_onboarding_ack(auth_token as string, SRP_ONBOARDING_PROGRAM_TYPE)
            const redirect_to = safe_onboarding_return_path(
                data.get('return') as string | null,
                default_return_path,
            )
            return Astro.redirect(redirect_to)
        } catch (err) {
            submit_error = err instanceof Error ? err.message : String(err)
        }
    }
}

import * as srp_overview_md from '@markdown/srp-overview.md';
import * as srp_source_md from '@markdown/srp-source.md';

import { marked } from 'marked';
import { renderer } from '@helpers/marked';

import Viewport from '@layouts/Viewport.astro';

import PageLanding from '@components/page/PageLanding.astro';
import PageTitle from '@components/page/PageTitle.astro';

import TextBox from '@components/layout/TextBox.astro';

import Flexblock from '@components/compositions/Flexblock.astro';
import FlexInline from '@components/compositions/FlexInline.astro';

import Button from '@components/blocks/Button.astro';

const page_title = t('onboarding.page_title');

const acknowledgments = [
    t('onboarding.acknowledgment_1'),
    t('onboarding.acknowledgment_2'),
    t('onboarding.acknowledgment_3'),
] as const;
---

<Viewport
    title={page_title}
    meta_description={t('onboarding.meta_description')}
    components={{
        alert_dialog: true,
        confirm_dialog: true,
        modal: true,
    }}
>
    <PageLanding
        cover={{
            image: "/images/srp-cover.jpg",
            image_990: "/images/srp-cover.jpg",
            overlay: true,
            scrollable: true,
        }}
        wide={true}
    >
        <Flexblock gap='var(--space-2xl)'>
            <FlexInline class="[ !items-start ]" justification='space-between'>
                <TextBox>
                    <PageTitle is_landing={true}>{page_title}</PageTitle>
                </TextBox>
                <FlexInline class="[ !items-start ]">
                    <Button href={translatePath('/ships/srp/')}>
                        {t('onboarding.back_to_srp')}
                    </Button>
                </FlexInline>
            </FlexInline>

            <TextBox>
                <p class="[ excerpt ]">{t('onboarding.subheader')}</p>
            </TextBox>

            <Flexblock gap='var(--space-xl)'>
                <TextBox>
                    <h2 class="[ onboarding-section-title ]">{t('overview_description')}</h2>
                    <div
                        class="[ prose ]"
                        set:html={marked.parse(srp_overview_md.rawContent(), { renderer })}
                    />
                </TextBox>

                <TextBox>
                    <h2 class="[ onboarding-section-title ]">{t('source_description')}</h2>
                    <div
                        class="[ prose ]"
                        set:html={marked.parse(srp_source_md.rawContent(), { renderer })}
                    />
                </TextBox>
            </Flexblock>

            <TextBox>
                {submit_error &&
                    <p class="[ onboarding-submit-error ]" role="alert">⚠️ {submit_error}</p>
                }
                <form class="[ onboarding-form ]" method="post">
                    <input type="hidden" name="return" value={return_from_query} />
                    <div class="[ onboarding-ack ]" role="group" aria-label={t('onboarding.acknowledgments_group_label')}>
                        {acknowledgments.map((text, i) => (
                            <label class="[ onboarding-ack__item ]">
                                <input
                                    class="[ onboarding-ack__input ]"
                                    type="checkbox"
                                    name={`onboarding_ack_${i + 1}`}
                                    value="on"
                                    required
                                />
                                <span
                                    class="[ onboarding-ack__text ]"
                                    set:html={marked.parseInline(text, { renderer })}
                                />
                            </label>
                        ))}
                    </div>

                    <div class="[ onboarding-form__actions ]">
                        <Button type="submit">{t('onboarding.submit_button')}</Button>
                    </div>
                </form>
            </TextBox>
        </Flexblock>
    </PageLanding>
</Viewport>

<style lang="scss">
    .prose {
        padding-top: var(--space-s);
    }

    .onboarding-section-title {
        font-size: var(--step-0);
        line-height: 1.5;
        font-weight: 600;
        text-wrap: pretty;
    }

    .onboarding-submit-error {
        color: var(--highlight);
        margin-bottom: var(--space-s);
    }

    .onboarding-form {
        display: flex;
        flex-direction: column;
        gap: var(--space-l);
    }

    .onboarding-ack {
        display: flex;
        flex-direction: column;
        gap: var(--space-l);
        padding-top: var(--space-m);
        border-top: 1px solid var(--border-color);
    }

    .onboarding-form__actions {
        padding-top: var(--space-s);
    }

    .onboarding-ack__item {
        display: flex;
        gap: var(--space-s);
        align-items: flex-start;
        cursor: pointer;
    }

    .onboarding-ack__input {
        appearance: none;
        flex-shrink: 0;
        width: 1.125rem;
        height: 1.125rem;
        margin: 0.2rem 0 0 0;
        border-radius: 2px;
        background: transparent;
        cursor: pointer;

        &:not(:checked) {
            border: 1px solid rgb(255 255 255 / 0.35);
            outline: 1px solid rgb(255 255 255 / 0.45);
            outline-offset: 1px;
        }

        &:checked {
            border: 1px solid rgb(255 255 255 / 0.35);
            outline: none;
            background-color: var(--fleet-yellow);
            box-shadow: inset 0 0 0 2px var(--background);
        }

        &:focus-visible {
            outline: 2px solid var(--highlight);
            outline-offset: 2px;
        }

        &:focus-visible:checked {
            outline-offset: 2px;
        }
    }

    .onboarding-ack__text {
        font-size: var(--step--1);
        line-height: 1.5;
        color: var(--fleet-yellow);

        :global(strong) {
            font-weight: 700;
            color: var(--highlight);
        }
    }
</style>
