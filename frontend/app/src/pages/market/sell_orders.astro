---
/* Unpublished — public stock browse removed; deep links redirect to Market Ops */

import { i18n } from '@helpers/i18n'
const { translatePath } = i18n(Astro.url)

import { get_market_locations } from '@helpers/api.minmatar.org/locations'
import { ops_redirect_target } from '@helpers/market_ops_redirect'

let target = translatePath('/market/ops/')

try {
    const locations = await get_market_locations()
    target = ops_redirect_target(translatePath, locations, Astro.url.searchParams)
} catch {
    // Keep default ops URL when locations cannot be loaded.
}

return Astro.redirect(target, 301)
---
