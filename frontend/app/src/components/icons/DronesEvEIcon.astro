---
import { i18n } from '@helpers/i18n'
const { t } = i18n(Astro.url)

import { get_bug_icon } from '@helpers/bug_icons'
---
<img class={Astro.props.class} loading="lazy" class="[ max-w-[100%] h-auto ]" src={get_bug_icon("/images/icons/48px-Icon_fit_drone.png")} width="48" height="48" alt={t('icon.drones.alt')} />