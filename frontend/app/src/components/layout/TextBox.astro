---
interface Props {
    max_width?:     string;
    [propName: string]: any;
}

const {
    max_width = 'var(--max-text-width)',
    ...attributes
} = Astro.props

import Wrapper from '@components/compositions/Wrapper.astro';
---

<Wrapper max_width={max_width} padding_inline="0" padding_block="0" {...attributes}>
    <slot />
</Wrapper>