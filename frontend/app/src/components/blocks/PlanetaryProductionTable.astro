---
import { i18n } from '@helpers/i18n'
const { t } = i18n(Astro.url)

import type { HarvestOverviewItem, ProductionOverviewItem } from '@dtypes/api.minmatar.org'

interface Props {
    harvest:            HarvestOverviewItem[];
    production:         ProductionOverviewItem[];
    init_tooltips?:     boolean;
}

const {
    harvest,
    production,
    init_tooltips,
} = Astro.props

import Flexblock from '@components/compositions/Flexblock.astro';

import HarvestResourceItem from '@components/blocks/HarvestResourceItem.astro';
import ProductionResourceItem from '@components/blocks/ProductionResourceItem.astro';
import Table from '@components/blocks/Table.astro';
---

<Flexblock gap='var(--space-2xl)'>
    <Flexblock gap='var(--space-l)'>
        <h4 class="[ group-title ]">{t('harvest_summary')}</h4>
        <Table>
            {harvest.map((resource) =>
                <div x-show="show_item($el)">
                    <HarvestResourceItem
                        resource={resource}
                        init_tooltips={init_tooltips}
                    />
                </div>
            )}
            <p class="[ no-result-text ]">{t('no_results')}</p>
        </Table>
    </Flexblock>

    <Flexblock gap='var(--space-l)'>
        <h4 class="[ group-title ]">{t('production_summary')}</h4>
        <Table>
            {production.map((resource) =>
                <div x-show="show_item($el)">
                    <ProductionResourceItem
                        resource={resource}
                        init_tooltips={init_tooltips}
                    />
                </div>
            )}
            <p class="[ no-result-text ]">{t('no_results')}</p>
        </Table>
    </Flexblock>
</Flexblock>

<style lang="scss">
    :not([style="display: none;"]) ~ .no-result-text {
        display: none;
    }
</style>