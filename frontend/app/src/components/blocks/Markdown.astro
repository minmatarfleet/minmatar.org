---
import { i18n } from '@helpers/i18n'
const { t } = i18n(Astro.url)

interface Props {
    markdown:               string;
    inline?:                boolean;
    inline_element?:        'p' | 'span' | 'small';
    element?:               'div' | 'Flexblock';
    open_in_new_tab?:       boolean;
    [propName: string]:     any;
}

const {
    markdown,
    inline = false,
    inline_element = 'p',
    element = Flexblock,
    open_in_new_tab = false,
    ...attributes
} = Astro.props

import { marked } from 'marked';
import { getRenderer } from '@helpers/marked';

const InlineElement = inline_element
const Element = element
const content = markdown ?? ''
const renderer = getRenderer(open_in_new_tab)

import Flexblock from '@components/compositions/Flexblock.astro'
---

{inline ?
    <InlineElement {...attributes} set:html={content ? marked.parseInline(content, { renderer: renderer, breaks: true }) : ''} /> :
    <Element {...attributes} set:html={content ? marked.parse(content, { renderer: renderer }) : ''} />
}