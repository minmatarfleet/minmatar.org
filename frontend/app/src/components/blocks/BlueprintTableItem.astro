---
import { i18n } from '@helpers/i18n'
const { t } = i18n(Astro.url)

import type { Blueprint } from '@dtypes/api.minmatar.org'

interface Props {
    blueprint:         Blueprint;
    is_copy:            boolean;
}

const {
    blueprint,
    is_copy,
} = Astro.props

const LOCATION_TEXT = {
    Hangar: t('Hangar'),
    Cargo: t('Cargo'),
    AssetSafety: t('AssetSafety'),
    FleetHangar: t('FleetHangar'),
    Deliveries: t('Deliveries'),
    CorpSAG: t('CorpSAG'),
}

import { get_bpc_icon } from '@helpers/eve_image_server';

import FlexInline from '@components/compositions/FlexInline.astro';
import FixedFluid from '@components/compositions/FixedFluid.astro';
import Flexblock from '@components/compositions/Flexblock.astro';

import CharacterPicture from '@components/blocks/CharacterPicture.astro';
import CorporationPicture from '@components/blocks/CorporationPicture.astro';
import Progress from '@components/blocks/Progress.astro';
import Picture from '@components/blocks/Picture.astro';

import MaterialEfficiencyIcon from '@components/icons/MaterialEfficiencyIcon.astro';
import TimeEfficiencyIcon from '@components/icons/TimeEfficiencyIcon.astro';
import CargoIcon from '@components/icons/CargoIcon.astro';
---

<div class="[ blueprint-item ]">
    <FixedFluid
        width='450px'
        gap='var(--space-3xs)'
    >
        <div>
            <FixedFluid
                class="[ items-center ]"
                width='64'
            >
                <Picture
                    src={get_bpc_icon(
                        blueprint.type_id,
                        is_copy,
                    )}
                    alt={blueprint.type_name}
                    size={64}
                />
                <Flexblock gap='var(--space-3xs)'>
                    <h3>{blueprint.type_name}</h3>
                    <small>
                        {blueprint.runs === -1 ? t('infinite_runs') : (blueprint.runs != 1 ? t('runs_count_plural') : t('runs_count_singular')).replace('{count}', String(blueprint.runs))}
                    </small>
                </Flexblock>
            </FixedFluid>
        </div>

        <FlexInline gap='var(--space-l)'>
            <Flexblock class="[ basis-17.5 ]" gap='var(--space-3xs)'>
                <FlexInline class="[ items-center! ]" justification='space-between'>
                    <div
                        class="[ text-highlight h-[16px] ]"
                        data-tippy-content={t('material_efficiency')}
                        x-init='tippy($el, tippy_options)'
                    >
                        <MaterialEfficiencyIcon size={16} xlink='#material_efficiency_icon' />
                    </div>
                    <small>{blueprint.material_efficiency}%</small>
                </FlexInline>
                <Progress
                    class="[ w-full ]"
                    max="10"
                    value={blueprint.material_efficiency.toString()}
                    data-tippy-content={`${blueprint.material_efficiency}%`}
                >
                    {blueprint.material_efficiency}%
                </Progress>
            </Flexblock>

            <Flexblock class="[ basis-17.5 ]" gap='var(--space-3xs)'>
                <FlexInline class="[ items-center! ]" justification='space-between'>
                    <div
                        class="[ text-highlight h-[16px] ]"
                        data-tippy-content={t('time_efficiency')}
                        x-init='tippy($el, tippy_options)'
                    >
                        <TimeEfficiencyIcon size={16} xlink='#time_efficiency_icon' />
                    </div>
                    <small>{blueprint.time_efficiency}%</small>
                </FlexInline>
                <Progress
                    class="[ w-full ]"
                    max="20"
                    value={blueprint.time_efficiency.toString()}
                    data-tippy-content={`${blueprint.time_efficiency}%`}
                >
                    {blueprint.time_efficiency}%
                </Progress>
            </Flexblock>
            
            <FlexInline gap='var(--space-3xs)'>
                {blueprint.owner.entity_type === 'character' &&
                    <CharacterPicture
                        character_id={blueprint.owner.entity_id}
                        size={32}
                    />
                }
                {blueprint.owner.entity_type === 'corporation' &&
                    <div class="[ border ]">
                        <CorporationPicture
                            corporation_id={blueprint.owner.entity_id}
                            size={32}
                        />
                    </div>
                }
            </FlexInline>

            <FixedFluid width='32px' breakpoint='30%' gap='var(--space-2xs)' class="[  items-center! ]">
                <div
                    class="[ text-highlight h-[32px] ]"
                    data-tippy-content={t('location')}
                    x-init='tippy($el, tippy_options)'
                >
                    <CargoIcon size={32} xlink='#cargo_icon' />
                </div>

                <small>{LOCATION_TEXT[blueprint.location_flag] ?? blueprint.location_flag}</small>
            </FixedFluid>
        </FlexInline>
    </FixedFluid>
</div>