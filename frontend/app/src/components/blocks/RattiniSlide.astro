---
import { i18n } from '@helpers/i18n'
const { t } = i18n(Astro.url)

import type { CorporationObject } from '@dtypes/layout_components'

interface Props {
    corporation:            CorporationObject;
    is_user_corporation?:   boolean;
    picture_placement?:     'left' | 'right';
    
}

const {
    corporation,
    is_user_corporation = false,
    picture_placement = 'left',
} = Astro.props

const BEARTHATCARES_ID = 634915984

import CorporationSlide from '@components/blocks/CorporationSlide.astro';
---

<CorporationSlide
    id="rattini-slide"
    ceo_image='/images/corporations/rattini/ceo.png'
    ceo_character_id={BEARTHATCARES_ID}
    corporation={corporation}
    is_user_corporation={is_user_corporation}
    picture_placement='left'
    mirror_slide={picture_placement === 'right'}
>
    <img slot="ships" class="[ jaguar ]" src="/images/corporations/rattini/jaguar.png" />
    <img slot="ships" class="[ scimitar ]" src="/images/corporations/rattini/scimitar.png" />
    <img slot="ships" class="[ sleipnir ]" src="/images/corporations/rattini/sleipnir.png" />

    <p>{corporation.introduction ? corporation.introduction : t('rattini_description_fallback') }</p>
</CorporationSlide>

<style lang="scss">
    .jaguar {
        position: absolute;
        top: 40%;
        left: 5%;
        height: auto;
        width: 63%;
        z-index: 2;
        transform: scale(0);
    }

    .scimitar {
        position: absolute;
        top: 48%;
        left: -40%;
        width: 83%;
        height: auto;
        z-index: 3;
        transform: scale(0);
    }

    .sleipnir {
        position: absolute;
        left: -25%;
        top: 34%;
        width: 72%;
        height: auto;
        z-index: 1;
        transform: scale(0);
    }

    @keyframes jaguar {
        0% {
            transform: scale(0);
            top: 20%;
            left: -15%;
        }

        30% {
            transform: scale(1);
            top: 33%;
            left: 31%;
        }

        100% {
            transform: scale(1.04);
            top: 33%;
            left: 31%;
        }
    }

    @keyframes scimitar {
        0% {
            transform: scale(0);
            top: 10%;
            left: -15%;
        }

        33% {
            transform: scale(1);
            top: 2%;
            left: 30%;
        }

        100% {
            transform: scale(1.03);
            top: 0%;
            left: 30%;
        }
    }

    @keyframes sleipnir {
        0% {
            transform: scale(0);
            left: -15%;
            top: 10%;
        }

        33% {
            transform: scale(1);
            top: 36%;
            left: 27%;
        }

        100% {
            transform: scale(1.03);
            top: 38%;
            left: 27%;
        }
    }
</style>

<style lang="scss" is:global>
    #rattini-slide .ceo {
        left: 0%;
    }

    .swiper-slide-active {
        .jaguar {
            animation: jaguar cubic-bezier(0.390, 0.575, 0.565, 1.000) both 2.7s;
            animation-delay: 1.3s;
            animation-iteration-count: 1;
            transform-origin: center;
            animation-fill-mode: forwards;
        }
        
        .scimitar {
            animation: scimitar cubic-bezier(0.390, 0.575, 0.565, 1.000) both 2.6s;
            animation-delay: 1.2s;
            animation-iteration-count: 1;
            transform-origin: center;
            animation-fill-mode: forwards;
        }
        
        .sleipnir {
            animation: sleipnir cubic-bezier(0.390, 0.575, 0.565, 1.000) both 2.5s;
            animation-delay: 1.4s;
            animation-iteration-count: 1;
            transform-origin: center;
            animation-fill-mode: forwards;
        }
    }
</style>