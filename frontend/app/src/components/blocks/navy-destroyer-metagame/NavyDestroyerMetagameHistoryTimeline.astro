---
import type { GuideHistoryEntry } from '@/data/navy-destroyer-metagame'

interface Props {
    entries: readonly GuideHistoryEntry[]
}

const { entries } = Astro.props
---

<ol class="ndm-history">
    {
        entries.map((entry, index) => (
            <li class="ndm-history__item">
                <div class="ndm-history__marker" aria-hidden="true" />
                <div class="ndm-history__body">
                    <p class="ndm-history__date">
                        <time>{entry.dateLabel}</time>
                        <span class="ndm-history__yc">{entry.yc}</span>
                    </p>
                    <h3 class="ndm-history__title">{entry.title}</h3>
                    <p class="ndm-history__description">{entry.description}</p>
                    {
                        entry.link && (
                            <p class="ndm-history__link-wrap">
                                <a
                                    href={entry.link.href}
                                    target="_blank"
                                    rel="nofollow noopener noreferrer"
                                    class="ndm-guide__link"
                                >
                                    {entry.link.label}
                                </a>
                            </p>
                        )
                    }
                </div>
                {index < entries.length - 1 && <div class="ndm-history__connector" aria-hidden="true" />}
            </li>
        ))
    }
</ol>

<style lang="scss">
    .ndm-history {
        display: flex;
        flex-direction: column;
        gap: 0;
        margin: 0;
        padding: 0;
        list-style: none;
    }

    .ndm-history__item {
        position: relative;
        display: grid;
        grid-template-columns: 1.25rem minmax(0, 1fr);
        gap: var(--space-s);
        padding-bottom: var(--space-l);
    }

    .ndm-history__item:last-child {
        padding-bottom: 0;
    }

    .ndm-history__marker {
        position: relative;
        z-index: 1;
        width: 0.75rem;
        height: 0.75rem;
        margin-top: 0.2rem;
        margin-left: 0.25rem;
        border-radius: 50%;
        background: color-mix(in srgb, var(--fleet-yellow) 35%, transparent);
        border: 1px solid color-mix(in srgb, var(--fleet-yellow) 55%, var(--border-color));
    }

    .ndm-history__item:last-child .ndm-history__marker {
        background: var(--fleet-red);
        border-color: var(--fleet-red);
        box-shadow: 0 0 10px color-mix(in srgb, var(--fleet-red) 45%, transparent);
    }

    .ndm-history__connector {
        position: absolute;
        top: 1rem;
        left: 0.6rem;
        bottom: 0;
        width: 1px;
        background: color-mix(in srgb, var(--border-color) 70%, transparent);
    }

    .ndm-history__body {
        min-width: 0;
    }

    .ndm-history__date {
        display: flex;
        flex-wrap: wrap;
        align-items: baseline;
        gap: var(--space-2xs);
        margin: 0 0 var(--space-3xs);
        font-size: var(--step--2);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-color-secondary, var(--faded));
    }

    .ndm-history__yc {
        color: var(--fleet-red);
    }

    .ndm-history__title {
        margin: 0 0 var(--space-3xs);
        font-family: var(--ndm-display-font, var(--heading-font));
        font-size: var(--step--1);
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--highlight);
    }

    .ndm-history__description {
        margin: 0;
        font-size: var(--step--1);
        line-height: 1.55;
        color: var(--text-color-secondary, var(--faded));
    }

    .ndm-history__link-wrap {
        margin: var(--space-2xs) 0 0;
        font-size: var(--step--1);
    }
</style>
