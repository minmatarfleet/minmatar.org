---
import {
    guideMeta,
    credits,
    additionalResources,
    introduction,
    considerations,
    considerationBullets,
    disclaimers,
    metagameSummary,
    glossary,
    guideSections,
    matchupLegend,
    matchupCharts,
    shipGuides,
} from '@/data/navy-destroyer-metagame'

import GuideContentsLayout from '@components/blocks/GuideContentsLayout.astro'
import NavyDestroyerMetagameMatchupChart from '@components/blocks/navy-destroyer-metagame/NavyDestroyerMetagameMatchupChart.astro'
import NavyDestroyerMetagameShipSection from '@components/blocks/navy-destroyer-metagame/NavyDestroyerMetagameShipSection.astro'
---

<div class="ndm-guide card component light-transparency border">
    <header class="ndm-guide__masthead">
        <p class="ndm-guide__series">{guideMeta.title}</p>
        <p class="ndm-guide__edition">{guideMeta.edition} · {guideMeta.yc}</p>
    </header>

    <GuideContentsLayout sections={guideSections}>
            <section id="introduction" data-section-id="introduction" class="ndm-section ndm-panel" aria-labelledby="ndm-intro-title">
                <h2 id="ndm-intro-title" class="ndm-section__title">Introduction</h2>
                {
                    introduction.map((paragraph) => (
                        <p class="ndm-section__paragraph" set:html={paragraph} />
                    ))
                }
            </section>

            <section id="considerations" data-section-id="considerations" class="ndm-section ndm-panel" aria-labelledby="ndm-considerations-title">
                <h2 id="ndm-considerations-title" class="ndm-section__title">Considerations of the Metagame</h2>
                {
                    considerations.map((paragraph) => (
                        <p class="ndm-section__paragraph">{paragraph}</p>
                    ))
                }
                <ul class="ndm-section__list">
                    {
                        considerationBullets.map((bullet) => (
                            <li>{bullet}</li>
                        ))
                    }
                </ul>
            </section>

            <section id="disclaimers" data-section-id="disclaimers" class="ndm-section ndm-panel" aria-labelledby="ndm-disclaimers-title">
                <h2 id="ndm-disclaimers-title" class="ndm-section__title">Disclaimers</h2>
                {
                    disclaimers.map((paragraph) => (
                        <p class="ndm-section__paragraph">{paragraph}</p>
                    ))
                }
            </section>

            <section id="summary" data-section-id="summary" class="ndm-section ndm-panel" aria-labelledby="ndm-summary-title">
                <h2 id="ndm-summary-title" class="ndm-section__title">Summary of the Metagame</h2>
                <div class="ndm-summary-grid">
                    {
                        metagameSummary.map((entry) => (
                            <article class="ndm-summary-card">
                                <h3 class="ndm-summary-card__ship">{entry.ship}</h3>
                                <p class="ndm-summary-card__text">{entry.text}</p>
                            </article>
                        ))
                    }
                </div>
            </section>

            <section id="matchups" data-section-id="matchups" class="ndm-section ndm-panel" aria-labelledby="ndm-matchups-title">
                <h2 id="ndm-matchups-title" class="ndm-section__title">Matchup Charts</h2>

                <div class="ndm-legend" aria-label="Matchup rating legend">
                    {
                        matchupLegend.map((item) => (
                            <div class="ndm-legend__item">
                                <span class:list={['ndm-legend__symbol', `ndm-legend__symbol--${item.rating === '?' ? 'unknown' : item.rating.replace(/\+/g, 'plus').replace(/-/g, 'minus').replace(/=/g, 'even')}`]}>
                                    {item.rating}
                                </span>
                                <span class="ndm-legend__label">
                                    <strong>{item.label}</strong>
                                    <span>{item.description}</span>
                                </span>
                            </div>
                        ))
                    }
                </div>

                <div class="ndm-charts-grid">
                    {
                        matchupCharts.map((chart) => (
                            <NavyDestroyerMetagameMatchupChart chart={chart} />
                        ))
                    }
                </div>
            </section>

            <div class="ndm-guide__ships">
                {
                    shipGuides.map((ship) => (
                        <NavyDestroyerMetagameShipSection ship={ship} />
                    ))
                }
            </div>

            <section id="glossary" data-section-id="glossary" class="ndm-section ndm-panel" aria-labelledby="ndm-glossary-title">
                <h2 id="ndm-glossary-title" class="ndm-section__title">Glossary</h2>
                <dl class="ndm-glossary">
                    {
                        glossary.map((entry) => (
                            <>
                                <dt class="ndm-glossary__term">{entry.term}</dt>
                                <dd class="ndm-glossary__definition">{entry.definition}</dd>
                            </>
                        ))
                    }
                </dl>
            </section>

            <section id="resources" data-section-id="resources" class="ndm-section ndm-panel" aria-labelledby="ndm-resources-title">
                <h2 id="ndm-resources-title" class="ndm-section__title">Additional Resources</h2>
                <p class="ndm-section__paragraph">
                    This web edition builds on Furl0w’s{' '}
                    <a
                        href={guideMeta.firstEditionUrl}
                        target="_blank"
                        rel="nofollow noopener noreferrer"
                        class="ndm-guide__link"
                    >
                        {credits.firstEditionLabel}
                    </a>
                    . The links below go deeper—original source, yearly meta references, and related guides on this site.
                </p>

                <div class="ndm-credits__quotes" aria-label="Reader testimonials from the First Edition">
                    {
                        credits.quotes.map((quote) => (
                            <blockquote class="ndm-credits__quote">
                                <p>"{quote.text}"</p>
                                <footer>- {quote.attribution}</footer>
                            </blockquote>
                        ))
                    }
                </div>

                <p class="ndm-credits__thanks">{credits.thanks}</p>

                <ul class="ndm-resources">
                    {
                        additionalResources.map((resource) => (
                            <li class="ndm-resources__item">
                                <a
                                    href={resource.href}
                                    target={resource.href.startsWith('http') ? '_blank' : undefined}
                                    rel={resource.href.startsWith('http') ? 'nofollow noopener noreferrer' : undefined}
                                    class="ndm-guide__link"
                                >
                                    {resource.title}
                                </a>
                                <span class="ndm-resources__note">{resource.note}</span>
                            </li>
                        ))
                    }
                </ul>
            </section>
    </GuideContentsLayout>
</div>

<style lang="scss">
    @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@500;600;700&family=Source+Sans+3:ital,wght@0,400;0,600;1,400&display=swap');

    .ndm-guide {
        --ndm-display-font: 'Orbitron', var(--heading-font);
        --ndm-body-font: 'Source Sans 3', var(--body-font);
        --ndm-panel-padding-block: var(--component-padding-block);
        --ndm-panel-padding-inline: var(--space-l-xl);
        width: 100%;
        max-width: 100%;
        min-width: 0;
        overflow-x: clip;
        padding: var(--space-2xl) var(--space-l-xl);
        font-family: var(--ndm-body-font);
    }

    @media (max-width: 48rem) {
        .ndm-guide {
            padding: var(--space-l) var(--space-s);
        }
    }

    .ndm-panel {
        padding: var(--ndm-panel-padding-block) var(--ndm-panel-padding-inline);
        background: color-mix(in srgb, var(--component-background) 72%, transparent);
        border: 1px solid color-mix(in srgb, var(--border-color) 70%, transparent);
        min-width: 0;
    }

    @media (max-width: 48rem) {
        .ndm-panel {
            --ndm-panel-padding-inline: var(--space-s);
        }
    }

    .ndm-guide__masthead {
        margin-bottom: var(--space-2xl);
        padding-bottom: var(--space-xl);
        text-align: center;
        border-bottom: 1px solid color-mix(in srgb, var(--border-color) 65%, transparent);
    }

    .ndm-guide__series {
        margin: 0;
        font-family: var(--ndm-display-font);
        font-size: clamp(var(--step-1), 3vw, var(--step-3));
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--highlight);
    }

    .ndm-guide__edition {
        margin: var(--space-s) 0 0;
        font-size: var(--step--1);
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--text-color-secondary, var(--faded));
    }

    .ndm-guide__ships {
        display: flex;
        flex-direction: column;
        gap: var(--space-l);
    }

    .ndm-section {
        scroll-margin-top: calc(var(--header-height, 4rem) + var(--space-l));
    }

    .ndm-section__title {
        margin: 0 0 var(--space-m);
        padding-bottom: var(--space-s);
        border-bottom: 1px solid color-mix(in srgb, var(--border-color) 55%, transparent);
        font-family: var(--ndm-display-font);
        font-size: clamp(var(--step-1), 2.5vw, var(--step-2));
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .ndm-section__subtitle {
        margin: var(--space-l) 0 var(--space-m);
        font-family: var(--ndm-display-font);
        font-size: var(--step-0);
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--highlight);
    }

    .ndm-section__paragraph {
        margin: 0 0 var(--space-m);
        font-size: var(--step-0);
        line-height: 1.7;
        max-width: var(--max-text-width);
    }

    .ndm-section__paragraph :global(a) {
        color: var(--highlight);
        text-decoration: underline;
        text-underline-offset: 0.15em;
    }

    .ndm-section__list {
        margin: 0;
        padding-left: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: var(--space-s);
        line-height: 1.65;
        max-width: var(--max-text-width);
    }

    .ndm-section__cover {
        margin: 0 0 var(--space-xl);
    }

    .ndm-section__cover-image,
    .ndm-section__figure-image {
        display: block;
        width: 100%;
        border: 1px solid color-mix(in srgb, var(--border-color) 70%, transparent);
    }

    .ndm-section__figure {
        margin: var(--space-xl) 0 0;
    }

    .ndm-section__figcaption {
        margin-top: var(--space-xs);
        font-size: var(--step--2);
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--text-color-secondary, var(--faded));
    }

    .ndm-credits__thanks {
        margin: 0 0 var(--space-l);
        max-width: var(--max-text-width);
        line-height: 1.65;
        font-size: var(--step--1);
        color: var(--text-color-secondary, var(--faded));
    }

    .ndm-credits__quotes {
        display: grid;
        gap: var(--space-m);
        margin: var(--space-l) 0;
        max-width: var(--max-text-width);
    }

    @media (min-width: 40rem) {
        .ndm-credits__quotes {
            grid-template-columns: 1fr 1fr;
        }
    }

    .ndm-credits__quote {
        margin: 0;
        padding: var(--component-padding-block) var(--space-m);
        background: color-mix(in srgb, var(--component-background) 78%, transparent);
        border: 1px solid color-mix(in srgb, var(--border-color) 60%, transparent);
        border-left: 3px solid var(--fleet-yellow);

        p {
            margin: 0 0 var(--space-2xs);
            font-style: italic;
        }

        footer {
            font-size: var(--step--1);
            color: var(--text-color-secondary, var(--faded));
        }
    }

    .ndm-resources {
        margin: 0;
        padding: 0;
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: var(--space-m);
        max-width: var(--max-text-width);
    }

    .ndm-resources__item {
        display: flex;
        flex-direction: column;
        gap: var(--space-3xs);
    }

    .ndm-resources__note {
        font-size: var(--step--1);
        line-height: 1.55;
        color: var(--text-color-secondary, var(--faded));
    }

    .ndm-guide__link {
        color: var(--highlight);
        text-decoration: underline;
        text-decoration-color: color-mix(in srgb, var(--fleet-yellow) 45%, transparent);
        text-underline-offset: 0.15em;

        &:hover,
        &:focus-visible {
            color: var(--fleet-yellow);
            text-decoration-color: currentColor;
        }
    }

    .ndm-summary-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(min(100%, 16rem), 1fr));
        gap: var(--space-m);
        margin-top: var(--space-m);
    }

    .ndm-summary-card {
        padding: var(--component-padding-block) var(--space-m);
        background: color-mix(in srgb, var(--component-background) 82%, transparent);
        border: 1px solid color-mix(in srgb, var(--border-color) 70%, transparent);
    }

    .ndm-summary-card__ship {
        margin: 0 0 var(--space-s);
        font-family: var(--ndm-display-font);
        font-size: var(--step--1);
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--fleet-red);
    }

    .ndm-summary-card__text {
        margin: 0;
        font-size: var(--step--1);
        line-height: 1.6;
    }

    .ndm-legend {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-xs);
        margin-bottom: var(--space-l);
        padding: var(--space-s);
        background: color-mix(in srgb, var(--component-background) 55%, transparent);
        border: 1px solid color-mix(in srgb, var(--border-color) 55%, transparent);
    }

    .ndm-legend__item {
        display: flex;
        align-items: center;
        gap: var(--space-xs);
        padding: var(--space-xs) var(--space-s);
        background: color-mix(in srgb, var(--component-background) 78%, transparent);
        border: 1px solid color-mix(in srgb, var(--border-color) 60%, transparent);
    }

    .ndm-legend__symbol {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 1.75rem;
        min-height: 1.75rem;
        border-radius: 999px;
        font-family: var(--ndm-display-font);
        font-size: var(--step--1);
        font-weight: 700;
    }

    .ndm-legend__symbol--plusplus { background: color-mix(in srgb, #2ecc71 22%, transparent); color: #7dffb0; }
    .ndm-legend__symbol--plus { background: color-mix(in srgb, #58d68d 18%, transparent); color: #9ef0b8; }
    .ndm-legend__symbol--even { background: color-mix(in srgb, #5dade2 18%, transparent); color: #a8d8ff; }
    .ndm-legend__symbol--minus { background: color-mix(in srgb, #e74c3c 16%, transparent); color: #ff9f96; }
    .ndm-legend__symbol--minusminus { background: color-mix(in srgb, #c0392b 20%, transparent); color: #ff8a80; }
    .ndm-legend__symbol--unknown { background: color-mix(in srgb, var(--faded) 18%, transparent); color: var(--text-color-secondary, var(--faded)); }

    .ndm-legend__label {
        display: flex;
        flex-direction: column;
        gap: 0.1rem;
        font-size: var(--step--1);

        strong {
            font-size: var(--step--1);
        }

        span {
            font-size: var(--step--2);
            color: var(--text-color-secondary, var(--faded));
        }
    }

    @media (min-width: 48rem) {
        .ndm-legend__label {
            flex-direction: row;
            align-items: baseline;
            gap: var(--space-2xs);
        }

        .ndm-legend__label span {
            font-size: var(--step--1);
        }
    }

    .ndm-charts-grid {
        display: flex;
        flex-direction: column;
        gap: var(--space-2xl);
    }

    .ndm-glossary {
        display: grid;
        grid-template-columns: minmax(6rem, 10rem) 1fr;
        gap: var(--space-s) var(--space-l);
        margin: 0 0 var(--space-xl);
    }

    .ndm-glossary__term {
        margin: 0;
        font-weight: 700;
        color: var(--fleet-yellow);
    }

    .ndm-glossary__definition {
        margin: 0;
        line-height: 1.6;
    }

    @media (max-width: 40rem) {
        .ndm-glossary {
            grid-template-columns: 1fr;
        }
    }
</style>
