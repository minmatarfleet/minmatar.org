---
interface Props {
    padding_inline?:    string;
    expanded?:          boolean;
    id?:                string;
    pre_chevron?:       boolean;
}

const {
    padding_inline = 'var(--space-3xs)',
    expanded = false,
    id,
    pre_chevron = false,
} = Astro.props

import Wrapper from '@components/compositions/Wrapper.astro';
import Flexblock from '@components/compositions/Flexblock.astro';
import FlexInline from '@components/compositions/FlexInline.astro';
import CollapsableButton from '@components/blocks/CollapsableButton.astro';
---

<Flexblock
    id={id ? id : undefined}
    gap='var(--space-3xs)'
    x-data={`{
        expanded: ${JSON.stringify(expanded)},
        toggle_collapse() {
            this.expanded = !this.expanded
        }
    }`}
>
    <CollapsableButton x-on:click="toggle_collapse()" pre_chevron={pre_chevron}>
        <slot name="head" />
    </CollapsableButton>

    <Wrapper
        padding_block='0'
        padding_inline={padding_inline}
        max_width='100%'
    >
        <div
            x-show="expanded"
            x-collapse.duration.0ms
            style="display: none"
        >
            <slot />
        </div>
    </Wrapper>
</Flexblock>