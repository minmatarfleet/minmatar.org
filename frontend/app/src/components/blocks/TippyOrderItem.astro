---
import { i18n } from '@helpers/i18n'
const { translatePath } = i18n(Astro.url)

interface Props {
    item_name:          string;
    quantity?:          number;
    contract_value?:    number;
    earnings?:          number;
    init_tooltip?:      boolean;
    placement?:         string;
    htmltag?:           string;
    width?:             string;
    height?:            string;
    [propName: string]: any;
}

const {
    item_name,
    quantity,
    contract_value,
    earnings,
    init_tooltip = false,
    htmltag = 'div',
    placement = 'top',
    width = '340px',
    height = '70px',
} = Astro.props;

import { query_string } from '@helpers/string';

const query = query_string({
    item_name: item_name,
    ...(quantity && { quantity }),
    ...(contract_value && { contract_value }),
    ...(earnings && { earnings }),
})

import Tippy from '@components/blocks/Tippy.astro';
---

<Tippy
    data-tippy-placement={placement}
    partial={`${translatePath('/partials/order_item_tooltip')}?${query}`}
    height={width}
    width={height}
    element={htmltag}
    init_tooltip={init_tooltip}
>
    <slot />
</Tippy>