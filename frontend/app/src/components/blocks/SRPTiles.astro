---
import { i18n } from '@helpers/i18n'
const { t } = i18n(Astro.url)

import type { SRPProgram } from '@dtypes/api.minmatar.org'
import { get_frontend_program } from '@helpers/fetching/srp'
import type { SRPTargetValue } from '@dtypes/layout_components'

interface Props {
    programs:           SRPProgram[];
    readonly:           boolean;
    init_tooltips:      boolean;
}

const {
    programs,
    readonly,
    init_tooltips,
} = Astro.props

const subcapitals_values:SRPTargetValue[] = []
const dreads_values:SRPTargetValue[] = []
const carriers_values:SRPTargetValue[] = []

programs.forEach(program => {
    const frontend_program = get_frontend_program(program.eve_group.name)

    const value:SRPTargetValue = {
        name: program.eve_type.name,
        type_id: program.eve_type.id,
        value: program.current_amount.srp_value,
    }

    if (frontend_program === 'carriers')
        carriers_values.push(value)
    else if (frontend_program === 'dreads')
        dreads_values.push(value)
    else
        subcapitals_values.push(value)
})

import Grid from '@components/compositions/Grid.astro';

import SRPTile from '@components/blocks/SRPTile.astro';
---

<Grid
    id="srp-tiles"
    class="[ w-full grid-fill ]"
    row_gap="var(--space-3xs)"
    column_gap="var(--space-3xs)"
    min_item_width="570px"
>
    <SRPTile
        id='subcapitals_program'
        program='subcapitals'
        description={t('subcapitals_program_description')}
        cover='/images/sbcapital-srp-cover.webp'
        values={subcapitals_values}
        readonly={readonly}
    >
        <small slot="values-footer">{t('subcapitals_program_hint')}</small>
    </SRPTile>

    <SRPTile
        id='dreads_program'
        program='dreads'
        description={t('dreads_program_description')}
        cover='/images/dreads-srp-cover.webp'
        values={dreads_values}
        readonly={readonly}
    />

    <SRPTile
        id='carriers_program'
        program='carriers'
        description={t('carriers_program_description')}
        cover='/images/carriers-srp-cover.webp'
        values={carriers_values}
        readonly={readonly}
    />
</Grid>