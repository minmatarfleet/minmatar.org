---
import { i18n } from '@helpers/i18n'
const { t, translatePath } = i18n(Astro.url)

import type { CorporationObject } from '@dtypes/layout_components'
import {
    isL3arnCorporation,
    l3arnApplicationAlpineState,
} from '@helpers/corporations/l3arn_application'
import {
    corporationApplicationAlpineState,
} from '@helpers/corporations/corporation_application'

interface Props {
    corporation:            CorporationObject;
    hidden?:                boolean;
}

const {
    corporation,
    hidden = false,
} = Astro.props

const is_l3arn = isL3arnCorporation(corporation)

const CORPORATION_REQUEST_STATUS_PARTIAL_URL = `${translatePath('/partials/corporation_slide_request_status_item/')}?corporation_id=${corporation.corporation_id}`

import Flexblock from '@components/compositions/Flexblock.astro';
import FlexInline from '@components/compositions/FlexInline.astro';

import DialogButton from "@components/blocks/DialogButton.astro";
import Button from '@components/blocks/Button.astro';
import CorporationItem from '@components/blocks/CorporationItem.astro';
import CorporationApplicationFormL3arn from '@components/blocks/CorporationApplicationFormL3arn.astro';
import CorporationApplicationForm from '@components/blocks/CorporationApplicationForm.astro';
---

<DialogButton
    color='green'
    hidden={hidden}
    inside_swiper={true}
>
    {t('enlist_today')}

    <form
        slot="dialog" 
        hx-post={CORPORATION_REQUEST_STATUS_PARTIAL_URL}
        hx-trigger="submit"
        hx-target={`#corporation-status-${corporation.corporation_id}`}
        hx-indicator=".loader"
        hx-swap="outerHTML transition:true"
        x-data={is_l3arn
            ? l3arnApplicationAlpineState(false)
            : corporationApplicationAlpineState(false)}
        x-on:submit={is_l3arn
            ? "if (error) { $event.preventDefault(); return }; close_dialog(); $nextTick(() => clearL3arnForm())"
            : "if (error) { $event.preventDefault(); return }; close_dialog(); $nextTick(() => clearCorpApplicationForm())"}
        x-init={is_l3arn ? "initL3arnForm()" : "initCorpApplicationForm()"}
    >
        <Flexblock gap="var(--space-l)">
            <Flexblock gap="var(--space-s)">
                <h3>{t('corporation_join_request_dialog_title')}</h3>

                <CorporationItem corporation={corporation} disable_applications={true} />

                {is_l3arn ? (
                    <CorporationApplicationFormL3arn include_field_names={true} />
                ) : (
                    <CorporationApplicationForm
                        corporation={corporation}
                        include_field_names={true}
                    />
                )}
            </Flexblock>

            <FlexInline justification='flex-end'>
                <Button
                    size='sm'
                    type="submit"
                    color='green'
                    x-bind:disabled="error"
                >
                    {t('apply')}
                </Button>
                <Button
                    type="button"
                    size='sm'
                    x-on:click="close_dialog()"
                >
                    {t('close')}
                </Button>
            </FlexInline>
        </Flexblock>
    </form>
</DialogButton>
