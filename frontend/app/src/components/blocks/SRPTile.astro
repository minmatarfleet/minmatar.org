---
import { i18n } from '@helpers/i18n'
const { lang, t } = i18n(Astro.url)

import type { User } from '@dtypes/jwt'
import * as jose from 'jose'

const auth_token = Astro.cookies.has('auth_token') ? Astro.cookies.get('auth_token')?.value : false
const user = auth_token ? jose.decodeJwt(auth_token) as User : false

import type { SRPTargetValue, SRPFrontendPrograms, SRPGroupHistory } from '@dtypes/layout_components'

interface Props {
    id:                 string;
    program:            SRPFrontendPrograms;
    description:        string;
    cover:              string;
    values?:            SRPTargetValue[];
    stats_history?:     SRPGroupHistory;
    readonly?:          boolean;
    init_tooltips:      boolean;
}

const {
    id,
    program,
    description,
    cover,
    values,
    stats_history,
    readonly = false,
    init_tooltips,
} = Astro.props

const values_sorted = values ? values.sort((a, b) => a.value - b.value) : undefined

const SLIDES_PER_VIEW = 4

import { number_thousand_separator, number_name } from '@helpers/numbers'

import FlexInline from '@components/compositions/FlexInline.astro';
import Flexblock from '@components/compositions/Flexblock.astro';
import Wrapper from '@components/compositions/Wrapper.astro';

import Tile from '@components/blocks/Tile.astro';
import ItemBadge from '@components/blocks/ItemBadge.astro';
import BadgeSwiper from '@components/blocks/BadgeSwiper.astro';
import ButtonAddKillmail from '@components/blocks/ButtonAddKillmail.astro';
import ButtonAuth from '@components/blocks/ButtonAuth.astro';
---
<Flexblock
    id={id}
    class="[ card component border light-transparency ]"
    gap='0'
>
    <Tile
        title={t(`${program}_program`)}
        description={description}
        cover={cover}
        transparent={true}
    >
        {stats_history &&
            <Flexblock slot="subtitle">
                <FlexInline justification='space-between'>
                    <Flexblock gap='var(--space-3xs)'>
                        <small class="[ text-highlight ]">{t('total_requested')}</small>
                        <p>
                            <span
                                data-tippy-content={number_name(stats_history.total, lang)}
                                x-init={init_tooltips ? 'tippy($el, tippy_options)' : undefined}
                            >
                                {number_thousand_separator(stats_history.total)}
                            </span>
                            ISK
                        </p>
                    </Flexblock>
                    <Flexblock gap='var(--space-3xs)'>
                        <small class="[ text-highlight ]">{t('approved')}</small>
                        <p class="[ text-green ]">
                            <span
                                data-tippy-content={number_name(stats_history.approved, lang)}
                                x-init={init_tooltips ? 'tippy($el, tippy_options)' : undefined}
                            >
                                {number_thousand_separator(stats_history?.approved)}
                            </span>
                            ISK
                        </p>
                    </Flexblock>
                    <Flexblock gap='var(--space-3xs)'>
                        <small class="[ text-highlight ]">{t('rejected')}</small>
                        <p class="[ text-red ]">
                            <span
                                data-tippy-content={number_name(stats_history.rejected, lang)}
                                x-init={init_tooltips ? 'tippy($el, tippy_options)' : undefined}
                            >
                                {number_thousand_separator(stats_history?.rejected)}
                            </span>
                            ISK
                        </p>
                    </Flexblock>
                </FlexInline>
                <small>{t('based_on_the_last_90_days')}</small>
            </Flexblock>
        }
    </Tile>

    <Wrapper
        class="[ pb-(--component-padding-block)! grow ]"
        padding_inline='var(--component-padding-block)'
        padding_block='0'
        max_width='100%'
    >
        <Flexblock
            class="[ justify-between! h-full ]"
            gap='var(--space-l)'
        >
            <Wrapper
                padding_block='0'
                padding_inline='0'
                max_width='570px'
            >
                <Flexblock gap='var(--space-l)'>
                    {values_sorted &&
                        <div
                            id={`${id}-swiper`}
                            class="[ swiper ][ w-full ]"
                            style={`--swiper-height: ${Math.min(SLIDES_PER_VIEW, values_sorted.length) * 64 + (Math.min(SLIDES_PER_VIEW, values_sorted.length) - 1) * 20}px`}
                        >
                            <BadgeSwiper
                                swiper_selector={`#${id}-swiper`}
                                slides_per_view={SLIDES_PER_VIEW}
                                mousewheel={values_sorted.length > SLIDES_PER_VIEW}
                            >
                                {values_sorted.map(value =>
                                    <div class="swiper-slide"  style="margin-bottom: 20px">
                                        <FlexInline gap='var(--space-3xs)' class="[ items-center! ]" justification='space-between'>
                                            <ItemBadge
                                                item_name={value.name}
                                                type_id={value.type_id}
                                            />
                                            <h3>{number_thousand_separator(value.value)} ISK</h3>
                                        </FlexInline> 
                                    </div>
                                )}
                            </BadgeSwiper>
                        </div>
                        <slot name="values-footer" />
                    }
                    <slot />
                </Flexblock>
            </Wrapper>

            {!readonly &&
                <FlexInline>
                    <div class="[ submit-tooltip ]">
                        <ButtonAddKillmail
                            program={program}
                            description={description}
                            cover={cover}
                        />
                    </div>
                </FlexInline>
            }
            {!user &&
                <FlexInline>
                    <div class="[ submit-tooltip ]">
                        <ButtonAuth
                            color='green'
                            dialog_title={t('add_killmail')}
                        >
                            {t('add_killmail')}
                        </ButtonAuth>
                    </div>
                </FlexInline>
            }
        </Flexblock>
    </Wrapper>
</Flexblock>

<style lang="scss">
    .swiper {
        height: var(--swiper-height);
    }

    .swiper-slide {
        min-height: 64px;
    }
</style>