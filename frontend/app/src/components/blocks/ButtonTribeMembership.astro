---
import { i18n } from '@helpers/i18n'
const { t, translatePath } = i18n(Astro.url)

import type { SummaryCharacter, TribeAvailableCharacter, TribeMembership  } from '@dtypes/api.minmatar.org'

interface Props {
    target_id:              string;
    title:                  string;
    tribe_id:               number;
    group_id:               number;
    membership_id:          number;
    pilots:                 SummaryCharacter[];
    membership:             TribeMembership;
    available_characters?:  TribeAvailableCharacter[];
    hidden?:                boolean;
    id?:                    string;
}

const {
    target_id,
    title,
    tribe_id,
    group_id,
    membership_id,
    pilots,
    membership,
    available_characters,
    hidden = false,
    id,
} = Astro.props

import { query_string } from '@helpers/string';

const TRIBE_GROUP_STATUS_PARTIAL_URL = translatePath(`/partials/tribe_group_status_component?tribe_id=${tribe_id}&group_id=${group_id}`)

// Avoid adding a frontmatter line with a string literal (e.g. ?? "" or ?? ''). It triggers
// esbuild "Unterminated string literal" when compiling this .astro file. Use template for defaults (e.g. data-api-url={import.meta.env.API_URL}).
import Flexblock from '@components/compositions/Flexblock.astro';
import FlexInline from '@components/compositions/FlexInline.astro';
import Wrapper from '@components/compositions/Wrapper.astro';

import DialogButton from "@components/blocks/DialogButton.astro";
import Button from '@components/blocks/Button.astro';
import CharacterCard from '@components/blocks/CharacterCard.astro';
import LandingSwiper from '@components/blocks/LandingSwiper.astro';
import CorporationBadge from '@components/blocks/CorporationBadge.astro';
import ButtonConfirm from '@components/blocks/ButtonConfirm.astro';
import Tag from '@components/blocks/Tag.astro';
---

<DialogButton
    id={id ? id : undefined}
    color='fleet-red'
    narrow={false}
    hidden={hidden}
    max_width='820px'
    disable_when_open={true}
>
    {t('membership')}

    <Flexblock slot="dialog" gap="var(--space-l)">
        <Flexblock gap="var(--space-s)">
            <Flexblock gap="var(--space-3xs)">
                <h3>{title}</h3>
                <small>{t('manage_membership')}</small>
            </Flexblock>
            
            <Wrapper
                padding_block='0'
                padding_inline='var(--space-xl)'
            >
                <div id={`${target_id}-swiper`} class="[ swiper ][ w-full pb-10! ]">
                    <LandingSwiper swiper_selector={`#${target_id}-swiper`}>
                        {pilots.map((pilot) => {
                            const is_member = membership.characters.find(character => character.character_id === pilot.character_id)

                            const available = available_characters?.find(
                                (a) => a.character_id === pilot.character_id
                            )
                            
                            const cid = pilot.character_id
                            const hasBar = available != null
                            const barLabel = hasBar
                                ? (available.qualifies
                                    ? t('tribes.detail.qualified')
                                    : available.missing_skills && available.missing_assets
                                        ? t('tribes.detail.missing_skills_and_assets')
                                        : available.missing_skills
                                            ? t('tribes.detail.missing_skills')
                                            : available.missing_assets
                                                ? t('tribes.detail.missing_assets')
                                                : t('tribes.detail.unqualified'))
                                : '';
                            return (
                                <div class="[ swiper-slide ]" style="margin-right: 5px">
                                    <div class="[ tribe-apply-character-card ]">
                                        <div class="[ tribe-apply-card-header ]">
                                            <CharacterCard
                                                character_id={pilot.character_id}
                                                character_name={pilot.character_name}
                                                x-model="characters"
                                                x-on:change="update_character_ids()"
                                                value={pilot.character_id}
                                                inert={true}
                                            >
                                                <div slot="actions">
                                                    {!is_member ?
                                                        <Button
                                                            color='green'
                                                            size='sm'
                                                            hx-post={`${TRIBE_GROUP_STATUS_PARTIAL_URL}&${query_string({
                                                                membership_id: membership_id,
                                                                character_id: pilot.character_id,
                                                            })}`}
                                                            hx-target={`#${target_id}`}
                                                            hx-indicator=".loader"
                                                            hx-swap="outerHTML transition:true"
                                                            x-on:click="close_dialog(false)"
                                                        >
                                                            {t('add')}
                                                        </Button> :
                                                        <ButtonConfirm
                                                            size='sm'
                                                            label={t('remove')}
                                                        >
                                                            <Button
                                                                size='sm'
                                                                hx-delete={`${TRIBE_GROUP_STATUS_PARTIAL_URL}&${query_string({
                                                                    membership_id: membership_id,
                                                                    character_id: pilot.character_id,
                                                                })}`}
                                                                hx-target={`#${target_id}`}
                                                                hx-indicator=".loader"
                                                                hx-swap="outerHTML transition:true"
                                                                x-on:click="close_dialog(false)"
                                                            >
                                                                {t('confirm')}
                                                            </Button>
                                                        </ButtonConfirm>
                                                    }
                                                </div>
                                                <Flexblock gap='var(--space-3xs)'>
                                                    {hasBar &&
                                                        <Tag
                                                            class="no-desaturate"
                                                            color={available.qualifies ? 'green' : 'fleet-red'}
                                                            text={barLabel}
                                                        />
                                                    }
                                                    <h3>{pilot.character_name}</h3>
                                                    <CorporationBadge
                                                        corporation={{
                                                            id: pilot.corp_id,
                                                            name: pilot.corp_name,
                                                            size: 'xs',
                                                        }}
                                                        highlight={false}
                                                    />
                                                </Flexblock>
                                            </CharacterCard>
                                        </div>
                                    </div>
                                </div>
                            )
                        })}
                    </LandingSwiper>
                </div>

                <div id={`${target_id}-swiper-button-prev`} class="[ swiper-button-prev hidden lg:block! ]"></div>
                <div id={`${target_id}-swiper-button-next`} class="[ swiper-button-next hidden lg:block! ]"></div>
            </Wrapper>
        </Flexblock>

        <FlexInline justification='space-between'>
            <ButtonConfirm
                size='sm'
                label={t('tribes.detail.leave')}
            >
                <Button
                    size='sm'
                    hx-delete={`${TRIBE_GROUP_STATUS_PARTIAL_URL}?${query_string({
                        tribe_id: tribe_id,
                        group_id: group_id,
                        membership_id: membership_id,
                    })}`}
                    hx-target={`#${target_id}`}
                    hx-indicator=".loader"
                    hx-swap="outerHTML transition:true"
                    x-on:click="$el.setAttribute('disabled','')"
                >
                    {t('confirm')}
                </Button>
            </ButtonConfirm>

            <Button
                type="button"
                size='sm'
                x-on:click="close_dialog()"
            >
                {t('close')}
            </Button>
        </FlexInline>
    </Flexblock>
</DialogButton>

<style lang="scss">
    h3 {
        font-size: var(--step-1);
    }

    .alliance-reel {
        position: relative;
    }

    .swiper-button-prev,
    .swiper-button-next {
        --swiper-navigation-color: var(--highlight);
        --swiper-navigation-sides-offset: var(--space-l);

        opacity: 0;
    }

    .swiper-initialized ~ .swiper-button-prev,
    .swiper-initialized ~ .swiper-button-next {
        opacity: 1;
    }

    .swiper-initialized ~ .swiper-button-next.swiper-button-disabled,
    .swiper-initialized ~ .swiper-button-prev.swiper-button-disabled {
        opacity: 0;
    }

    .swiper-button-next.swiper-button-disabled,
    .swiper-button-prev.swiper-button-disabled {
        --swiper-navigation-color: var(--fleet-yellow);
        opacity: 1;
    }

    .swiper-button-prev {
        transform: translateY(-1.25rem);
    }

    .swiper-button-next {
        transform: translateY(-1.25rem);
    }

    .swiper-slide {
        width: min(100%, 240px);
    }
</style>
