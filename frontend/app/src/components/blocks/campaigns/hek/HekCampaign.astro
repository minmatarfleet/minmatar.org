---
import {
    CAMPAIGN_BEATS,
    ENEMY_STRUCTURE_VALUE_ESTIMATE,
    formatIsk,
    HEADLINES,
    HMA_REPARATIONS_ISK,
    ISK_DESTROYED,
    ISK_LOST,
    KILLMAIL_COUNT,
    LOSSMAIL_COUNT,
    METRICS_END,
    METRICS_START,
    REMAINING_TARGETS,
    STRUCTURES_CLEARED_FROM_TIMERS,
} from '@/data/campaigns/hek'

import CampaignDataTable from '@components/blocks/campaigns/etherium-reach/CampaignDataTable.astro'
import CampaignStat from '@components/blocks/campaigns/etherium-reach/CampaignStat.astro'

const HEADLINE_CATEGORY_LABELS = {
    aar: 'AAR',
    update: 'Update',
} as const

const settlementRows = [
    {
        cells: ['HMA reparations accepted', formatIsk(HMA_REPARATIONS_ISK)] as const,
        tone: 'success' as const,
    },
    {
        cells: ['Structures cleared from timers', String(STRUCTURES_CLEARED_FROM_TIMERS)] as const,
    },
    {
        cells: ['Enemy structure value (est.)', `~${formatIsk(ENEMY_STRUCTURE_VALUE_ESTIMATE)}`] as const,
    },
]

const remainingTargetRows = REMAINING_TARGETS.map((target) => ({
    cells: [target, 'Still targeted'] as const,
    tone: 'warning' as const,
}))

function formatBeatDate(isoDate: string): string {
    return new Date(`${isoDate}T00:00:00Z`).toLocaleDateString('en-GB', {
        day: 'numeric',
        month: 'short',
        year: 'numeric',
        timeZone: 'UTC',
    })
}

function formatHeadlineDate(isoDate: string): string {
    return formatBeatDate(isoDate)
}
---

<div class="hek-campaign">
    <section class="hek-campaign__section">
        <h3>Campaign by the numbers</h3>
        <p class="hek-campaign__meta">
            Combat in Metropolis · {METRICS_START} – {METRICS_END} · zKillboard
        </p>
        <div class="hek-campaign__stat-grid hek-campaign__stat-grid--3">
            <CampaignStat
                label="ISK destroyed"
                value={formatIsk(ISK_DESTROYED)}
                tone="success"
            />
            <CampaignStat
                label="ISK lost"
                value={formatIsk(ISK_LOST)}
                tone="danger"
            />
            <CampaignStat
                label="HMA reparations"
                value={formatIsk(HMA_REPARATIONS_ISK)}
                tone="info"
            />
        </div>
        <p class="hek-campaign__footnote">
            {KILLMAIL_COUNT.toLocaleString()} kills and {LOSSMAIL_COUNT.toLocaleString()} losses
            in Metropolis during the metrics window.
        </p>
    </section>

    <section class="hek-campaign__section">
        <h3>Reparations and settlement</h3>
        <p class="hek-campaign__meta">
            After a week of structure pressure, [SLUSH] offered 20 billion ISK in surrender terms.
            Kleenur spearheaded the ISK path; the alliance accepted reparations and stood down
            timers on roughly a dozen medium structures.
        </p>
        <CampaignDataTable
            headers={['Outcome', 'Detail']}
            rows={settlementRows}
        />
        <div class="hek-campaign__subsection">
            <h4>Structures still on the list</h4>
            <p class="hek-campaign__meta">
                Targets named in the 17 Nov announcement after partial settlement
            </p>
            <CampaignDataTable
                headers={['Structure', 'Status']}
                rows={remainingTargetRows}
                striped={true}
            />
        </div>
    </section>

    <section class="hek-campaign__section">
        <h3>Campaign timeline</h3>
        <p class="hek-campaign__meta">
            Key beats from Discord archives and public posts
        </p>
        <ol class="hek-campaign__timeline">
            {
                CAMPAIGN_BEATS.map((beat) => (
                    <li class="hek-campaign__timeline-item">
                        <time class="hek-campaign__timeline-date" datetime={beat.date}>
                            {formatBeatDate(beat.date)}
                        </time>
                        <div class="hek-campaign__timeline-body">
                            <p class="hek-campaign__timeline-label">{beat.label}</p>
                            <p class="hek-campaign__timeline-source">{beat.source}</p>
                        </div>
                    </li>
                ))
            }
        </ol>
    </section>

    <section class="hek-campaign__section">
        <h3>Headlines</h3>
        <p class="hek-campaign__meta">
            Public posts from the Hek theater
        </p>
        <div class="hek-headline-cards">
            {
                HEADLINES.map((headline) => (
                    <a
                        class:list={[
                            'hek-headline-card',
                            `hek-headline-card--${headline.category}`,
                        ]}
                        style={`--hek-headline-bg: url('${headline.backgroundImage}')`}
                        href={headline.url}
                        target="_blank"
                        rel="noopener noreferrer nofollow"
                    >
                        <div class="hek-headline-card__body">
                            <div class="hek-headline-card__meta">
                                <time datetime={headline.date}>
                                    {formatHeadlineDate(headline.date)}
                                </time>
                                <span class="hek-headline-card__tag">
                                    {HEADLINE_CATEGORY_LABELS[headline.category]}
                                </span>
                            </div>
                            <h4 class="hek-headline-card__title">{headline.title}</h4>
                        </div>
                        <span class="hek-headline-card__arrow" aria-hidden="true">→</span>
                    </a>
                ))
            }
        </div>
    </section>

    <footer class="hek-campaign__footer">
        <span>Hek Campaign Report</span>
        <span>November 2023</span>
    </footer>
</div>

<style lang="scss">
    .hek-campaign {
        display: flex;
        flex-direction: column;
        gap: var(--space-2xl);
        width: 100%;
        min-width: 0;
    }

    .hek-campaign__section {
        display: flex;
        flex-direction: column;
        gap: var(--space-m);
        min-width: 0;

        h3,
        h4 {
            margin: 0;
            color: var(--highlight);
            line-height: 1.2;
        }

        h3 {
            font-size: var(--step-1);
        }

        h4 {
            font-size: var(--step-0);
        }

        h3 + .hek-campaign__meta,
        h4 + .hek-campaign__meta {
            margin-top: calc(var(--space-2xs) - var(--space-m));
        }
    }

    .hek-campaign__subsection {
        display: flex;
        flex-direction: column;
        gap: var(--space-m);
        min-width: 0;
        padding-top: var(--space-l);
        border-top: 1px solid color-mix(in srgb, var(--border-color) 45%, transparent);
    }

    .hek-campaign__meta,
    .hek-campaign__footnote {
        margin: 0;
        font-size: var(--step--1);
        color: var(--faded);
        line-height: 1.5;
    }

    .hek-campaign__stat-grid {
        display: grid;
        gap: var(--space-m);
        min-width: 0;
    }

    .hek-campaign__stat-grid--3 {
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .hek-campaign__timeline {
        display: flex;
        flex-direction: column;
        gap: 0;
        margin: 0;
        padding: 0;
        list-style: none;
        border: 1px solid color-mix(in srgb, var(--border-color) 80%, transparent);
    }

    .hek-campaign__timeline-item {
        display: grid;
        grid-template-columns: 7.5rem minmax(0, 1fr);
        gap: var(--space-m);
        padding: var(--space-m) var(--space-l);
        border-bottom: 1px solid color-mix(in srgb, var(--border-color) 60%, transparent);

        &:last-child {
            border-bottom: none;
        }
    }

    .hek-campaign__timeline-date {
        font-size: var(--step--1);
        font-weight: 600;
        color: var(--fleet-yellow);
        white-space: nowrap;
    }

    .hek-campaign__timeline-body {
        display: flex;
        flex-direction: column;
        gap: var(--space-3xs);
        min-width: 0;
    }

    .hek-campaign__timeline-label {
        margin: 0;
        font-size: var(--step-0);
        color: var(--highlight);
        line-height: 1.35;
    }

    .hek-campaign__timeline-source {
        margin: 0;
        font-size: var(--step--1);
        color: var(--faded);
        line-height: 1.4;
    }

    .hek-headline-cards {
        display: flex;
        flex-direction: column;
        gap: var(--space-m);
        min-width: 0;
    }

    .hek-headline-card {
        position: relative;
        isolation: isolate;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-m);
        padding: var(--space-m) var(--space-l);
        min-width: 0;
        overflow: hidden;
        text-decoration: none;
        color: inherit;
        border: 1px solid color-mix(in srgb, var(--border-color) 80%, transparent);
        border-left-width: 3px;
        transition:
            border-color 0.15s ease,
            transform 0.15s ease;

        &::before {
            content: '';
            position: absolute;
            inset: 0;
            z-index: 0;
            background-image: var(--hek-headline-bg);
            background-size: cover;
            background-position: center;
            transition: transform 0.15s ease;
        }

        &::after {
            content: '';
            position: absolute;
            inset: 0;
            z-index: 0;
            transition: opacity 0.15s ease;
        }

        > * {
            position: relative;
            z-index: 1;
        }

        &:hover,
        &:focus-visible {
            transform: translateX(2px);
            border-color: color-mix(in srgb, var(--border-color-hover) 80%, transparent);
        }

        &:hover::before,
        &:focus-visible::before {
            transform: scale(1.03);
        }

        &:focus-visible {
            outline: 2px solid var(--fleet-yellow);
            outline-offset: 2px;
        }
    }

    .hek-headline-card--aar {
        border-left-color: var(--fleet-yellow);

        &::after {
            background:
                linear-gradient(
                    90deg,
                    color-mix(in srgb, hsl(0 0% 4%) 94%, var(--fleet-red) 6%) 0%,
                    color-mix(in srgb, hsl(0 0% 4%) 82%, var(--fleet-red) 5%) 42%,
                    color-mix(in srgb, hsl(0 0% 4%) 58%, transparent) 100%
                );
        }
    }

    .hek-headline-card--update {
        border-left-color: var(--alliance-blue);

        &::after {
            background:
                linear-gradient(
                    90deg,
                    color-mix(in srgb, hsl(0 0% 4%) 94%, var(--alliance-blue) 6%) 0%,
                    color-mix(in srgb, hsl(0 0% 4%) 82%, var(--alliance-blue) 5%) 42%,
                    color-mix(in srgb, hsl(0 0% 4%) 58%, transparent) 100%
                );
        }
    }

    .hek-headline-card__body {
        display: flex;
        flex-direction: column;
        gap: var(--space-2xs);
        min-width: 0;
        flex: 1;
    }

    .hek-headline-card__meta {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: var(--space-s);
        font-size: var(--step--1);
        color: var(--faded);
        line-height: 1.4;

        time {
            white-space: nowrap;
        }
    }

    .hek-headline-card__tag {
        padding: 0.1em 0.55em;
        font-size: 0.85em;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        border: 1px solid transparent;
        line-height: 1.4;
        color: color-mix(in srgb, var(--alliance-blue) 65%, white);
        background: color-mix(in srgb, var(--alliance-blue) 18%, transparent);
        border-color: color-mix(in srgb, var(--alliance-blue) 35%, transparent);
    }

    .hek-headline-card--aar .hek-headline-card__tag {
        color: var(--fleet-yellow);
        background: color-mix(in srgb, var(--fleet-yellow) 12%, transparent);
        border-color: color-mix(in srgb, var(--fleet-yellow) 28%, transparent);
    }

    .hek-headline-card__title {
        margin: 0;
        font-size: var(--step-0);
        font-weight: 600;
        color: var(--highlight);
        line-height: 1.35;
    }

    .hek-headline-card__arrow {
        flex-shrink: 0;
        font-size: var(--step-1);
        color: var(--faded);
        transition: color 0.15s ease, transform 0.15s ease;
    }

    .hek-headline-card:hover .hek-headline-card__arrow,
    .hek-headline-card:focus-visible .hek-headline-card__arrow {
        color: var(--fleet-yellow);
        transform: translateX(3px);
    }

    .hek-campaign__footer {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        gap: var(--space-s);
        font-size: var(--step--1);
        color: var(--faded);
    }

    @media (max-width: 900px) {
        .hek-campaign__stat-grid--3 {
            grid-template-columns: 1fr;
        }

        .hek-campaign__timeline-item {
            grid-template-columns: 1fr;
            gap: var(--space-2xs);
        }
    }

    @media (max-width: 480px) {
        .hek-headline-card {
            padding: var(--space-m);
        }

        .hek-headline-card__arrow {
            display: none;
        }
    }
</style>
