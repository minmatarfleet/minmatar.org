---
import type { CampaignTableRow } from '@/data/campaigns/etherium-reach'

interface Props {
    headers: string[]
    rows: CampaignTableRow[]
    striped?: boolean
    /** Green ▲ on success-tone first cells (campaign tables). Off for industry. */
    success_marker?: boolean
}

const { headers, rows, striped = false, success_marker = true } = Astro.props
---

<div class="er-table-wrap" tabindex="0" role="region">
    <table class:list={['er-table', !success_marker && 'er-table--no-markers']}>
        <thead>
            <tr>
                {
                    headers.map((header, index) => (
                        <th
                            scope="col"
                            class:list={[
                                index > 0 && 'er-table__numeric',
                            ]}
                        >
                            {header}
                        </th>
                    ))
                }
            </tr>
        </thead>
        <tbody>
            {
                rows.map((row) => (
                    <tr class:list={[row.tone && `er-table__row--${row.tone}`]}>
                        {
                            row.cells.map((cell, index) => (
                                <td class:list={[index > 0 && 'er-table__numeric']}>
                                    {index === 0 && row.icon_url ? (
                                        <span class="er-table__name">
                                            <img
                                                class="er-table__icon"
                                                src={row.icon_url}
                                                alt=""
                                                width="24"
                                                height="24"
                                                loading="lazy"
                                            />
                                            <span>{cell}</span>
                                        </span>
                                    ) : (
                                        cell
                                    )}
                                </td>
                            ))
                        }
                    </tr>
                ))
            }
        </tbody>
    </table>
</div>

<style lang="scss">
    .er-table-wrap {
        overflow-x: auto;
        min-width: 0;
    }

    table {
        width: 100%;
        border-spacing: var(--space-3xs);
        font-size: var(--step--1);
    }

    th,
    td {
        padding: var(--space-s);
        border: 1px solid color-mix(in srgb, var(--border-color) 80%, transparent);
        text-align: left;
        vertical-align: top;
    }

    th {
        background: color-mix(in srgb, var(--component-background) 90%, transparent);
        font-weight: 600;
        color: var(--highlight);
        background-color: var(--light-transparency-background-mobile);
        
        @media screen and (min-width: 980px) {
            background-color: var(--light-transparency-background);
            backdrop-filter: blur(var(--transparency-backdrop-blur-heavier));
        }
    }

    td {
        color: var(--foreground);
        background-color: var(--light-transparency-background);
        backdrop-filter: blur(var(--transparency-backdrop-blur));
    }

    .er-table__numeric {
        text-align: right;
        font-variant-numeric: tabular-nums;
    }

    .er-table__name {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2xs);
    }

    .er-table__icon {
        flex-shrink: 0;
        width: 24px;
        height: 24px;
        object-fit: contain;
        border-radius: 2px;
    }

    .er-table__row--info td {
        font-weight: 600;
    }

    .er-table__row--success td:first-child:after {
        content: '▲';
        color: var(--green);
    }

    .er-table--no-markers .er-table__row--success td:first-child:after {
        content: none;
    }

    .er-table__row--warning td:first-child {
        color: var(--fleet-yellow);
    }
</style>
