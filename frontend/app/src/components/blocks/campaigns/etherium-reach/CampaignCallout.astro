---
interface Props {
    title: string
    tone?: 'neutral' | 'info'
}

const { title, tone = 'neutral' } = Astro.props
---

<aside class:list={['er-callout', `er-callout--${tone}`]}>
    <p class="er-callout__title">{title}</p>
    <div class="er-callout__body">
        <slot />
    </div>
</aside>

<style lang="scss">
    .er-callout {
        padding: var(--space-m) var(--space-l);
        border: 1px solid color-mix(in srgb, var(--border-color) 80%, transparent);
        background: color-mix(in srgb, var(--component-background) 70%, transparent);
    }

    .er-callout--info {
        border-left: 4px solid var(--alliance-blue);
    }

    .er-callout--neutral {
        border-left: 4px solid var(--faded);
    }

    .er-callout__title {
        margin: 0 0 var(--space-2xs);
        font-size: var(--step-0);
        font-weight: 600;
        color: var(--highlight);
    }

    .er-callout__body {
        font-size: var(--step--1);
        color: var(--faded);
        line-height: 1.6;

        :global(p) {
            margin: 0;
        }
    }
</style>
