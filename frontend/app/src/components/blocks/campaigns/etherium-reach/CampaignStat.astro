---
import TextGroup from '@components/blocks/TextGroup.astro'

interface Props {
    label: string
    tone?: 'info' | 'success' | 'danger'
}

const { label, tone } = Astro.props

import Wrapper from '@components/compositions/Wrapper.astro';
---

<Wrapper
    class:list={[ '[ card border light-transparency ]', tone && `er-stat--${tone}` ]}
    padding_block='var(--space-s)'
    padding_inline='var(--space-s)'
>
    <TextGroup title={label}>
        <b><slot /></b>
    </TextGroup>
</Wrapper>

<style lang="scss">
    b {
        font-size: var(--step-0);
    }

    .er-stat--info b {
        color: var(--alliance-blue);
    }

    .er-stat--success b {
        color: var(--green);
    }

    .er-stat--danger b {
        color: var(--fleet-red);
    }
</style>
