---
import { i18n } from '@helpers/i18n'
const { lang } = i18n(Astro.url)

import {
    CONSTELLATIONS_BY_DESTROYED,
    CONTRACTED_ISK,
    HEADLINES,
    ISK_DESTROYED_BY_CONSTELLATION,
    PERIOD_SCALDING_FLEETS,
    PERIOD_SCALDING_ISK_KILLS,
    PERIOD_SCALDING_ISK_LOSSES,
    TOP_FLEET_COMMANDERS,
    TOP_FLEET_PILOTS,
    formatIsk,
} from '@/data/campaigns/scalding-pass'

import { get_player_icon } from '@helpers/eve_image_server'

import Flexblock from '@components/compositions/Flexblock.astro'
import TextBox from '@components/layout/TextBox.astro'
import Grid from '@components/compositions/Grid.astro'
import ComponentBlock from '@components/blocks/ComponentBlock.astro'
import FlexInline from '@components/compositions/FlexInline.astro'
import CampaignDataTable from '@components/blocks/campaigns/etherium-reach/CampaignDataTable.astro'
import CampaignStat from '@components/blocks/campaigns/etherium-reach/CampaignStat.astro'
import PlayerContentChartChartjs from '@components/blocks/campaigns/scalding-pass/PlayerContentChartChartjs.astro'
import PlayerContentChartLegend from '@components/blocks/campaigns/scalding-pass/PlayerContentChartLegend.astro'
import CountUpAnimation from '@components/blocks/CountUpAnimation.astro'
import CharacterPicture from '@components/blocks/CharacterPicture.astro'
import CharacterCard from '@components/blocks/CharacterCard.astro'

const disclosureRows = [
    { cells: ['Diplomatic contract', formatIsk(CONTRACTED_ISK)] as const },
    {
        cells: ['Total disclosed', formatIsk(CONTRACTED_ISK)] as const,
        tone: 'info' as const,
    },
]

function formatHeadlineDate(isoDate: string): string {
    return new Date(`${isoDate}T00:00:00Z`).toLocaleDateString('en-GB', {
        day: 'numeric',
        month: 'short',
        year: 'numeric',
        timeZone: 'UTC',
    })
}

function formatHeadlineViews(views: string | number): string {
    if (typeof views === 'string') {
        return views === '—' ? views : `${views} views`
    }
    if (views >= 1_000_000) {
        return `${(views / 1_000_000).toFixed(1)}M views`
    }
    if (views >= 1_000) {
        return `${Math.round(views / 1_000)}K views`
    }
    return `${views.toLocaleString()} views`
}

const HEADLINE_CATEGORY_LABELS = {
    aar: 'AAR',
} as const

const constellationRows = [
    ...CONSTELLATIONS_BY_DESTROYED.map((constellation) => ({
        cells: [constellation, formatIsk(ISK_DESTROYED_BY_CONSTELLATION[constellation])] as const,
        tone: constellation === '4YFT-F' ? ('warning' as const) : undefined,
    })),
    {
        cells: [
            'All Scalding Pass',
            formatIsk(PERIOD_SCALDING_ISK_KILLS),
        ] as const,
        tone: 'info' as const,
    },
]

import { number_name } from '@helpers/numbers'
---

<TextBox>
    <Flexblock gap='var(--space-m)'>
        <Flexblock gap='var(--space-3xs)'>
            <h2>Content summary</h2>
            <small>Combat and fleets in Scalding Pass</small>
        </Flexblock>

        <Grid
            class="[ w-full grid-fill ]"
            row_gap="var(--space-3xs)"
            column_gap="var(--space-3xs)"
            min_item_width="300px"
        >
            <CampaignStat
                label="ISK destroyed"
                tone="success"
            >
                <CountUpAnimation
                    element='span' 
                    target={PERIOD_SCALDING_ISK_KILLS}
                    data-tippy-content={number_name(PERIOD_SCALDING_ISK_KILLS, lang)}
                />
            </CampaignStat>
            <CampaignStat
                label="ISK lost"
                tone="danger"
            >
                <CountUpAnimation
                    element='span' 
                    target={PERIOD_SCALDING_ISK_LOSSES}
                    data-tippy-content={number_name(PERIOD_SCALDING_ISK_LOSSES, lang)}
                />
            </CampaignStat>
            <CampaignStat
                label="Campaign fleets"
            >
                <CountUpAnimation
                    element='span' 
                    target={PERIOD_SCALDING_FLEETS}
                    data-tippy-content={number_name(PERIOD_SCALDING_FLEETS, lang)}
                />
            </CampaignStat>
        </Grid>
    </Flexblock>
</TextBox>

 <Flexblock>
    <Flexblock gap='var(--space-3xs)'>
        <h2>Player content over time</h2>
        <small>Monthly ISK destroyed in Scalding Pass and fleets flown there</small>
    </Flexblock>

    <ComponentBlock>
        <PlayerContentChartChartjs />
    </ComponentBlock>
</Flexblock>

 <Flexblock gap='var(--space-l)'>
    <Flexblock gap='var(--space-3xs)'>
        <h2>Campaign disclosure</h2>
        <small>Public contracted support during the campaign</small>
    </Flexblock>
    
    <CampaignDataTable headers={['Source', 'ISK']} rows={disclosureRows} />
    <small>Pilot income was not tracked during this campaign.</small>

    <Flexblock gap='var(--space-3xs)'>
        <h2>Combat by constellation</h2>
        <small>ISK destroyed across Scalding Pass constellations</small>
    </Flexblock>
    
    <CampaignDataTable
        headers={['Constellation', 'Destroyed']}
        rows={constellationRows}
        striped={true}
    />
 </Flexblock>

 <Flexblock gap='var(--space-l)'>
    <Flexblock>
        <Flexblock gap='var(--space-3xs)'>
            <h4>Top commanders</h4>
            <small>Fleet commanders in Scalding Pass during this campaign</small>
        </Flexblock>

        <Grid
            class="[ w-full grid-fill ]"
            row_gap="var(--space-3xs)"
            column_gap="var(--space-3xs)"
            min_item_width="324px"
        >
            {
                TOP_FLEET_COMMANDERS.map((fc) => (
                    <CharacterCard
                        character_id={fc.characterId ?? 0}
                        character_name={fc.name}
                        alt={`${fc.name} portrait`}
                        narrow={false}
                    >
                        <Flexblock gap='var(--space-3xs)'>
                            <h3>{fc.name}</h3>
                            <small>{fc.fleetCount.toLocaleString()} fleets</small>
                        </Flexblock>
                    </CharacterCard>
                ))
            }
        </Grid>
    </Flexblock>

    <Flexblock>
        <Flexblock gap='var(--space-3xs)'>
            <h4>Top pilots</h4>
            <small>Fleet participants in Scalding Pass during this campaign</small>
        </Flexblock>

        <Grid
            class="[ w-full grid-fill ]"
            row_gap="var(--space-3xs)"
            column_gap="var(--space-3xs)"
            min_item_width="324px"
        >
            {
                TOP_FLEET_PILOTS.map((pilot) => (
                    <CharacterCard
                        character_id={pilot.characterId ?? 0}
                        character_name={pilot.name}
                        alt={`${pilot.name} portrait`}
                        narrow={false}
                    >
                        <Flexblock gap='var(--space-3xs)'>
                            <h3>{pilot.name}</h3>
                            <small>{pilot.fleetCount.toLocaleString()} fleets</small>
                        </Flexblock>
                    </CharacterCard>
                ))
            }
        </Grid>
    </Flexblock>
</Flexblock>

<Flexblock>
    <Flexblock gap='var(--space-3xs)'>
        <h2>Headlines</h2>
        <small>Stories and updates from the campaign</small>
    </Flexblock>

    <div class="sp-headline-cards">
        {
            HEADLINES.map((headline) => (
                <a
                    class:list={[
                        'sp-headline-card',
                        `sp-headline-card--${headline.category}`,
                    ]}
                    style={`--sp-headline-bg: url('${headline.backgroundImage}')`}
                    href={headline.url}
                    target="_blank"
                    rel="noopener noreferrer nofollow"
                >
                    <div class="sp-headline-card__body">
                        <div class="sp-headline-card__meta">
                            <time datetime={headline.date}>
                                {formatHeadlineDate(headline.date)}
                            </time>
                            <span class="sp-headline-card__tag">
                                {HEADLINE_CATEGORY_LABELS[headline.category]}
                            </span>
                        </div>
                        <h4 class="sp-headline-card__title">{headline.title}</h4>
                        <p class="sp-headline-card__reddit">
                            <span class="sp-headline-card__reddit-upvotes" aria-label={`${headline.upvotes} upvotes`}>
                                ▲ {headline.upvotes.toLocaleString()}
                            </span>
                            <span aria-hidden="true">·</span>
                            <span>{headline.comments.toLocaleString()} comments</span>
                            <span aria-hidden="true">·</span>
                            <span>{formatHeadlineViews(headline.views)}</span>
                        </p>
                    </div>
                    <span class="sp-headline-card__arrow" aria-hidden="true">→</span>
                </a>
            ))
        }
    </div>
</Flexblock>

<FlexInline justification='space-between'>
    <span>Scalding Pass Campaign Report</span>
    <span>July 2026</span>
</FlexInline>

<style lang="scss">
    .sp-campaign {
        display: flex;
        flex-direction: column;
        gap: var(--space-2xl);
        width: 100%;
        min-width: 0;
    }

    .sp-campaign__section {
        display: flex;
        flex-direction: column;
        gap: var(--space-m);
        min-width: 0;

        h3,
        h4 {
            margin: 0;
            color: var(--highlight);
            line-height: 1.2;
        }

        h3 {
            font-size: var(--step-1);
        }

        h4 {
            font-size: var(--step-0);
        }

        h3 + .sp-campaign__meta,
        h4 + .sp-campaign__meta {
            margin-top: calc(var(--space-2xs) - var(--space-m));
        }
    }

    .sp-campaign__subsection {
        display: flex;
        flex-direction: column;
        gap: var(--space-m);
        min-width: 0;
        padding-top: var(--space-l);
        border-top: 1px solid color-mix(in srgb, var(--border-color) 45%, transparent);
    }

    .sp-campaign__meta,
    .sp-campaign__subheading,
    .sp-campaign__footnote {
        margin: 0;
        font-size: var(--step--1);
        color: var(--faded);
        line-height: 1.5;
    }

    .sp-campaign__subheading {
        margin-bottom: var(--space-s);
    }

    .sp-campaign__stat-grid {
        display: grid;
        gap: var(--space-m);
        min-width: 0;
    }

    .sp-campaign__stat-grid--3 {
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .sp-campaign__fc-grid {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: var(--space-m);
        min-width: 0;
    }

    .sp-fc-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--space-s);
        padding: var(--space-s);
        background: color-mix(in srgb, var(--component-background) 80%, transparent);
        border: 1px solid color-mix(in srgb, var(--border-color) 80%, transparent);
        min-width: 0;
        text-align: center;
    }

    .sp-fc-card__portrait {
        flex-shrink: 0;
        width: 64px;
        height: 64px;
        border-radius: 4px;
    }

    .sp-fc-card__body {
        display: flex;
        flex-direction: column;
        gap: var(--space-3xs);
        min-width: 0;
        width: 100%;
    }

    .sp-fc-card__name {
        font-size: var(--step-0);
        font-weight: 600;
        color: var(--highlight);
        line-height: 1.2;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .sp-fc-card__count {
        font-size: var(--step--1);
        color: var(--faded);
    }

    .sp-campaign__chart-block {
        display: flex;
        flex-direction: column;
        gap: var(--space-s);
        min-width: 0;
    }

    .sp-campaign__chart-card {
        display: flex;
        flex-direction: column;
        gap: var(--space-s);
        padding: var(--space-m);
        background: color-mix(in srgb, var(--component-background) 70%, transparent);
        border: 1px solid color-mix(in srgb, var(--border-color) 80%, transparent);
        min-width: 0;
    }

    .sp-campaign__chart-plot {
        margin-inline: calc(-1 * var(--space-m));
        min-width: 0;
    }

    .sp-headline-cards {
        display: flex;
        flex-direction: column;
        gap: var(--space-m);
        min-width: 0;
    }

    .sp-headline-card {
        position: relative;
        isolation: isolate;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-m);
        padding: var(--space-m) var(--space-l);
        min-width: 0;
        overflow: hidden;
        text-decoration: none;
        color: inherit;
        border: 1px solid color-mix(in srgb, var(--border-color) 80%, transparent);
        border-left-width: 3px;
        transition:
            border-color 0.15s ease,
            transform 0.15s ease;

        &::before {
            content: '';
            position: absolute;
            inset: 0;
            z-index: 0;
            background-image: var(--sp-headline-bg);
            background-size: cover;
            background-position: center;
            transition: transform 0.15s ease;
        }

        &::after {
            content: '';
            position: absolute;
            inset: 0;
            z-index: 0;
            transition: opacity 0.15s ease;
        }

        > * {
            position: relative;
            z-index: 1;
        }

        &:hover,
        &:focus-visible {
            transform: translateX(2px);
            border-color: color-mix(in srgb, var(--border-color-hover) 80%, transparent);
        }

        &:hover::before,
        &:focus-visible::before {
            transform: scale(1.03);
        }

        &:focus-visible {
            outline: 2px solid var(--fleet-yellow);
            outline-offset: 2px;
        }
    }

    .sp-headline-card--aar {
        border-left-color: var(--fleet-yellow);

        &::after {
            background:
                linear-gradient(
                    90deg,
                    color-mix(in srgb, hsl(0 0% 4%) 94%, var(--fleet-red) 6%) 0%,
                    color-mix(in srgb, hsl(0 0% 4%) 82%, var(--fleet-red) 5%) 42%,
                    color-mix(in srgb, hsl(0 0% 4%) 58%, transparent) 100%
                );
        }

        &:hover::after,
        &:focus-visible::after {
            background:
                linear-gradient(
                    90deg,
                    color-mix(in srgb, hsl(0 0% 4%) 90%, var(--fleet-red) 10%) 0%,
                    color-mix(in srgb, hsl(0 0% 4%) 78%, var(--fleet-red) 8%) 42%,
                    color-mix(in srgb, hsl(0 0% 4%) 52%, transparent) 100%
                );
        }

        .sp-headline-card__tag {
            color: var(--fleet-yellow);
            background: color-mix(in srgb, var(--fleet-yellow) 12%, transparent);
            border-color: color-mix(in srgb, var(--fleet-yellow) 28%, transparent);
        }
    }

    .sp-headline-card__body {
        display: flex;
        flex-direction: column;
        gap: var(--space-2xs);
        min-width: 0;
        flex: 1;
    }

    .sp-headline-card__meta {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: var(--space-s);
        font-size: var(--step--1);
        color: var(--faded);
        line-height: 1.4;

        time {
            white-space: nowrap;
        }
    }

    .sp-headline-card__tag {
        padding: 0.1em 0.55em;
        font-size: 0.85em;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        border: 1px solid transparent;
        line-height: 1.4;
    }

    .sp-headline-card__title {
        margin: 0;
        font-size: var(--step-0);
        font-weight: 600;
        color: var(--highlight);
        line-height: 1.35;
    }

    .sp-headline-card__reddit {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.45em;
        margin: 0;
        font-size: var(--step--2);
        color: color-mix(in srgb, var(--faded) 88%, transparent);
        line-height: 1.4;
    }

    .sp-headline-card__reddit-upvotes {
        color: color-mix(in srgb, var(--faded) 95%, var(--fleet-yellow) 5%);
    }

    .sp-headline-card__arrow {
        flex-shrink: 0;
        font-size: var(--step-1);
        color: var(--faded);
        transition: color 0.15s ease, transform 0.15s ease;
    }

    .sp-headline-card:hover .sp-headline-card__arrow,
    .sp-headline-card:focus-visible .sp-headline-card__arrow {
        color: var(--fleet-yellow);
        transform: translateX(3px);
    }

    .sp-campaign__footer {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        gap: var(--space-s);
        font-size: var(--step--1);
        color: var(--faded);
    }

    @media (max-width: 900px) {
        .sp-campaign__stat-grid--3 {
            grid-template-columns: 1fr;
        }

        .sp-campaign__fc-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @media (max-width: 480px) {
        .sp-campaign__fc-grid {
            grid-template-columns: 1fr;
        }

        .sp-headline-card {
            padding: var(--space-m);
        }

        .sp-headline-card__arrow {
            display: none;
        }
    }
</style>
