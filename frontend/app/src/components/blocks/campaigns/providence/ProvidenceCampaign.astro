---
import { i18n } from '@helpers/i18n'
const { lang } = i18n(Astro.url)

import {
    CAMPAIGN_ISK_DESTROYED,
    FLEET_PARTICIPATION_PCT,
    FLEET_PILOTS,
    formatIsk,
    HEADLINES,
    OTHER_FLEET_COMMANDERS,
    PERIOD_CAMPAIGN_FLEETS,
    TOP_FLEET_COMMANDERS,
    TOP_FLEET_PILOTS,
} from '@/data/campaigns/providence'

import { get_player_icon } from '@helpers/eve_image_server'

import Flexblock from '@components/compositions/Flexblock.astro'
import TextBox from '@components/layout/TextBox.astro'
import Grid from '@components/compositions/Grid.astro'
import ComponentBlock from '@components/blocks/ComponentBlock.astro'
import FlexInline from '@components/compositions/FlexInline.astro'
import CampaignStat from '@components/blocks/campaigns/etherium-reach/CampaignStat.astro'
import CountUpAnimation from '@components/blocks/CountUpAnimation.astro'
import CharacterPicture from '@components/blocks/CharacterPicture.astro'
import CharacterCard from '@components/blocks/CharacterCard.astro'
import ProvidenceContentChartChartjs from '@components/blocks/campaigns/providence/ProvidenceContentChartChartjs.astro'

function formatHeadlineDate(isoDate: string): string {
    return new Date(`${isoDate}T00:00:00Z`).toLocaleDateString('en-GB', {
        day: 'numeric',
        month: 'short',
        year: 'numeric',
        timeZone: 'UTC',
    })
}

function formatHeadlineViews(views: string | number): string {
    if (typeof views === 'string') {
        return views === '—' ? views : `${views} views`
    }
    if (views >= 1_000_000) {
        return `${(views / 1_000_000).toFixed(1)}M views`
    }
    if (views >= 1_000) {
        return `${Math.round(views / 1_000)}K views`
    }
    return `${views.toLocaleString()} views`
}

const HEADLINE_CATEGORY_LABELS = {
    aar: 'AAR',
    industry: 'Industry',
} as const

import { number_name } from '@helpers/numbers'
---

<TextBox>
    <Flexblock gap='var(--space-m)'>
        <Flexblock gap='var(--space-3xs)'>
            <h2>Campaign by the numbers</h2>
            <small>Participation and combat in the Providence war</small>
        </Flexblock>
        <Grid
            class="[ w-full grid-fill ]"
            row_gap="var(--space-3xs)"
            column_gap="var(--space-3xs)"
            min_item_width="300px"
        >
            <CampaignStat
                label="Participation"
                tone="success"
            >
                <CountUpAnimation
                    element='span' 
                    target={FLEET_PARTICIPATION_PCT}
                />% · <CountUpAnimation
                    element='span' 
                    target={FLEET_PILOTS}
                /> pilots
            </CampaignStat>
            <CampaignStat
                label="ISK destroyed"
                tone="success"
            >
                <CountUpAnimation
                    element='span' 
                    target={CAMPAIGN_ISK_DESTROYED}
                    data-tippy-content={number_name(CAMPAIGN_ISK_DESTROYED, lang)}
                />
            </CampaignStat>
            <CampaignStat
                label="Campaign fleets"
            >
                <CountUpAnimation
                    element='span' 
                    target={PERIOD_CAMPAIGN_FLEETS}
                    data-tippy-content={number_name(PERIOD_CAMPAIGN_FLEETS, lang)}
                />
            </CampaignStat>
        </Grid>
    </Flexblock>
</TextBox>

<Flexblock>
    <Flexblock gap='var(--space-3xs)'>
        <h2>Player content over time</h2>
        <small>Monthly ISK destroyed and fleets flown</small>
    </Flexblock>

    <ComponentBlock>
        <ProvidenceContentChartChartjs />
    </ComponentBlock>
</Flexblock>

<Flexblock gap='var(--space-l)'>
    <Flexblock>
        <Flexblock gap='var(--space-3xs)'>
            <h4>Top commanders</h4>
            <small>Fleet commanders contributing to this campaign</small>
        </Flexblock>

        <Grid
            class="[ w-full grid-fill ]"
            row_gap="var(--space-3xs)"
            column_gap="var(--space-3xs)"
            min_item_width="324px"
        >
            {
                TOP_FLEET_COMMANDERS.map((fc) => (
                    <>{'isAggregate' in fc && fc.isAggregate ? (
                        <Flexblock class="[ justify-between! h-full ]">
                            <Grid
                                class="[ w-full grid-fill max-h-[190px] overflow-y-auto ]"
                                row_gap="0"
                                column_gap="0"
                                min_item_width="64px"
                            >
                                {OTHER_FLEET_COMMANDERS.commanders.map(commander =>
                                    <div data-tippy-content={`${commander.name} · ${commander.fleetCount} fleets`}>
                                        <CharacterPicture
                                            character_id={commander.characterId}
                                            character_name={commander.name}
                                            size={64}
                                            icon_quality={128}
                                        />
                                    </div>
                                )}
                            </Grid>

                            <Flexblock gap='var(--space-3xs)'>
                                <h3>{fc.name}</h3>
                                <small>{fc.fleetCount.toLocaleString()} fleets</small>
                            </Flexblock>
                        </Flexblock>
                    ) : (
                        <CharacterCard
                            character_id={fc.characterId ?? 0}
                            character_name={fc.name}
                            alt={`${fc.name} portrait`}
                            narrow={false}
                        >
                            <Flexblock gap='var(--space-3xs)'>
                                <h3>{fc.name}</h3>
                                <small>{fc.fleetCount.toLocaleString()} fleets</small>
                            </Flexblock>
                        </CharacterCard>
                    )}</>
                ))
            }
        </Grid>
        
        <small>FC counts use in-game fleet commander when tracked, otherwise who scheduled the fleet. SEDIT, Vard, and other unrelated fights excluded. Instance tracking from late May 2024.</small>
    </Flexblock>

    <Flexblock>
        <Flexblock gap='var(--space-3xs)'>
            <h4>Top pilots</h4>
            <small>Fleet participants contributing to this campaign</small>
        </Flexblock>

        <Grid
            class="[ w-full grid-fill ]"
            row_gap="var(--space-3xs)"
            column_gap="var(--space-3xs)"
            min_item_width="324px"
        >
            {
                TOP_FLEET_PILOTS.map((pilot) => (
                    <CharacterCard
                        character_id={pilot.characterId ?? 0}
                        character_name={pilot.name}
                        alt={`${pilot.name} portrait`}
                        narrow={false}
                    >
                        <Flexblock gap='var(--space-3xs)'>
                            <h3>{pilot.name}</h3>
                            <small>{pilot.fleetCount.toLocaleString()} fleets</small>
                        </Flexblock>
                    </CharacterCard>
                ))
            }
        </Grid>
    </Flexblock>
</Flexblock>

<Flexblock>
    <Flexblock gap='var(--space-3xs)'>
        <h2>Headlines</h2>
        <small>Stories and updates from the campaign</small>
    </Flexblock>

    <div class="er-headline-cards">
        {
            HEADLINES.map((headline) => (
                <a
                    class:list={[
                        'er-headline-card',
                        `er-headline-card--${headline.category}`,
                    ]}
                    style={`--er-headline-bg: url('${headline.backgroundImage}')`}
                    href={headline.url}
                    target="_blank"
                    rel="noopener noreferrer nofollow"
                >
                    <div class="er-headline-card__body">
                        <div class="er-headline-card__meta">
                            <time datetime={headline.date}>
                                {formatHeadlineDate(headline.date)}
                            </time>
                            <span class="er-headline-card__tag">
                                {HEADLINE_CATEGORY_LABELS[headline.category]}
                            </span>
                        </div>
                        <h4 class="er-headline-card__title">{headline.title}</h4>
                        <p class="er-headline-card__reddit">
                            <span class="er-headline-card__reddit-upvotes" aria-label={`${headline.upvotes} upvotes`}>
                                ▲ {headline.upvotes.toLocaleString()}
                            </span>
                            <span aria-hidden="true">·</span>
                            <span>{headline.comments.toLocaleString()} comments</span>
                            <span aria-hidden="true">·</span>
                            <span>{formatHeadlineViews(headline.views)}</span>
                        </p>
                    </div>
                    <span class="er-headline-card__arrow" aria-hidden="true">→</span>
                </a>
            ))
        }
    </div>
</Flexblock>

<FlexInline justification='space-between'>
    <span>Providence Campaign Report</span>
    <span>July 2026</span>
</FlexInline>

<style lang="scss">
    .er-campaign {
        display: flex;
        flex-direction: column;
        gap: var(--space-2xl);
        width: 100%;
        min-width: 0;
    }

    .er-campaign__section {
        display: flex;
        flex-direction: column;
        gap: var(--space-m);
        min-width: 0;

        h3,
        h4 {
            margin: 0;
            color: var(--highlight);
            line-height: 1.2;
        }

        h3 {
            font-size: var(--step-1);
        }

        h4 {
            font-size: var(--step-0);
        }

        h3 + .er-campaign__meta,
        h4 + .er-campaign__meta {
            margin-top: calc(var(--space-2xs) - var(--space-m));
        }
    }

    .er-campaign__subsection {
        display: flex;
        flex-direction: column;
        gap: var(--space-m);
        min-width: 0;
        padding-top: var(--space-l);
        border-top: 1px solid color-mix(in srgb, var(--border-color) 45%, transparent);
    }

    .er-campaign__meta,
    .er-campaign__footnote {
        margin: 0;
        font-size: var(--step--1);
        color: var(--faded);
        line-height: 1.5;
    }

    .er-campaign__stat-grid {
        display: grid;
        gap: var(--space-m);
        min-width: 0;
    }

    .er-campaign__stat-grid--3 {
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .er-campaign__fc-grid {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: var(--space-m);
        min-width: 0;
    }

    .er-fc-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--space-s);
        padding: var(--space-s);
        background: color-mix(in srgb, var(--component-background) 80%, transparent);
        border: 1px solid color-mix(in srgb, var(--border-color) 80%, transparent);
        min-width: 0;
        text-align: center;
    }

    .er-fc-card__portrait {
        flex-shrink: 0;
        width: 64px;
        height: 64px;
        border-radius: 4px;
    }

    .er-fc-card__portraits {
        display: grid;
        flex-shrink: 0;
        grid-template-columns: repeat(4, 1fr);
        gap: 1px;
        width: 64px;
        height: 64px;
        overflow: hidden;
    }

    .er-fc-card__portrait-mini {
        display: block;
        width: 100%;
        height: 100%;
        border-radius: 2px;
        object-fit: cover;
    }

    .er-fc-card__body {
        display: flex;
        flex-direction: column;
        gap: var(--space-3xs);
        min-width: 0;
        width: 100%;
    }

    .er-fc-card__name {
        font-size: var(--step-0);
        font-weight: 600;
        color: var(--highlight);
        line-height: 1.2;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .er-fc-card__count {
        font-size: var(--step--1);
        color: var(--faded);
    }

    .er-campaign__chart-block {
        display: flex;
        flex-direction: column;
        gap: var(--space-s);
        min-width: 0;
    }

    .er-campaign__chart-card {
        display: flex;
        flex-direction: column;
        gap: var(--space-s);
        padding: var(--space-m);
        background: color-mix(in srgb, var(--component-background) 70%, transparent);
        border: 1px solid color-mix(in srgb, var(--border-color) 80%, transparent);
        min-width: 0;
    }

    .er-campaign__chart-plot {
        margin-inline: calc(-1 * var(--space-m));
        min-width: 0;
    }

    .er-headline-cards {
        display: flex;
        flex-direction: column;
        gap: var(--space-m);
        min-width: 0;
    }

    .er-headline-card {
        position: relative;
        isolation: isolate;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-m);
        padding: var(--space-m) var(--space-l);
        min-width: 0;
        overflow: hidden;
        text-decoration: none;
        color: inherit;
        border: 1px solid color-mix(in srgb, var(--border-color) 80%, transparent);
        border-left-width: 3px;
        transition:
            border-color 0.15s ease,
            transform 0.15s ease;

        &::before {
            content: '';
            position: absolute;
            inset: 0;
            z-index: 0;
            background-image: var(--er-headline-bg);
            background-size: cover;
            background-position: center;
            transition: transform 0.15s ease;
        }

        &::after {
            content: '';
            position: absolute;
            inset: 0;
            z-index: 0;
            transition: opacity 0.15s ease;
        }

        > * {
            position: relative;
            z-index: 1;
        }

        &:hover,
        &:focus-visible {
            transform: translateX(2px);
            border-color: color-mix(in srgb, var(--border-color-hover) 80%, transparent);
        }

        &:hover::before,
        &:focus-visible::before {
            transform: scale(1.03);
        }

        &:focus-visible {
            outline: 2px solid var(--fleet-yellow);
            outline-offset: 2px;
        }
    }

    .er-headline-card--aar {
        border-left-color: var(--fleet-yellow);

        &::after {
            background:
                linear-gradient(
                    90deg,
                    color-mix(in srgb, hsl(0 0% 4%) 94%, var(--fleet-red) 6%) 0%,
                    color-mix(in srgb, hsl(0 0% 4%) 82%, var(--fleet-red) 5%) 42%,
                    color-mix(in srgb, hsl(0 0% 4%) 58%, transparent) 100%
                );
        }

        .er-headline-card__tag {
            color: var(--fleet-yellow);
            background: color-mix(in srgb, var(--fleet-yellow) 12%, transparent);
            border-color: color-mix(in srgb, var(--fleet-yellow) 28%, transparent);
        }
    }

    .er-headline-card__body {
        display: flex;
        flex-direction: column;
        gap: var(--space-2xs);
        min-width: 0;
        flex: 1;
    }

    .er-headline-card__meta {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: var(--space-s);
        font-size: var(--step--1);
        color: var(--faded);
        line-height: 1.4;

        time {
            white-space: nowrap;
        }
    }

    .er-headline-card__tag {
        padding: 0.1em 0.55em;
        font-size: 0.85em;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        border: 1px solid transparent;
        line-height: 1.4;
    }

    .er-headline-card__title {
        margin: 0;
        font-size: var(--step-0);
        font-weight: 600;
        color: var(--highlight);
        line-height: 1.35;
    }

    .er-headline-card__reddit {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.45em;
        margin: 0;
        font-size: var(--step--2);
        color: color-mix(in srgb, var(--faded) 88%, transparent);
        line-height: 1.4;
    }

    .er-headline-card__arrow {
        flex-shrink: 0;
        font-size: var(--step-1);
        color: var(--faded);
        transition: color 0.15s ease, transform 0.15s ease;
    }

    .er-headline-card:hover .er-headline-card__arrow,
    .er-headline-card:focus-visible .er-headline-card__arrow {
        color: var(--fleet-yellow);
        transform: translateX(3px);
    }

    .er-campaign__footer {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        gap: var(--space-s);
        font-size: var(--step--1);
        color: var(--faded);
    }

    @media (max-width: 900px) {
        .er-campaign__stat-grid--3 {
            grid-template-columns: 1fr;
        }

        .er-campaign__fc-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @media (max-width: 480px) {
        .er-campaign__fc-grid {
            grid-template-columns: 1fr;
        }

        .er-headline-card {
            padding: var(--space-m);
        }

        .er-headline-card__arrow {
            display: none;
        }
    }
</style>
