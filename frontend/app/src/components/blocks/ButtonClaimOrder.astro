---
import { i18n } from '@helpers/i18n'
const { lang, t, translatePath } = i18n(Astro.url)

import type { RootSingleItem } from '@dtypes/api.minmatar.org'
import type { ButtonColors, ButtonSizes } from '@dtypes/layout_components';

interface Props {
    target_id:      string;
    title:          string;
    reclaim:        boolean;
    order_id:       number;
    claimed:        number;
    item:           RootSingleItem;
    size?:          ButtonSizes;
    character_id:   number;
    hidden?:        boolean;
    id?:            string;
}

const {
    target_id,
    title,
    reclaim,
    order_id,
    claimed,
    item,
    size = 'sm',
    character_id,
    hidden = false,
    id,
} = Astro.props

import { hours_diff } from '@helpers/date'

const clip_maximum = new Date(item.self_assign_window_ends_at) > new Date()
const hours_left = hours_diff(new Date(), item.self_assign_window_ends_at)

let max_claimable_items = item.unassigned_quantity
if (item.self_assign_maximum && clip_maximum)
    max_claimable_items = item.self_assign_maximum - claimed

const ORDER_ITEM_PARTIAL_URL = translatePath(`/partials/order_item_component?order_id=${order_id}&item_id=${item.id}`)

import { number_thousand_separator } from '@helpers/numbers'

// Avoid adding a frontmatter line with a string literal (e.g. ?? "" or ?? ''). It triggers
// esbuild "Unterminated string literal" when compiling this .astro file. Use template for defaults (e.g. data-api-url={import.meta.env.API_URL}).
import Flexblock from '@components/compositions/Flexblock.astro';
import FlexInline from '@components/compositions/FlexInline.astro';
import FluidFixed from '@components/compositions/FluidFixed.astro';

import DialogButton from "@components/blocks/DialogButton.astro";
import Button from '@components/blocks/Button.astro';
import Input from '@components/blocks/Input.astro';
import ItemBadge from '@components/blocks/ItemBadge.astro';
---

<DialogButton
    id={id ? id : undefined}
    color={reclaim ? 'fleet-red' : 'green'}
    narrow={false}
    size={size}
    hidden={hidden}
    max_width='520px'
    @dialog_opened.stop="$el.querySelector('button').setAttribute('disabled', '')"
    @dialog_closed.stop="$el.querySelector('button').removeAttribute('disabled')"
>
    {reclaim ? t('reclaim') : t('claim')}

    <form
        slot="dialog" 
        hx-post={ORDER_ITEM_PARTIAL_URL}
        hx-trigger="submit"
        hx-target={`#${target_id}`}
        hx-indicator=".loader"
        hx-swap="outerHTML transition:true"
        x-on:submit="close_dialog(false)"
        x-data={`{
            quantity: 0,
            target_estimated_margin: ${item.target_estimated_margin},
            total_text: '0 ISK',
            total_text_template: '{value} ISK',
            number_thousand_separator(val) {
                return val.toLocaleString('${lang}', {
                    minimumFractionDigits: 0,
                    maximumFractionDigits: 0,
                })
            },
            update_total_text() {
                const total = this.quantity * this.target_estimated_margin
                this.total_text = this.total_text_template.replace('{value}', this.number_thousand_separator(total))
            }
        }`}
    >
        <Flexblock gap="var(--space-l)">
            <Flexblock gap="var(--space-s)">
                <h3>{title}</h3>
                    
                <p>{reclaim ? t('define_add_assignment_quantity') : t('define_produce_quantity')}</p>
                
                <Flexblock>
                    <FluidFixed
                        width='150px'
                    >
                        <FlexInline class="[ w-full ]" justification='space-between'>
                            <ItemBadge
                                item_name={item.eve_type_name}
                                type_id={item.eve_type_id}
                            >
                                {clip_maximum ?
                                    <small>{hours_left !== 1 ?
                                        t('up_to_count_for_plural').replace('{count}', String(max_claimable_items)).replace('{hours}', String(hours_left)) :
                                        t('up_to_count_for_singular').replace('{count}', String(max_claimable_items))
                                    }</small> :
                                    <small>{t('up_to_count').replace('{count}', String(max_claimable_items))}</small>
                                }
                            </ItemBadge>
                        </FlexInline>
                        <Input
                            name="quantity"
                            type="number"
                            min="0"
                            max={max_claimable_items}
                            value="0"
                            x-model="quantity"
                            width='150px'
                            x-on:input={`quantity = Math.min(quantity, ${max_claimable_items}); update_total_text()`}
                        />
                        <input type="hidden" name="character_id" value={character_id} />
                    </FluidFixed>
                    <Flexblock gap='var(--space-3xs)'>
                        <FlexInline justification='flex-end'>
                            <small>{t('target_unit_price')}</small>
                            <small class="[ basis-[160px] text-right ]">{number_thousand_separator(parseInt(item.target_unit_price ?? '0') ?? 0)} ISK</small>
                        </FlexInline>
                        <FlexInline justification='flex-end'>
                            <small>{t('target_estimated_margin')}</small>
                            <small class="[ basis-[160px] text-right ]">{number_thousand_separator(parseInt(item.target_estimated_margin ?? '0') ?? 0)} ISK</small>
                        </FlexInline>
                        <FlexInline justification='flex-end'>
                            <p class="[ basis-[160px] text-green text-right ]"><b x-text="total_text">0 ISK</b></p>
                        </FlexInline>
                    </Flexblock>
                </Flexblock>
            </Flexblock>

            <FlexInline justification='flex-end'>
                <Button
                    type="submit"
                    color='green'
                    size='sm'
                    x-bind:disabled="quantity == 0"
                    off_disable={true}
                    disabled
                >
                    {t('claim')}
                </Button>

                <Button
                    type="button"
                    size='sm'
                    x-on:click="close_dialog()"
                >
                    {t('close')}
                </Button>
            </FlexInline>
        </Flexblock>
    </form>
</DialogButton>

<style lang="scss">
    h3 {
        font-size: var(--step-1);
    }
</style>
