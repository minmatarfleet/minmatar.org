---
import { i18n } from '@helpers/i18n'
const { t } = i18n(Astro.url)

import Flexblock from '@components/compositions/Flexblock.astro';
import { get_corporations_list } from '@helpers/fetching/corporations';
import type { CorporationObject } from '@dtypes/layout_components';
import {
    filterL3arnApplicationAllianceCorporations,
    L3ARN_FORM_PREFIX,
} from '@helpers/corporations/l3arn_application';
import { corporationApplicationFieldName } from './field_names';

interface Props {
    include_field_names?: boolean;
    form_prefix?: string;
    id_prefix?: string;
    alliance_corporations?: CorporationObject[];
}

const {
    include_field_names = false,
    form_prefix = L3ARN_FORM_PREFIX,
    id_prefix = 'l3arn',
    alliance_corporations,
} = Astro.props;

const fieldName = (key: string) =>
    corporationApplicationFieldName(form_prefix, include_field_names, key);

const otherAllianceCorporations = alliance_corporations
    ? filterL3arnApplicationAllianceCorporations(alliance_corporations)
    : filterL3arnApplicationAllianceCorporations(
        await get_corporations_list('alliance'),
    );
---

<Flexblock
    class="[ w-full ]"
    gap="var(--space-xs)"
    role="group"
    aria-labelledby={`${id_prefix}-other-corps-label`}
>
    <span id={`${id_prefix}-other-corps-label`} class="field-label">
        {t('l3arn_application_other_corps')}
    </span>
    {otherAllianceCorporations.map((corporation) => (
        <label
            class="choice-row"
            for={`${id_prefix}-other-corp-${corporation.corporation_id}`}
        >
            <input
                id={`${id_prefix}-other-corp-${corporation.corporation_id}`}
                type="checkbox"
                name={fieldName('other_corporations')}
                value={corporation.corporation_name}
                x-model="other_corporations"
                x-on:change="updateApplicationStatus()"
            />
            <span>{corporation.corporation_name}</span>
        </label>
    ))}

    <small class="form-subtext form-subtext--after-list">
        <a
            class="browse-corps-link"
            href="https://my.minmatar.org/alliance/corporations/list/"
            target="_blank"
            rel="noreferrer noopener"
        >
            {t('l3arn_application_other_corps_link')}
            <span class="visually-hidden">{t('opens_in_new_tab')}</span>
        </a>
    </small>
</Flexblock>

<style lang="scss">
    @import './_shared.scss';
</style>
