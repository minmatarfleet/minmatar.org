---
import { i18n } from '@helpers/i18n'
const { t } = i18n(Astro.url)

import Flexblock from '@components/compositions/Flexblock.astro';
import Textarea from '@components/blocks/Textarea.astro';
import {
    L3ARN_APPLICATION_COUNTER_THRESHOLD_OFFSET,
    L3ARN_APPLICATION_FIELD_LIMITS,
    L3ARN_FORM_PREFIX,
} from '@helpers/corporations/l3arn_application';
import { corporationApplicationFieldName } from './field_names';

interface Props {
    include_field_names?: boolean;
    form_prefix?: string;
    id_prefix?: string;
}

const {
    include_field_names = false,
    form_prefix = L3ARN_FORM_PREFIX,
    id_prefix = 'l3arn',
} = Astro.props;

const fieldName = (key: string) =>
    corporationApplicationFieldName(form_prefix, include_field_names, key);

const goalsLimit = L3ARN_APPLICATION_FIELD_LIMITS.goals;
const goalsCounterThreshold =
    goalsLimit - L3ARN_APPLICATION_COUNTER_THRESHOLD_OFFSET;
---

<Flexblock class="[ w-full ]" gap="var(--space-2xs)">
    <label for={`${id_prefix}-goals`}>{t('l3arn_application_goals')}</label>
    <div class="remain-wrapper" data-limit={goalsLimit}>
        <Textarea
            id={`${id_prefix}-goals`}
            name={fieldName('goals')}
            x-model="goals"
            rows="3"
            maxlength={goalsLimit}
            required
            x-on:input="updateApplicationStatus()"
        />
        <small
            x-show={`goals.length > ${goalsCounterThreshold}`}
            x-text={`${goalsLimit} - goals.length`}
            x-bind:class="(!fieldWithinLimit('goals') ? 'text-red animate-fade-in-up' : '')"
        >
            {goalsLimit}
        </small>
    </div>
</Flexblock>

<style lang="scss">
    @import './_shared.scss';
</style>
