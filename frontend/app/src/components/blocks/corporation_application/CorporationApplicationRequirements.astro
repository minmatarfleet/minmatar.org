---
/**
 * Shared requirements block for corporation application forms.
 *
 * Intended for reuse across all corp apply forms (L3ARN and future corps).
 * Alpine models: agree_tenets, confirm_omega, confirm_auth_chars.
 * Field keys: agree_tenets, confirm_omega, confirm_auth_chars.
 */
import { i18n } from '@helpers/i18n'
const { t, translatePath } = i18n(Astro.url)

import Flexblock from '@components/compositions/Flexblock.astro';
import RadioCheckInput from '@components/blocks/RadioCheckInput.astro'
import Markdown from '@components/blocks/Markdown.astro'

import { L3ARN_FORM_PREFIX } from '@helpers/corporations/l3arn_application';
import { corporationApplicationFieldName } from './field_names';

interface Props {
    include_field_names?: boolean;
    include_omega?: boolean;
    form_prefix?: string;
    id_prefix?: string;
}

const {
    include_field_names = false,
    include_omega = true,
    form_prefix = L3ARN_FORM_PREFIX,
    id_prefix = 'l3arn',
} = Astro.props;

const fieldName = (key: string) =>
    corporationApplicationFieldName(form_prefix, include_field_names, key);
---

<Flexblock class="[ w-full ]">
    <h4 class="[ text-foreground ]">{t('l3arn_application_requirements_heading')}</h4>

    <Flexblock class="[ w-full ]" gap="var(--space-xs)">
        <RadioCheckInput
            id={`${id_prefix}-agree-tenets`}
            type="checkbox"
            name={fieldName('agree_tenets')}
            x-model="agree_tenets"
            x-on:change="updateApplicationStatus()"
        >
            <Markdown
                markdown={t('l3arn_application_agree_tenets_before')}
                inline={true}
                inline_element='span'
                open_in_new_tab={true}
            />
        </RadioCheckInput>

        {include_omega && (
            <RadioCheckInput
                id={`${id_prefix}-confirm-omega`}
                type="checkbox"
                name={fieldName('confirm_omega')}
                x-model="confirm_omega"
                x-on:change="updateApplicationStatus()"
            >
                <Markdown markdown={t('l3arn_application_confirm_omega')} inline={true} inline_element='span' />
            </RadioCheckInput>
        )}

        <RadioCheckInput
            id={`${id_prefix}-confirm-auth`}
            type="checkbox"
            name={fieldName('confirm_auth_chars')}
            x-model="confirm_auth_chars"
            x-on:change="updateApplicationStatus()"
        >
            <Markdown markdown={t('l3arn_application_confirm_auth')} inline={true} inline_element='span' />
        </RadioCheckInput>
    </Flexblock>
</Flexblock>

<style lang="scss">
    @import './_shared.scss';

    .section-heading {
        display: block;
        margin: 0;
        line-height: 1.45;
    }
</style>
