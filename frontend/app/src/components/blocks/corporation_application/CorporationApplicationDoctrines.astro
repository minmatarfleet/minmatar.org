---
import { i18n } from '@helpers/i18n'
const { t, translatePath } = i18n(Astro.url)

import Flexblock from '@components/compositions/Flexblock.astro';
import Textarea from '@components/blocks/Textarea.astro';
import {
    CORPORATION_APPLICATION_COUNTER_THRESHOLD_OFFSET,
    CORPORATION_APPLICATION_FIELD_LIMITS,
    CORPORATION_APPLICATION_FORM_PREFIX,
} from '@helpers/corporations/corporation_application';
import { corporationApplicationFieldName } from './field_names';

interface Props {
    include_field_names?: boolean;
    form_prefix?: string;
    id_prefix?: string;
}

const {
    include_field_names = false,
    form_prefix = CORPORATION_APPLICATION_FORM_PREFIX,
    id_prefix = 'corp-app',
} = Astro.props;

const fieldName = (key: string) =>
    corporationApplicationFieldName(form_prefix, include_field_names, key);

const doctrinesLimit = CORPORATION_APPLICATION_FIELD_LIMITS.doctrines;
const doctrinesCounterThreshold =
    doctrinesLimit - CORPORATION_APPLICATION_COUNTER_THRESHOLD_OFFSET;
---

<Flexblock class="[ w-full ]" gap="var(--space-2xs)">
    <label for={`${id_prefix}-doctrines`}>{t('corporation_application_doctrines')}</label>
    <p class="form-subtext">
        <a
            href={translatePath('/ships/doctrines/')}
            target="_blank"
            rel="noreferrer noopener"
        >
            {t('corporation_application_doctrines_link')}
            <span class="visually-hidden">{t('opens_in_new_tab')}</span>
        </a>
    </p>
    <div class="remain-wrapper" data-limit={doctrinesLimit}>
        <Textarea
            id={`${id_prefix}-doctrines`}
            name={fieldName('doctrines')}
            x-model="doctrines"
            rows="3"
            maxlength={doctrinesLimit}
            required
            x-on:input="updateApplicationStatus()"
        />
        <small
            x-show={`doctrines.length > ${doctrinesCounterThreshold}`}
            x-text={`${doctrinesLimit} - doctrines.length`}
            x-bind:class="(!fieldWithinLimit('doctrines') ? 'text-red animate-fade-in-up' : '')"
        >
            {doctrinesLimit}
        </small>
    </div>
</Flexblock>

<style lang="scss">
    @import './_shared.scss';
</style>
