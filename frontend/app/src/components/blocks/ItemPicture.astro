---
import { i18n } from '@helpers/i18n'
const { t } = i18n(Astro.url)

import type { EvEImageServiceSize, ImageSize } from '@dtypes/layout_components'

interface BlueprintParam {
    is_copy:    boolean;
}

interface Props {
    item_id:        number;
    item_name?:     string;
    size?:          ImageSize;
    narrow?:        boolean;
    icon_quality?:  EvEImageServiceSize;
    mask?:          boolean;
    quantity?:      number;
    blueprint?:     BlueprintParam;
}

const {
    item_id,
    item_name,
    size = 64,
    narrow = false,
    icon_quality = 64,
    mask = false,
    quantity,
    blueprint,
} = Astro.props

import { get_item_icon, get_bpc_icon } from '@helpers/eve_image_server';

import NotificationBadge from '@components/blocks/NotificationBadge.astro';
---

<picture class="animated">
    <img
        class:list={{ mask }}
        loading="lazy"
        height={narrow ? 412 : size}
        width={size}
        src={blueprint ? get_bpc_icon(item_id, blueprint.is_copy, icon_quality ?? size) : get_item_icon(item_id, icon_quality ?? size)}
        alt={item_name ?? t('item_picture')}
    />
    {quantity &&
        <NotificationBadge class="[ quantity-badge ]" number={quantity} />
    }
</picture>

<style lang="scss">
    picture {
        position: relative;

        .quantity-badge {
            position: absolute;
            bottom: -5px;
            right: -5px;
        }
    }

    img {
        object-fit: cover;
        width: 100%;
    }

    .mask {
        -webkit-mask-image: linear-gradient(to bottom,rgb(0,0,0) 0%,rgba(0,0,0,.7) 50%,transparent 100%);
        mask-image: linear-gradient(to bottom,rgb(0,0,0) 0%,rgba(0,0,0,.7) 50%,transparent 100%);
    }
</style>