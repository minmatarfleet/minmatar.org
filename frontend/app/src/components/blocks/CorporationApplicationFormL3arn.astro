---
import { i18n } from '@helpers/i18n'
const { t } = i18n(Astro.url)

import Flexblock from '@components/compositions/Flexblock.astro';
import FlexInline from '@components/compositions/FlexInline.astro';
import Input from '@components/blocks/Input.astro';
import Textarea from '@components/blocks/Textarea.astro';
import { L3ARN_FORM_PREFIX } from '@helpers/corporations/l3arn_application';

interface Props {
    include_field_names?: boolean;
}

const { include_field_names = false } = Astro.props;

const fieldName = (key: string) =>
    include_field_names ? `${L3ARN_FORM_PREFIX}${key}` : undefined;
---

<Flexblock gap="var(--space-m)">
    <p>{t('l3arn_application_intro')}</p>

    <Flexblock class="[ w-full ]" gap="var(--space-3xs)">
        <label for="l3arn-introduction">{t('l3arn_application_introduction')}</label>
        <Textarea
            id="l3arn-introduction"
            name={fieldName('introduction')}
            x-model="introduction"
            rows="4"
            required
            x-on:input="updateApplicationStatus()"
        />
    </Flexblock>

    <Flexblock class="[ w-full ]" gap="var(--space-3xs)">
        <label for="l3arn-timezone">{t('l3arn_application_timezone')}</label>
        <Input
            id="l3arn-timezone"
            name={fieldName('timezone')}
            x-model="timezone"
            required
            x-on:input="updateApplicationStatus()"
        />
    </Flexblock>

    <Flexblock class="[ w-full ]" gap="var(--space-3xs)">
        <label for="l3arn-roles">{t('l3arn_application_roles')}</label>
        <Input
            id="l3arn-roles"
            name={fieldName('roles')}
            x-model="roles"
            required
            x-on:input="updateApplicationStatus()"
        />
    </Flexblock>

    <Flexblock class="[ w-full ]" gap="var(--space-3xs)">
        <label for="l3arn-goals">{t('l3arn_application_goals')}</label>
        <Textarea
            id="l3arn-goals"
            name={fieldName('goals')}
            x-model="goals"
            rows="3"
            required
            x-on:input="updateApplicationStatus()"
        />
    </Flexblock>

    <Flexblock class="[ w-full ]" gap="var(--space-3xs)">
        <label for="l3arn-comms">{t('l3arn_application_comms')}</label>
        <Textarea
            id="l3arn-comms"
            name={fieldName('comfortable_comms')}
            x-model="comfortable_comms"
            rows="2"
            required
            x-on:input="updateApplicationStatus()"
        />
        <small>{t('l3arn_application_comms_hint')}</small>
    </Flexblock>

    <Flexblock class="[ w-full ]" gap="var(--space-3xs)">
        <label for="l3arn-how-found">{t('l3arn_application_how_found')}</label>
        <Input
            id="l3arn-how-found"
            name={fieldName('how_found')}
            x-model="how_found"
            required
            x-on:input="updateApplicationStatus()"
        />
    </Flexblock>

    <Flexblock class="[ w-full ]" gap="var(--space-3xs)">
        <label for="l3arn-only-l3arn">{t('l3arn_application_only_l3arn')}</label>
        <Textarea
            id="l3arn-only-l3arn"
            name={fieldName('only_l3arn')}
            x-model="only_l3arn"
            rows="2"
            required
            x-on:input="updateApplicationStatus()"
        />
        <small>
            <a href="https://my.minmatar.org/alliance/corporations/list/" target="_blank" rel="noreferrer noopener">
                {t('l3arn_application_other_corps_link')}
            </a>
        </small>
    </Flexblock>

    <Flexblock gap="var(--space-xs)">
        <strong>{t('l3arn_application_requirements_heading')}</strong>
        <small>{t('l3arn_application_tenets_hint')}</small>

        <FlexInline gap="var(--space-xs)">
            <input
                id="l3arn-agree-tenets"
                type="checkbox"
                name={fieldName('agree_tenets')}
                x-model="agree_tenets"
                x-on:change="updateApplicationStatus()"
            />
            <label for="l3arn-agree-tenets">{t('l3arn_application_agree_tenets')}</label>
        </FlexInline>

        <FlexInline gap="var(--space-xs)">
            <input
                id="l3arn-confirm-omega"
                type="checkbox"
                name={fieldName('confirm_omega')}
                x-model="confirm_omega"
                x-on:change="updateApplicationStatus()"
            />
            <label for="l3arn-confirm-omega">{t('l3arn_application_confirm_omega')}</label>
        </FlexInline>

        <FlexInline gap="var(--space-xs)">
            <input
                id="l3arn-confirm-not-alt"
                type="checkbox"
                name={fieldName('confirm_not_alt')}
                x-model="confirm_not_alt"
                x-on:change="updateApplicationStatus()"
            />
            <label for="l3arn-confirm-not-alt">{t('l3arn_application_confirm_not_alt')}</label>
        </FlexInline>

        <FlexInline gap="var(--space-xs)">
            <input
                id="l3arn-confirm-not-dual"
                type="checkbox"
                name={fieldName('confirm_not_dual_citizen')}
                x-model="confirm_not_dual_citizen"
                x-on:change="updateApplicationStatus()"
            />
            <label for="l3arn-confirm-not-dual">{t('l3arn_application_confirm_not_dual')}</label>
        </FlexInline>

        <FlexInline gap="var(--space-xs)">
            <input
                id="l3arn-confirm-auth"
                type="checkbox"
                name={fieldName('confirm_auth_chars')}
                x-model="confirm_auth_chars"
                x-on:change="updateApplicationStatus()"
            />
            <label for="l3arn-confirm-auth">{t('l3arn_application_confirm_auth')}</label>
        </FlexInline>
    </Flexblock>
</Flexblock>

<style lang="scss">
    label {
        font-weight: 600;
    }

    small {
        color: var(--highlight);
    }

    input[type='checkbox'] {
        width: auto;
    }
</style>
