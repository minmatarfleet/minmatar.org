---
import { i18n } from '@helpers/i18n'
const { lang, t, translatePath } = i18n(Astro.url)

import type { FleetUI, FleetCompositionUI, FleetRadarUI, SRPUI, FleetCombatLog } from '@dtypes/layout_components'

import type { SummaryCharacter, FleetMetrics, FleetCommanderMetrics } from '@dtypes/api.minmatar.org'
import type { FleetRoleVolunteer } from '@helpers/api.minmatar.org/fleets'

interface Props {
    fleet:                      FleetUI;
    history?:                   boolean;
    can_remove_fleet:           boolean;
    is_fleet_commander?:        boolean;
    fleet_composition?:         FleetCompositionUI[];
    fleet_radar?:               FleetRadarUI[];
    saved_logs?:                FleetCombatLog[];
    volunteers:                 FleetRoleVolunteer[],
    pilots:                     SummaryCharacter[],
    update_cover:               boolean;
    fleet_metrics:              FleetMetrics | undefined;
    fleet_commander_metrics:    FleetCommanderMetrics | undefined;
}

const {
    fleet,
    history = false,
    can_remove_fleet = false,
    is_fleet_commander = false,
    fleet_composition,
    fleet_radar,
    saved_logs = [],
    volunteers,
    pilots,
    update_cover,
    fleet_metrics,
    fleet_commander_metrics,
} = Astro.props

console.log(fleet)

const FLEET_COMPOSITION_PARTIAL_URL = `${translatePath('/partials/fleet_composition')}?id=${fleet.id}`

import { minutes_to } from '@helpers/date';

const diff_time = minutes_to(fleet.start_time)
const minutes_to_fleet = diff_time < 0 ? Math.abs(diff_time) : 0
const pre_pingable = minutes_to_fleet >= 30

import { get_fleet_tracking_texts } from '@helpers/fetching/fleets'
const fleet_tracking_texts = get_fleet_tracking_texts(lang, fleet.tracking)

import Flexblock from '@components/compositions/Flexblock.astro';
import Wrapper from '@components/compositions/Wrapper.astro';
import BlockList from '@components/compositions/BlockList.astro';

import FleetCompositionBlock from '@components/blocks/FleetCompositionBlock.astro';
// import RemoveFleetButton from '@components/blocks/RemoveFleetButton.astro';
import TextGroup from '@components/blocks/TextGroup.astro';
import FleetStatus from '@components/blocks/FleetStatus.astro';
import SRPTable from '@components/blocks/SRPTable.astro';
import FleetHero from '@components/blocks/FleetHero.astro';
import FleetCombatLogTable from '@components/blocks/FleetCombatLogTable.astro';
import LocalTimeGroup from '@components/blocks/LocalTimeGroup.astro';
import AARLinkButton from '@components/blocks/AARLinkButton.astro';
import FleetRoles from '@components/blocks/FleetRoles.astro';

const eve_time = new Date(fleet.start_time);
const eve_time_text = eve_time.toLocaleDateString(lang, JSON.parse(import.meta.env.DATETIME_FORMAT))
---

<Flexblock
    gap="var(--space-2xl)"
    x-data={`{
        tracking_started: false,
    }`}
    @tracking_started="tracking_started = true"
    @is_fleet_time="document.getElementById('preping-button').remove()"
>
    <BlockList gap="var(--space-xl)">
        <FleetHero
            fleet={{
                audience: fleet.audience,
                doctrine_id: fleet?.doctrine?.id,
                fleet_commander_id: fleet.fleet_commander_id,
                fleet_commander_name: fleet.fleet_commander_name,
                id: fleet.id,
                start_time: fleet.start_time,
                description: fleet.description,
                location: fleet.location,
                objective: fleet.objective,
                status: fleet.status,
                tracking: fleet.tracking,
                type: fleet.type,
                corporation_id: fleet_commander_metrics?.corporation_id ?? 0,
                corporation_name: fleet_commander_metrics?.corporation_name ?? t('unknown_corporation'),
                fleet_commander_fleet_count: fleet_commander_metrics?.fleet_count,
                members_count: fleet_metrics?.members ?? 0,
            }}
            doctrine={fleet.doctrine}
            update_cover={update_cover}
            cover_overlay={true}
        >
            <TextGroup title={t('eve_time')} class="[ sentence-cap ]">
                {eve_time_text}
            </TextGroup>
            <LocalTimeGroup eve_time={eve_time} />
        </FleetHero>

        <div class="[ animate-fade-in animate-duration-250 animate-delay-1000 ]">
            <FleetStatus
                fleet_id={fleet.id}
                start_time={fleet.start_time}
                fleet_tracking={fleet.tracking}
                fleet_status={fleet.status}
                is_fleet_commander={is_fleet_commander}
                fleet_tracking_texts={fleet_tracking_texts}
            />
        </div>

        {history &&
            <div class="[ animate-fade-in animate-duration-250 animate-delay-1000 ]">
                <AARLinkButton
                    aarlink={fleet.aar_link ? fleet.aar_link : undefined}
                    fleet_id={fleet.id}
                    can_edit={can_remove_fleet}
                />
            </div>
        }

        {!history &&
            <div class="[ animate-fade-in animate-duration-250 animate-delay-1000 ]">
                <FleetRoles
                    volunteers={volunteers}
                    pilots={pilots}
                    fleet_id={fleet.id}
                    readonly={fleet.status === 'cancelled'}
                />
            </div>
        }

        {is_fleet_commander &&
            <div
                class="[ animate-fade-in animate-duration-250 animate-delay-1000 ]"
                x-data={`{
                    global_collapse: $persist(false),
                }`}
            >
                {fleet?.tracking &&
                    <FleetCompositionBlock
                        composition={fleet_composition ?? []}
                        fleet_radar={fleet_radar ?? []}
                        fleet_id={fleet.id}
                    />
                }

                {!fleet?.tracking &&
                    <template
                        x-if="tracking_started"
                    >
                        <div
                            x-data={`{
                                init() {
                                    htmx.process($el)
                                }
                            }`}
                            hx-get={FLEET_COMPOSITION_PARTIAL_URL}
                            hx-trigger="load delay:30s once"
                            hx-indicator=".loader"
                            hx-swap="innerHTML transition:true"
                        >
                            <p class="[ loading ]">{t('loading_fleet_composition')}</p>
                        </div>
                    </template>
                }
            </div>
        }
    </BlockList>

    <Wrapper padding_block='0' padding_inline='0' class="[ animate-fade-in animate-duration-250 animate-delay-1000 ]">
        <FleetCombatLogTable
            saved_logs={saved_logs}
            fleet_id={fleet.id}
            disabled={fleet.status === 'cancelled'}
        />
    </Wrapper>
</Flexblock>