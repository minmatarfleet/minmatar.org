---
import type { TagColors } from '@dtypes/layout_components';

interface Props {
    text:                   string;
    title?:                 string;
    color?:                 TagColors | string;
    narrow?:                boolean;
    [propName: string]: any;
}

const {
    text,
    title,
    color = 'fleet-red',
    narrow = false,
    ...attributes
} = Astro.props;

delete attributes.class

const tag_color = `var(--${color})`;

const optional_attributes = {
    ...(title && { "title": title })
}
---

<span class:list={['tag w-fit', { narrow: narrow }, Astro.props.class]} {...optional_attributes} {...attributes}>{text}</span>

<style lang="scss" define:vars={{ tag_color }}>
    span {
        display: flex;
        padding: var(--space-3xs) var(--space-2xs);
        font-size: var(--step--2);
        color: var(--highlight);
        background-color: var(--tag_color);

        &.narrow {
            padding: 0px 3px;
        }
    }
</style>