---
import { i18n } from '@helpers/i18n'
const { t, translatePath } = i18n(Astro.url)

import type { SpaceTruckerStatistics } from '@dtypes/api.minmatar.org'

interface Props {
    space_truckers:     SpaceTruckerStatistics[];
}

const {
    space_truckers,
} = Astro.props

import Wrapper from '@components/compositions/Wrapper.astro';
import FixedFluid from '@components/compositions/FixedFluid.astro';
import FlexInlineSiblings from '@components/compositions/FlexInlineSiblings.astro';
import FlexInline from '@components/compositions/FlexInline.astro';

import Marquee from '@components/blocks/Marquee.astro';
import SpaceTruckerBadge from '@components/blocks/SpaceTruckerBadge.astro';
import Button from '@components/blocks/Button.astro';
---

<div
    class="[ bottom-bar ][ card component light-transparency hidden! animate-slide-in-bottom ]"
    x-on:marquee-started="$el.classList.add('lg:block!')"
>
    <Wrapper
        class="[ space-truckers-reel ]"
        neocom={true}
        max_width='var(--max-content-width)'
        centered={true}
        padding_block='var(--space-2xs)'
    >
        <FixedFluid width='170px' class="[ items-center! ]">
            <h4>{t('space_trucker_ranking')}</h4>
            <FlexInlineSiblings
                min-shink-width='250px'
                shrinkable-sibbling='first'
            >
                {space_truckers.length >= 5 ?
                    <Marquee>
                        <div style="width: calc(450px + var(--space-l))"><hr class="[ border-bottom ]" /></div>
                        {space_truckers.map((trucker, index) =>
                            <SpaceTruckerBadge place={index + 1} trucker={trucker} />
                        )}
                        <div style="width: 450px"><hr class="[ border-bottom ]" /></div>
                        {space_truckers.map((trucker, index) =>
                            <SpaceTruckerBadge place={index + 1} trucker={trucker} />
                        )}
                    </Marquee> :
                    <FlexInline gap='var(--space-l)'>
                        {space_truckers.map((trucker, index) =>
                            <SpaceTruckerBadge place={index + 1} trucker={trucker} />
                        )}
                    </FlexInline>
                }

                <Button
                    href={translatePath('/alliance/tribes/3')}
                    size='sm'
                >
                    {t('become_a_trucker')}
                </Button>
            </FlexInlineSiblings>
        </FixedFluid>
    </Wrapper>
</div>

<style lang="scss">
    .bottom-bar {
        position: fixed;
        left: 0;
        bottom: 0;
        width: 100%;
        z-index: var(--sticky-z-index);
    }

    .space-truckers-reel {
        position: relative;
    }
</style>