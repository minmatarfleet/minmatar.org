---
import { i18n } from '@helpers/i18n'
const { translatePath } = i18n(Astro.url)

interface Props {
    page:       number;
    text:       string;
    active?:    boolean;
    tribe_id:   number;
    group_id:   number;
}

const {
    page,
    text,
    active = false,
    tribe_id,
    group_id,
} = Astro.props

const TRIBE_GROUP_ACTIVITY_PARTIAL_URL = translatePath(`/partials/tribe_group_activity_component?tribe_id=${tribe_id}&group_id=${group_id}&is_pagination=true`)

import Button from '@components/blocks/Button.astro';
---

<Button
    color={active ? 'transparent' : undefined}
    size='sm'
    hx-get={`${TRIBE_GROUP_ACTIVITY_PARTIAL_URL}&page=${page}`}
    hx-swap="outerHTML transition:true"
    hx-target="#activity-list"
    hx-indicator=".loader"
>
    {text}
</Button>