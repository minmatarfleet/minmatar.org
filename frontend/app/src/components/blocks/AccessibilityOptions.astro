---
import { i18n } from '@helpers/i18n'
const { t } = i18n(Astro.url)

interface Props {
    color_blind:    boolean;
}

const {
    color_blind,
} = Astro.props

import Flexblock from "@components/compositions/Flexblock.astro";
import FlexInlineSiblings from "@components/compositions/FlexInlineSiblings.astro";

import SwitchSquare from '@components/blocks/SwitchSquare.astro';
import TextGroup from '@components/blocks/TextGroup.astro';
import Select from '@components/blocks/Select.astro';
---

<Flexblock gap='var(--space-l)'>
    <h2>{t('accessibility_options')}</h2>

    <SwitchSquare
        class="[ w-full ]"
        x-model="color_blind_mode"
        label={t('color_blind_mode')}
        description={t('color_blind_description')}
    />

    <FlexInlineSiblings
        min-shink-width='200px'
        shrinkable-sibbling='first'
    >
        <TextGroup title={t('ui_scaling')}>
            <small>{t('ui_scaling_description')}</small>
        </TextGroup>
        <Select size='sm' x-model="ui_scaling">
            <option value="100">100%</option>
            <option value="90">90%</option>
            <option value="80">80%</option>
        </Select>
    </FlexInlineSiblings>
</Flexblock>