---
import { i18n } from '@helpers/i18n'
const { lang, t, translatePath } = i18n(Astro.url)

import type { CampaignMeta } from '@/data/campaigns'
import { formatIsk } from '@/data/campaigns'

interface Props {
    campaign:       CampaignMeta;
}

const {
    campaign,
} = Astro.props

const href = translatePath(campaign.path)
const name = t(campaign.nameKey as any)
const period = t(campaign.periodKey as any)
const excerpt = t(campaign.excerptKey as any)
const isk_label = t('campaigns.isk_destroyed')
const isk_value = formatIsk(campaign.iskDestroyed)
const view_label = t('campaigns.view_report')

import { number_thousand_separator, number_name } from '@helpers/numbers'

import Flexblock from '@components/compositions/Flexblock.astro';
import Wrapper from '@components/compositions/Wrapper.astro';

import Tile from '@components/blocks/Tile.astro'
import Button from '@components/blocks/Button.astro'
import Tag from './Tag.astro';
---

<Flexblock
    class="[ card component border light-transparency ]"
    gap='0'
>
    <Tile
        title={name}
        description={excerpt}
        cover={campaign.coverImage}
        transparent={true}
    >
        <Flexblock slot="subtitle" gap='var(--space-m)'>
            <Tag text={period} color='fleet-yellow' />

            <Flexblock gap='var(--space-3xs)'>
                <small>{t('destroyed')}</small>
                <h3>
                    <span
                        data-tippy-content={number_name(campaign.iskDestroyed, lang)}
                    >{number_thousand_separator(campaign.iskDestroyed)}</span>&nbsp;ISK
                </h3>
            </Flexblock>
            
        </Flexblock>
    </Tile>

    <Wrapper
        class="[ pb-(--component-padding-block)! grow ]"
        padding_inline='var(--component-padding-block)'
        padding_block='0'
        max_width='100%'
    >
        <Button href={href}>
            {view_label}
        </Button>
    </Wrapper>
</Flexblock>