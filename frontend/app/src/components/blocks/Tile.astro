---
interface Props {
    title:              string;
    description?:       string;
    cover:              string;
    alt?:               string;
    transparent?:       boolean;
    soft?:              boolean;
    optimize?:          boolean;
    width?:             number;
    height?:            number;
    [propName: string]: any;
}

const {
    title,
    description,
    cover,
    alt,
    transparent = false,
    soft = true,
    optimize,
    width = '512',
    height = '512',
    ...attributes
} = Astro.props

const transparent_class = transparent ? '' : 'border light-transparency'

const slot_content = await Astro.slots.render('default')

import Flexblock from '@components/compositions/Flexblock.astro';
import BlockList from '@components/compositions/BlockList.astro';
import FlexInline from '@components/compositions/FlexInline.astro';
import Wrapper from '@components/compositions/Wrapper.astro';
import { Image } from 'astro:assets';

import Markdown from '@components/blocks/Markdown.astro';
---

<Wrapper
    class:list={[`card component relative tile ${transparent_class}`, { soft: soft }, Astro.props.class ]}
    padding_inline='var(--component-padding-block)'
    padding_block='var(--component-padding-block)'
    max_width='100%'
>
    {optimize ?
        <Image
            src={cover}
            alt={alt ?? title}
            width={width}
            height={height}
            quality={90}
            format='webp'
        /> :
        <img class="[ z-0 ]" src={cover} alt={alt ?? title} />
    }
    
    <BlockList class="[ relative z-10 !justify-end min-h-[420px] ]">
        <Flexblock gap='var(--space-3xs)'>
            <slot name="icon" />
            <h2>{title}</h2>
        </Flexblock>
        
        <Flexblock gap='var(--space-m)'>
            {description && <Markdown class="[ max-w-[380px] ]" markdown={description} inline={true} />}

            <slot name="subtitle" />

            {slot_content && <FlexInline><slot /></FlexInline>}
        </Flexblock>
    </BlockList>
</Wrapper>

<style lang="scss">
    img {
        object-fit: cover;
        position: absolute;
        top: 0;
        left: 0;
        height: 100%;
        width: 100%;
        mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 1) 0%, rgba(0, 0, 0, 0.1) 65%, transparent 90%);
    }

    .soft img {
        mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.8) 0%, rgba(0, 0, 0, 0.1) 65%, transparent 90%);
    }

    h2 {
        font-size: var(--step-3);
    }
</style>