---
import { i18n } from '@helpers/i18n'
const { translatePath } = i18n(Astro.url)

import type { CorporationBadgeProps, EvEImageServiceSize } from '@dtypes/layout_components'
import { get_corporation_by_id } from '@helpers/api.eveonline/corporations'
import type { CorporationEvE } from '@dtypes/api.eveonline'

interface Props {
    corporation:    CorporationBadgeProps;
    border?:        boolean;
    highlight?:     boolean;
    show_modal?:    boolean;
}

const {
    corporation,
    border = false,
    highlight = true,
    show_modal = false,
} = Astro.props

let corporation_eve:CorporationEvE | null = null
let get_eve_corporation_error
if (!corporation?.name) {
    try {
        corporation_eve = await get_corporation_by_id(corporation.id)
    } catch (error) {
        get_eve_corporation_error = error.message
    }
}

const LOGO_SIZES = {
    'xs': 24,
    'sm': 32,
    'lg': 64,
}

const LOGO_QLTY = {
    'xs': 32,
    'sm': 32,
    'lg': 64,
}

const GAPS = {
    'xs': 'var(--space-3xs)',
    'sm': 'var(--space-2xs)',
    'lg': 'var(--space-s)',
}

const corporation_name = corporation?.name ?? (corporation_eve?.name ?? get_eve_corporation_error)
const size = corporation?.size ?? 'sm'
const logo_size = LOGO_SIZES[size] ?? 32
const logo_qlty = LOGO_QLTY[size] ?? 32
const description:string | false = corporation?.description ?? false
const gap = GAPS[size] ?? 'var(--space-2xs)'

const Element = show_modal ? StylessButton : 'div'

import { get_corporation_logo } from '@helpers/eve_image_server';

import FixedFluid from '@components/compositions/FixedFluid.astro'
import Flexblock from '@components/compositions/Flexblock.astro';

import StylessButton from '@components/blocks/StylessButton.astro';
---

<Element
    x-data={show_modal ? `{
            show_corporation_modal() {
                show_modal({
                    partial: '${translatePath('/partials/corporation_modal_component/')}?corporation_id=${corporation.id}',
                })
            }
        }` :
        undefined
    }
    x-on:click.stop.prevent={show_modal ? 'show_corporation_modal()' : undefined}
>
    <FixedFluid
        width={`${logo_size}px`}
        gap={gap}
        class="[ items-center ]"
    >
        <picture class:list={{ border: border }}>
            <img loading="lazy" src={get_corporation_logo(corporation.id, logo_qlty as EvEImageServiceSize)} width={logo_size} height={logo_size} />
        </picture>
        <Flexblock gap='0' class="[ w-full ]">
            {size == 'lg' ?
                <span>
                    <span class:list={[ { 'text-[var(--highlight)]': highlight }, 'max-w-fit' ]}>{corporation_name}</span>
                </span>
                <slot>
                    <small>{description}</small>
                </slot>
                :
                <small class="[ max-w-fit ]">
                    <a class:list={{ 'text-[var(--highlight)]': highlight }}>{corporation_name}</a>
                </small>
            }
        </Flexblock>
    </FixedFluid>
</Element>