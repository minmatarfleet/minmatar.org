---
import {
    guideMeta,
    credits,
    additionalResources,
    introduction,
    considerations,
    considerationBullets,
    disclaimers,
    metagameSummary,
    glossary,
    guideSections,
    matchupLegend,
    matchupCharts,
    shipGuides,
} from '@/data/faction-warfare-cruiser-guide'

import GuideContentsLayout from '@components/blocks/GuideContentsLayout.astro'
import GuideShell from '@components/blocks/GuideShell.astro'
import FactionWarfareCruiserGuideMatchupChart from '@components/blocks/faction-warfare-cruiser-guide/FactionWarfareCruiserGuideMatchupChart.astro'
import FactionWarfareCruiserGuideShipSection from '@components/blocks/faction-warfare-cruiser-guide/FactionWarfareCruiserGuideShipSection.astro'
import { get_fittings } from '@helpers/api.minmatar.org/ships'
import type { Fitting } from '@dtypes/api.minmatar.org'

let fittingLibrary: Fitting[] = []
try {
    fittingLibrary = await get_fittings()
} catch {
    fittingLibrary = []
}
---

<GuideShell
    title={guideMeta.title}
    subtitle={`${guideMeta.edition} · ${guideMeta.yc}`}
>
    <div class="fwc-guide">
    <GuideContentsLayout sections={guideSections}>
            <section id="introduction" data-section-id="introduction" class="fwc-section fwc-panel" aria-labelledby="fwc-intro-title">
                <h2 id="fwc-intro-title" class="fwc-section__title">Introduction</h2>
                {
                    introduction.map((paragraph) => (
                        <p class="fwc-section__paragraph" set:html={paragraph} />
                    ))
                }
            </section>

            <section id="considerations" data-section-id="considerations" class="fwc-section fwc-panel" aria-labelledby="fwc-considerations-title">
                <h2 id="fwc-considerations-title" class="fwc-section__title">Considerations of the Metagame</h2>
                {
                    considerations.map((paragraph) => (
                        <p class="fwc-section__paragraph">{paragraph}</p>
                    ))
                }
                <ul class="fwc-section__list">
                    {
                        considerationBullets.map((bullet) => (
                            <li>{bullet}</li>
                        ))
                    }
                </ul>
            </section>

            <section id="disclaimers" data-section-id="disclaimers" class="fwc-section fwc-panel" aria-labelledby="fwc-disclaimers-title">
                <h2 id="fwc-disclaimers-title" class="fwc-section__title">Disclaimers</h2>
                {
                    disclaimers.map((paragraph) => (
                        <p class="fwc-section__paragraph">{paragraph}</p>
                    ))
                }
            </section>

            <section id="summary" data-section-id="summary" class="fwc-section fwc-panel" aria-labelledby="fwc-summary-title">
                <h2 id="fwc-summary-title" class="fwc-section__title">Summary of the Metagame</h2>
                <div class="fwc-summary-grid">
                    {
                        metagameSummary.map((entry) => (
                            <article class="fwc-summary-card">
                                <h3 class="fwc-summary-card__title">{entry.archetype}</h3>
                                <p class="fwc-summary-card__text">{entry.text}</p>
                            </article>
                        ))
                    }
                </div>
            </section>

            <section id="matchups" data-section-id="matchups" class="fwc-section fwc-panel" aria-labelledby="fwc-matchups-title">
                <h2 id="fwc-matchups-title" class="fwc-section__title">Matchup Charts</h2>

                <div class="fwc-legend" aria-label="Matchup rating legend">
                    {
                        matchupLegend.map((item) => (
                            <div class="fwc-legend__item">
                                <span class:list={['fwc-legend__symbol', `fwc-legend__symbol--${item.rating === '?' ? 'unknown' : item.rating.replace(/\+/g, 'plus').replace(/-/g, 'minus').replace(/=/g, 'even')}`]}>
                                    {item.rating}
                                </span>
                                <span class="fwc-legend__label">
                                    <strong>{item.label}</strong>
                                    <span>{item.description}</span>
                                </span>
                            </div>
                        ))
                    }
                </div>

                <div class="fwc-charts-grid">
                    {
                        matchupCharts.map((chart) => (
                            <FactionWarfareCruiserGuideMatchupChart chart={chart} />
                        ))
                    }
                </div>
            </section>

            <div class="fwc-guide__ships">
                {
                    shipGuides.map((ship) => (
                        <FactionWarfareCruiserGuideShipSection ship={ship} fittingLibrary={fittingLibrary} />
                    ))
                }
            </div>

            <section id="glossary" data-section-id="glossary" class="fwc-section fwc-panel" aria-labelledby="fwc-glossary-title">
                <h2 id="fwc-glossary-title" class="fwc-section__title">Glossary</h2>
                <dl class="fwc-glossary">
                    {
                        glossary.map((entry) => (
                            <>
                                <dt class="fwc-glossary__term">{entry.term}</dt>
                                <dd class="fwc-glossary__definition">{entry.definition}</dd>
                            </>
                        ))
                    }
                </dl>
            </section>

            <section id="resources" data-section-id="resources" class="fwc-section fwc-panel" aria-labelledby="fwc-resources-title">
                <h2 id="fwc-resources-title" class="fwc-section__title">Additional Resources</h2>
                <p class="fwc-section__paragraph">
                    Written by {credits.author}. The links below cover sibling hull guides, plex fundamentals, and deeper yearly data when you want another angle.
                </p>
                <ul class="fwc-resources">
                    {
                        additionalResources.map((resource) => (
                            <li class="fwc-resources__item">
                                <a
                                    href={resource.href}
                                    target={resource.href.startsWith('http') ? '_blank' : undefined}
                                    rel={resource.href.startsWith('http') ? 'nofollow noopener noreferrer' : undefined}
                                    class="fwc-guide__link"
                                >
                                    {resource.title}
                                </a>
                                <span class="fwc-resources__note">{resource.note}</span>
                            </li>
                        ))
                    }
                </ul>
            </section>
    </GuideContentsLayout>
    </div>
</GuideShell>

<style lang="scss">
    .fwc-guide {
        --fwc-display-font: 'Orbitron', var(--heading-font);
        --fwc-body-font: 'Source Sans 3', var(--body-font);
        --fwc-panel-padding-block: var(--component-padding-block);
        --fwc-panel-padding-inline: var(--space-l-xl);
        font-family: var(--fwc-body-font);
    }

    .fwc-panel {
        padding: var(--fwc-panel-padding-block) var(--fwc-panel-padding-inline);
        background: color-mix(in srgb, var(--component-background) 72%, transparent);
        border: 1px solid color-mix(in srgb, var(--border-color) 70%, transparent);
        min-width: 0;
    }

    @media (max-width: 48rem) {
        .fwc-panel {
            --fwc-panel-padding-inline: var(--space-s);
        }
    }

    .fwc-guide__ships {
        display: flex;
        flex-direction: column;
        gap: var(--space-l);
    }

    .fwc-section {
        scroll-margin-top: calc(var(--header-height, 4rem) + var(--space-l));
    }

    .fwc-section__title {
        margin: 0 0 var(--space-m);
        padding-bottom: var(--space-s);
        border-bottom: 1px solid color-mix(in srgb, var(--border-color) 55%, transparent);
        font-family: var(--fwc-display-font);
        font-size: clamp(var(--step-1), 2.5vw, var(--step-2));
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .fwc-section__subtitle {
        margin: var(--space-l) 0 var(--space-m);
        font-family: var(--fwc-display-font);
        font-size: var(--step-0);
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--highlight);
    }

    .fwc-section__paragraph {
        margin: 0 0 var(--space-m);
        font-size: var(--step-0);
        line-height: 1.7;
        max-width: var(--max-text-width);
    }

    .fwc-section__paragraph :global(a) {
        color: var(--highlight);
        text-decoration: underline;
        text-underline-offset: 0.15em;
    }

    .fwc-section__list {
        margin: 0;
        padding-left: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: var(--space-s);
        line-height: 1.65;
        max-width: var(--max-text-width);
    }

    .fwc-section__cover {
        margin: 0 0 var(--space-xl);
    }

    .fwc-section__cover-image,
    .fwc-section__figure-image {
        display: block;
        width: 100%;
        border: 1px solid color-mix(in srgb, var(--border-color) 70%, transparent);
    }

    .fwc-section__figure {
        margin: var(--space-xl) 0 0;
    }

    .fwc-section__figcaption {
        margin-top: var(--space-xs);
        font-size: var(--step--2);
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--text-color-secondary, var(--faded));
    }

    .fwc-resources {
        margin: 0;
        padding: 0;
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: var(--space-m);
        max-width: var(--max-text-width);
    }

    .fwc-resources__item {
        display: flex;
        flex-direction: column;
        gap: var(--space-3xs);
        line-height: 1.55;
    }

    .fwc-resources__note {
        font-size: var(--step--1);
        color: var(--text-color-secondary, var(--faded));
    }

    .fwc-guide__link {
        color: var(--highlight);
        text-decoration: underline;
        text-decoration-color: color-mix(in srgb, var(--fleet-yellow) 45%, transparent);
        text-underline-offset: 0.15em;

        &:hover,
        &:focus-visible {
            color: var(--fleet-yellow);
            text-decoration-color: currentColor;
        }
    }

    .fwc-summary-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(min(100%, 16rem), 1fr));
        gap: var(--space-m);
        margin-top: var(--space-m);
    }

    .fwc-summary-card {
        padding: var(--component-padding-block) var(--space-m);
        background: color-mix(in srgb, var(--component-background) 82%, transparent);
        border: 1px solid color-mix(in srgb, var(--border-color) 70%, transparent);
    }

    .fwc-summary-card__title {
        margin: 0 0 var(--space-s);
        font-family: var(--fwc-display-font);
        font-size: var(--step--1);
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--fleet-red);
    }

    .fwc-summary-card__text {
        margin: 0;
        font-size: var(--step--1);
        line-height: 1.6;
    }

    .fwc-legend {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-xs);
        margin-bottom: var(--space-l);
        padding: var(--space-s);
        background: color-mix(in srgb, var(--component-background) 55%, transparent);
        border: 1px solid color-mix(in srgb, var(--border-color) 55%, transparent);
    }

    .fwc-legend__item {
        display: flex;
        align-items: center;
        gap: var(--space-xs);
        padding: var(--space-xs) var(--space-s);
        background: color-mix(in srgb, var(--component-background) 78%, transparent);
        border: 1px solid color-mix(in srgb, var(--border-color) 60%, transparent);
    }

    .fwc-legend__symbol {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 1.75rem;
        min-height: 1.75rem;
        border-radius: 999px;
        font-family: var(--fwc-display-font);
        font-size: var(--step--1);
        font-weight: 700;
    }

    .fwc-legend__symbol--plusplus { background: color-mix(in srgb, #2ecc71 22%, transparent); color: #7dffb0; }
    .fwc-legend__symbol--plus { background: color-mix(in srgb, #58d68d 18%, transparent); color: #9ef0b8; }
    .fwc-legend__symbol--even { background: color-mix(in srgb, #5dade2 18%, transparent); color: #a8d8ff; }
    .fwc-legend__symbol--minus { background: color-mix(in srgb, #e74c3c 16%, transparent); color: #ff9f96; }
    .fwc-legend__symbol--minusminus { background: color-mix(in srgb, #c0392b 20%, transparent); color: #ff8a80; }
    .fwc-legend__symbol--unknown { background: color-mix(in srgb, var(--faded) 18%, transparent); color: var(--text-color-secondary, var(--faded)); }

    .fwc-legend__label {
        display: flex;
        flex-direction: column;
        gap: 0.1rem;
        font-size: var(--step--1);

        strong {
            font-size: var(--step--1);
        }

        span {
            font-size: var(--step--2);
            color: var(--text-color-secondary, var(--faded));
        }
    }

    @media (min-width: 48rem) {
        .fwc-legend__label {
            flex-direction: row;
            align-items: baseline;
            gap: var(--space-2xs);
        }

        .fwc-legend__label span {
            font-size: var(--step--1);
        }
    }

    .fwc-charts-grid {
        display: flex;
        flex-direction: column;
        gap: var(--space-2xl);
    }

    .fwc-glossary {
        display: grid;
        grid-template-columns: minmax(6rem, 10rem) 1fr;
        gap: var(--space-s) var(--space-l);
        margin: 0 0 var(--space-xl);
    }

    .fwc-glossary__term {
        margin: 0;
        font-weight: 700;
        color: var(--fleet-yellow);
    }

    .fwc-glossary__definition {
        margin: 0;
        line-height: 1.6;
    }

    @media (max-width: 40rem) {
        .fwc-glossary {
            grid-template-columns: 1fr;
        }
    }
</style>
