---
import { i18n } from '@helpers/i18n'
const { t } = i18n(Astro.url)

import ClipboardButton from '@components/blocks/ClipboardButton.astro'
import ComponentBlock from '@components/blocks/ComponentBlock.astro'
import FittingLink from '@components/blocks/FittingLink.astro'
import ItemPicture from '@components/blocks/ItemPicture.astro'
import Tag from '@components/blocks/Tag.astro'
import FixedFluid from '@components/compositions/FixedFluid.astro'
import Flexblock from '@components/compositions/Flexblock.astro'
import FlexInline from '@components/compositions/FlexInline.astro'
import type { GuideFitting } from '@/data/faction-warfare-cruiser-guide'
import type { ResolvedGuideFitting } from '@helpers/guide_fittings'

interface Props {
    fit: ResolvedGuideFitting<GuideFitting>
    shipName: string
}

const { fit, shipName } = Astro.props
const textareaId = `fwc-fit-${fit.id}`
---

<ComponentBlock
    class="fwc-fit-card"
    padding_block="var(--space-s)"
    padding_inline="var(--space-s)"
>
    <Flexblock class="[ fwc-fit-card__layout ]" gap="var(--space-s)">
        <FixedFluid class="[ items-start ]" width="64px" breakpoint="0">
            <ItemPicture
                item_id={fit.shipId}
                item_name={shipName}
                size={64}
            />
            <Flexblock gap="var(--space-3xs)">
                <FlexInline gap="var(--space-3xs)">
                    <Tag text="[NVY]" color="fleet-yellow" narrow={true} />
                </FlexInline>
                <h3 class="[ title ]">{fit.name}</h3>
                <p class="[ description ]">{fit.description}</p>
            </Flexblock>
        </FixedFluid>

        <FlexInline class="[ fwc-fit-card__actions ]">
            {fit.fromLibrary && (
                <FittingLink
                    class="[ action-button ]"
                    fitting_id={fit.resolvedFittingId}
                    is_button={true}
                >
                    {t('view_fitting')}
                </FittingLink>
            )}
            <ClipboardButton
                class="[ action-button ]"
                id={textareaId}
                narrow={true}
                text={t('copy_fitting')}
            >
                {fit.resolvedEftFormat}
            </ClipboardButton>
        </FlexInline>
    </Flexblock>
</ComponentBlock>

<style lang="scss">
    .fwc-fit-card__layout {
        min-width: 0;
    }

    .title {
        margin: 0;
        min-width: 0;
        font-size: var(--step-0);
        line-height: 1.2;
        overflow-wrap: anywhere;
    }

    .description {
        margin: 0;
        font-size: var(--step--1);
        line-height: 1.5;
        color: var(--text-color-secondary, var(--faded));
        overflow-wrap: anywhere;
    }

    .fwc-fit-card__actions {
        gap: var(--space-xs);
        flex-wrap: wrap;
        justify-content: flex-start;
    }

    @media (min-width: 30rem) {
        .fwc-fit-card__actions {
            justify-content: flex-end;
        }
    }
</style>
