---
import { i18n } from '@helpers/i18n'
const { t, translatePath } = i18n(Astro.url)

import type { GuideMeta } from '@/data/guides/types'
import { getGuideCoverImage } from '@/data/guides/covers'

interface Props {
    guide: GuideMeta
}

const { guide } = Astro.props
const guideUrl = guide.path ? translatePath(guide.path) : translatePath(`/guides/${guide.slug}/`)

import Flexblock from '@components/compositions/Flexblock.astro'
import FlexInline from '@components/compositions/FlexInline.astro'
import Wrapper from '@components/compositions/Wrapper.astro'

import Tile from '@components/blocks/Tile.astro'
import PilotBadge from '@components/blocks/PilotBadge.astro'
import CorporationBadge from '@components/blocks/CorporationBadge.astro'
import AllianceBadge from '@components/blocks/AllianceBadge.astro'
import Button from '@components/blocks/Button.astro'
import ClipboardButton from '@components/blocks/ClipboardButton.astro'
---

<Flexblock
    class="[ card component border light-transparency relative ]"
    gap='0'
>
    <Tile
        title={guide.title}
        cover={getGuideCoverImage(guide)}
        alt={guide.title}
        transparent={true}
        soft={false}
        narrow={true}
    >
        <Flexblock slot="subtitle">
            <FlexInline>
                {guide.authors.map(author =>
                    <>{author.entity === 'character' &&
                        <PilotBadge
                            character_id={author.id}
                            character_name={author.name}
                            size={32}
                            centered={true}
                        >
                            <small>{t('author')}</small>
                        </PilotBadge>
                    }</>
                    <>{author.entity === 'corporation' &&
                        <CorporationBadge
                            corporation={{
                                id: author.id,
                                name: author.name,
                                size: 'sm'
                            }}
                        >
                            <small>{t('author')}</small>
                        </CorporationBadge>
                    }</>
                    <>{author.entity === 'alliance' &&
                        <AllianceBadge
                            alliance={{
                                id: author.id,
                                name: author.name,
                                size: 'sm'
                            }}
                        >
                            <small>{t('author')}</small>
                        </AllianceBadge>
                    }</>
                )}
            </FlexInline>
        </Flexblock>
    </Tile>
    <Wrapper
        class="[ pb-(--component-padding-block)! grow ]"
        padding_inline='var(--component-padding-block)'
        padding_block='0'
        max_width='100%'
    >
         <Flexblock
            class="[ justify-between! h-full ]"
            gap='var(--space-l)'
        >
            <p class="[ excerpt ]">{guide.excerpt}</p>
            <FlexInline>
                <Button size='sm' href={guideUrl}>{t('view')}</Button>
                <ClipboardButton id={`guide-${guide.slug}`} text={t('share')}>{guideUrl}</ClipboardButton>
            </FlexInline>
        </Flexblock>
    </Wrapper>
</Flexblock>

<style lang="scss">
    .guide-card-link {
        display: block;
        text-decoration: none;
        color: inherit;
        height: 100%;

        &:hover h3 {
            color: var(--highlight);
        }
    }

    h3 {
        font-size: var(--step-0);
        line-height: 1.25;
        transition: color 0.15s ease;
    }

    .excerpt {
        color: var(--muted-color);
        font-size: var(--step--1);
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
