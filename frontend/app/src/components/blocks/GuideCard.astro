---
import { i18n } from '@helpers/i18n'
const { t, translatePath } = i18n(Astro.url)

import type { GuideMeta } from '@/data/guides/types'
import { getGuideCoverImage } from '@/data/guides/covers'

interface Props {
    guide: GuideMeta
}

const { guide } = Astro.props

import Flexblock from '@components/compositions/Flexblock.astro'
import PictureCard from '@components/blocks/PictureCard.astro'
import Tag from '@components/blocks/Tag.astro'
---

<a class="[ guide-card-link ]" href={translatePath(`/guides/${guide.slug}/`)}>
    <PictureCard
        src={getGuideCoverImage(guide)}
        alt={guide.title}
        narrow={true}
    >
        <div slot="header">
            <Tag color="fleet-red" text={guide.category} />
        </div>
        <Flexblock gap="var(--space-3xs)">
            <h3>{guide.title}</h3>
            <p class="[ excerpt ]">{guide.excerpt}</p>
            <small class="[ text-muted ]">{t('guides.author')}: {guide.author}</small>
        </Flexblock>
    </PictureCard>
</a>

<style lang="scss">
    .guide-card-link {
        display: block;
        text-decoration: none;
        color: inherit;
        height: 100%;

        &:hover h3 {
            color: var(--highlight);
        }
    }

    h3 {
        font-size: var(--step-0);
        line-height: 1.25;
        transition: color 0.15s ease;
    }

    .excerpt {
        color: var(--muted-color);
        font-size: var(--step--1);
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
