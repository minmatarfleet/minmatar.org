---
interface Props {
    padding_inline?: string;
    padding_block?: string;
    max_width?: string;
    centered?: boolean;
    neocom?: boolean;
    [propName: string]: any;
}

const {
    padding_inline = 'var(--space-2xl-3xl)',
    padding_block = 'var(--space-2xl)',
    max_width = '80rem',
    centered = false,
    neocom = false,
    ...attributes
} = Astro.props;

delete attributes.class
---

<div class:list={['wrapper', { 'compensate-neocom': neocom }, Astro.props.class]} {...attributes} data-mod={centered ? 'centered' : ''}>
    <slot />
</div>

<style lang="scss" define:vars={{
    wrapper_padding_inline: padding_inline,
    wrapper_padding_block: padding_block,
    wrapper_max_width: max_width
}}>
    .wrapper {
        padding-block: var(--wrapper_padding_block);
        padding-inline: var(--wrapper_padding_inline);
        max-width: 60ch;
        max-inline-size: var(--wrapper_max_width);

        &.compensate-neocom {
            padding-inline-end: var(--space-l-xl) !important;

            @media screen and (max-width: 600px) {
                padding-inline-start: var(--space-2xs) !important;
                padding-inline-end: var(--space-2xs) !important;
            }
        }
    }
</style>

<style lang="scss" is:global>
    .wrapper {
        display: block;
        padding: 1em;

        &[data-mod="centered"] {
            margin-left: auto;
            margin-right: auto;
        }
    }
</style>