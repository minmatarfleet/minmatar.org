# Copy to .env and fill in. Used by mcps/docker-compose-mcp.yml (Reddit Docker MCP)
# and by local MCP wrapper scripts (run-discord-mcp.sh, run-reddit-mcp.sh).
#
# Keep personal credentials here — do not reuse work Sentry/Google accounts.

# --- Composio (Google Drive + other apps via https://connect.composio.dev/mcp) ---
# Sign up at https://dashboard.composio.dev → AI Clients → Cursor → copy API key.
# Connect Google Drive under Connect Apps in the Composio dashboard.
COMPOSIO_API_KEY=

# --- Reddit (Docker catalog image: mcp/reddit-mcp) ---
# Script app: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=mcp-reddit-agent/0.1

# --- Discord (local JAR MCP only; not used by docker-compose-mcp.yml) ---
# https://discord.com/developers/applications — personal/community bot, Message Content intent
DISCORD_TOKEN=
DISCORD_GUILD_ID=1041384161505722368
