# Copy to .env and fill in. Used by mcps/docker-compose-mcp.yml (Reddit Docker MCP)
# and by local MCP wrapper scripts (run-discord-mcp.sh, run-reddit-mcp.sh).

# --- Reddit (Docker catalog image: mcp/reddit-mcp) ---
# Script app: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=mcp-reddit-agent/0.1

# --- Discord (local JAR MCP only; not used by docker-compose-mcp.yml) ---
# https://discord.com/developers/applications — bot token, Message Content intent as needed
DISCORD_TOKEN=
DISCORD_GUILD_ID=1330189904249612329
